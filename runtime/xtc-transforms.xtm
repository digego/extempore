;; xtc:desugar:intersection* is cl:intersection for
;; an arbirary number of sets (i.e. args)
;; also handles *xtc:codegen:other* which we want
;; to match against anything.
(define xtc:desugar:intersection*
  (lambda args
    (let loop ((a args)
               (res '()))
      (if (null? a)
          res
          (loop (cdr a)
                (if (null? res)
                    (car a)
                    (if (null? (car a))
                        res
                        (cl:intersection (car a) res))))))))




(define xtc:desugar:complex-unify
  (lambda (sym types vars)
    ;; (println 1 'sym: sym 'types: types)

    (set! types (cl:remove-duplicates types))

    ;; (println 2 'sym: sym 'types: types)

    ;; this is here to catch any trailing complex types
    ;; i.e. ((211 2 106) (211 2 106) 211 2 106)
    ;; we turn them into
    ;; ((211 2 106) (211 2 106) (211 2 106))
    (set! types
          (let loop ((lst types))
            (if (null? lst) '()
                (if (or (list? (car lst))
                        (string? (car lst)))
                    (cons (car lst) (loop (cdr lst)))
                    (list lst)))))

    ;; (println 3 'sym: sym 'types: types)

    (set! types (xtc:desugar:type-unify types vars))

    ;; (println 4 'sym: sym 'types: types)

    types))


;; this goes through IN ORDER and returns either:
;; NULL if the lists don't match
;; or
(define xtc:desugar:unify-lists
  (lambda args
                                        ;(println 'unify: args 'norm: (xtc:desugar:type-normalize args))
    (if (null? args)
        args
        (let ((lgths (map (lambda (k) (length k)) args)))
          (if (not (null? (cl:remove (car lgths) lgths)))
              '()
              (let ((result
                     (apply map (lambda args
                                  (let ((l1 (cl:remove '() args)))
                                    (if (null? l1) l1
                                        (let ((l2 (cl:remove-duplicates l1)))
                                          (if (null? l2)
                                              l2
                                              ;;(car l2))))))
                                              (if (= 1 (length l2))
                                                  (car l2)
                                                  '()))))))
                            args)))
                                        ;(println 'result: result)
                (if (member '() result)
                    '()
                    result)))))))



;; this is here to normalize any recursive tuples
;; i.e. put them in their simplist "named" form
;; you can pass in a a complete list of types
;; at the end and have this normalize them
(define xtc:desugar:type-normalize
  (lambda (t)
    (cond ((atom? t) t)
          ((and (list? t)
                (not (null? t))
                (not (xtc:codegen:type? (car t)))
                (number? (car t))
                ;;(= *xtc:codegen:tuple* (modulo (car t) *xtc:codegen:pointer*)))
                (xtc:codegen:tuple? (car t)))
           ;; first check all sub tuples for possible normalization!
           (set! t (map (lambda (a) (xtc:desugar:type-normalize a)) t))
           (let ((named-types (cl:remove-if-not string? t)))
             (if (null? named-types)
                 t
                 (let ((res (map (lambda (k)
                                   ;; (println 'k: k)
                                   (let* ((split (regex:split k "%|(_poly_)"))
                                          (gen-type (if (xtc:cache:get-generictype-candidate-types (cadr split))
                                                        (symbol->string (xtc:cache:get-generictype-candidate-types (cadr split)))
                                                        ""))
                                          ;; (gen-type (symbol->string (xtc:cache:get-generictype-candidate-types (cadr split))))
                                          (named-type (xtc:cache:get-namedtype-type k))
                                          (domatch? (if (and (list? named-type)
                                                             (= (length named-type) (length t)))
                                                        #t #f))
                                          (match (if domatch?
                                                     (map (lambda (a b)
                                                            ;; (println 'aa a 'bb b)
                                                            (if (equal? a b) #t
                                                                (if (and (symbol? a)
                                                                         (regex:match? gen-type (symbol->string a)))
                                                                    #t
                                                                    #f)))
                                                          t ;; type coming in
                                                          named-type)
                                                     (list k))))
                                     (if (member #f match) #f k)))
                                 named-types)))
                   (set! res (cl:remove-if-not string? res))
                   (if (null? res)
                       (xtc:desugar:type-normalize (cdr t))
                       (if (car res)
                           (car res)
                           t))))))
          ((pair? t)
           (cons (xtc:desugar:type-normalize (car t))
                 (xtc:desugar:type-normalize (cdr t)))))))


;; this function is here to support type-unify
;; in the following way:
;;
;; when going through type-unify it is possible
;; for a situation to arrise where a unification
;; over something like this may occur:
;; (("%list--3834748* (112 !head##829 list*##829"))
;;
;; the result for the unification will be "%list-3834748*"
;; check-to-update-generic-vars is here to do a quick
;; check of the (112 !head##829 list*##829) to update
;; any possible vars (such as !head##829) which could get
;; useful information from the "%list--3834748*" before
;; they get thrown away.
(define xtc:desugar:check-to-update-generic-vars
  (lambda (atom lists vars)
    ;; (println 'checktoupdategenericvars: atom 'lists lists 'vars: vars)
    (let ((atom-type (if (string? atom)
                         (xtc:cache:get-namedtype-type atom)
                         atom)))
      ;; (println 'atom: atom 'atom-type atom-type 'lists lists)
      (if (list? atom-type)
          (map (lambda (e)
                 ;; (println 'type-match: atom-type 'against e)
                 (if (and (list? e)
                          (= (length e) (length atom-type)))
                     (if (and (number? (car e))
                              (number? (car atom-type))
                              (= (car e) (car atom-type)))
                         (map (lambda (a b)
                                (if (and (symbol? a)
                                         (xtc:typecheck:vars-ref vars a))
                                    (set! vars (xtc:typecheck:vars-update a vars '() b))))
                              (cdr e)
                              (cdr atom-type)))))
               lists))
      #t)))

(define xtc:desugar:type-unify-closure
  (lambda (t vars)
    ;; (println 'cls: t (flatten-1 t))
    (if (or (null? t)
            (not (list? (car t))))
        t
        (let* ((t1 (flatten-1 t))
               (lgth (length (car t1)))
               (t2 (cl:remove-if (lambda (x) (or (atom? x)
                                            (<> (length x) lgth)))
                                    t1))
               (p2 (map (lambda (i)
                          ;; (println 'i i)
                          (map (lambda (x)
                                 ;; (println 'x x)
                                 (list-ref x i))
                               t2))
                        (range 1 lgth)))
               (p3 (map (lambda (x) (xtc:desugar:type-unify (cl:remove-duplicates x) vars)) p2))
               (p4 (cons 213 p3)))
          ;; (println 'p2 p2 'p3 p3 'p4 p4 't t)
          (set! p4 '())
          (if (null? p4) t2 p4)))))

(define xtc:desugar:occurs-in-type?
  (lambda (sym type)
    (cond ((null? type) #f)
          ((symbol? type) (equal? sym type))
          ((string? type) #f)
          ((number? type) #f)
          ((list? type) (cl:some (lambda (t) (xtc:desugar:occurs-in-type? sym t)) type))
          ((pair? type) (or (xtc:desugar:occurs-in-type? sym (car type))
                            (xtc:desugar:occurs-in-type? sym (cdr type))))
          (else #f))))

;;
;; IF TYPE CANNOT BE UNIFIED SUCCESSFULLY THEN WE SHOULD RETURN NULL '()
;; i.e. if we have ((114 0 0) (14 0 0)) don't return this -> return '()
;;
(define xtc:desugar:type-unify
  (lambda (t vars)
    ;; (println 't: t 'vars: vars)
    (cond ((atom? t)
           (if (and (symbol? t)
                    #t
                    (or (xtc:cache:get-generictype-candidate-types
                         (string->symbol
                          (xtc:codegen:get-base-type
                           (car (string-split-on (car (string-split-on (symbol->string t) "##")) "%")))))
                        (if (and (or (string-contains? (symbol->string t) ":")
                                     (string-contains? (symbol->string t) "{"))
                                 (xtc:cache:get-generictype-candidate-types
                                  (string->symbol (car (xtc:desugar:split-namedtype t)))))
                            #t
                            #f)))
               (xtc:desugar:reify-generic-type t vars '())
               (let ((val (and (symbol? t) (xtc:typecheck:vars-ref vars t))))
                 (if (and val (not (null? val)))
                     ;; directly bound (bare variable, or a symbolic chain):
                     ;; resolve through its value as usual
                     (if (xtc:desugar:occurs-in-type? t val)
                         t
                         (let ((r (xtc:desugar:type-unify val vars)))
                           (if (null? r) t r)))
                     ;; #315: a starred occurrence (!a*) carries no binding of its
                     ;; own --- it is the base variable (!a) at a pointer depth.
                     ;; Resolve the base and re-apply the depth structurally, so
                     ;; !a* reifies to i64* when !a = i64 (the field/parameter
                     ;; relationship is X vs X*, never derived by string surgery).
                     (let ((depth (and (symbol? t)
                                       (xtc:type:bare-bang-var? t)
                                       (xtc:codegen:get-ptr-depth (symbol->string t)))))
                       (if (and depth (> depth 0))
                           (let ((base (xtc:desugar:type-unify (xtc:type:bang-base-key t) vars)))
                             (if (xtc:codegen:type? base)
                                 (xtc:type:deepen-ptr-depth base depth)
                                 t))
                           t))))))
          ((list? t)
           (cond ((xtc:desugar:complex-type? t)
                  (map (lambda (v) (xtc:desugar:type-unify v vars)) t))
                 ((= (length t) 1)
                  (xtc:desugar:type-unify (car t) vars))
                 (else
                  (let* ((ts (xtc:desugar:type-normalize
                              (map (lambda (v)
                                     (let ((vvv (xtc:desugar:type-unify v vars)))
                                       ;; (println 'vvv: vvv)
                                       (xtc:desugar:type-clean vvv)))
                                   t)))
                         (ts1 (cl:remove #f ts))
                         (ts2 (cl:remove-duplicates ts1))
                         (result ts2))
                    ;; (println 1 t 'unified: result)
                    (if (and (= (length result) 1)
                             (xtc:codegen:type? (car result)))
                        (car result) ;; return immediately if we have a result
                        (begin
                          ;; first check result to see if we have a valid named-type (i.e. "%string")
                          (if (and #f
                                   (= (length result) 2) ;; find all occurences of ((112 0 1) "%string--38293482")
                                   (cl:find-if string? result)
                                   (cl:find-if (lambda (k) (not (string? k))) result))
                              (set! result (list (cl:find-if string? result))))

                          ;; (println 2 t 'unified: result)
                          ;; this is here for cases like
                          ;; (!head%a##287 0 1) ;; which should resolve to (0 1) if !head%a##287 has no type
                          (if (and (not (cl:find-if xtc:desugar:complex-type? result))
                                   (not (cl:find-if string? result))
                                   (cl:find-if symbol? result))
                              (set! result (cl:remove-if symbol? result)))

                          ;; (println 3 t 'unified: result)
                          ;; next check to see if we need to do some number crunching
                          ;; basically checking to solve things like
                          ;; ((0 1) 1) which should resolve to 1
                          ;; (0 (0 1) (0 1 2)) which should resolve to 0
                          ;; ((0 1) (0 1 2)) sould resolve to (0 1 2)
                          (if (and (cl:find-if list? result)
                                   (not (cl:find-if xtc:desugar:complex-type? result)))
                              (let ((non-choices (cl:remove-duplicates (cl:remove-if list? result)))
                                    (choices (cl:remove-duplicates (flatten (cl:remove-if atom? ts2)))))
                                (if (and (= (length non-choices) 1)
                                         (member (car non-choices) choices))
                                    (set! result (car non-choices))
                                    (set! result (cl:remove-duplicates (flatten result))))))

                          ;; (println 4 t 'unified: result)
                          ;; if there is a choice between resolved types and unresolved types
                          ;; then obviously we should choose resolved types!
                          (if (list? result)
                              (let ((resolved (cl:remove-duplicates
                                               (cl:remove-if-not (lambda (k)
                                                                   (if (and (xtc:codegen:type? k)
                                                                            (xtc:desugar:complex-type? k))
                                                                       #t #f))
                                                                 result))))
                                (if (not (null? resolved))
                                    ;; (set! result (car resolved)))))
                                    (set! result resolved))))

                          ;; (println 5 t 'unified: result)
                          ;; finally return type (and do generic update check)
                          (if (null? result)
                              result
                              (if (and (not (number? result))
                                       (not (xtc:codegen:type? result))
                                       (list? result)
                                       (xtc:codegen:tuple? (car result)))
                                  (let* ((r1 (cl:remove-if (lambda (x) (not (xtc:codegen:type? x))) result))
                                         (res (cl:remove-duplicates r1))
                                         (resl (length res)))
                                    ;; (println 'res: res)
                                    (if (= resl 1)
                                        (begin
                                          (xtc:desugar:check-to-update-generic-vars (car res) t vars)
                                          (car res))
                                        r1))
                                    ;; (if res res
                                    ;;     (car result))) ;; result is a proper tuple
                                  (if (and (list? result)
                                           (= (length result) 1))
                                      (begin
                                        (xtc:desugar:check-to-update-generic-vars (car result) t vars)
                                        (car result)) ;; if result only has 1 element then return that
                                      ;; result)))))))))
                                      (if (and (list? result)
                                               (xtc:codegen:closure? (car result)))
                                          (xtc:desugar:type-unify-closure result vars)
                                          (if (or (xtc:codegen:type? result) ;; either result is a propert type
                                                  (not (cl:find-if (lambda (k) (not (number? k))) result))) ;; or list of number '(0 1 2 3) for example
                                              result ;; if list is either a propert type OR a list of numeric types (i.e. '(0 1 2))
                                              '()))))))))))) ;; if we still have mixed choice of complex types then return NULL
          ((pair? t)
           (xtc:desugar:type-unify (cdr t) vars))
          (else (xtc:diagnostics:print-bad-type-error t)))))


(define xtc:desugar:generic-type-details
  (lambda (a)
    (if (and (symbol? a)
             (string-contains? (symbol->string a) "##"))
        (let* ((a-parts (string-split-on (symbol->string a) "##"))
               (gname (car a-parts))
               (gnum (string->number (cadr a-parts)))
               (_basename (xtc:codegen:get-base-type gname))
               (name_and_type (xtc:desugar:split-namedtype _basename))
               (basename (car name_and_type))
               (gtype (if (null? (cdr name_and_type)) #f (cadr name_and_type)))
               (b-parts (string-split-on basename "%"))
               (gchar (cdr b-parts))
               (gname2 (car b-parts))
               (gpt (xtc:cache:get-generictype-candidate-types gname2)))
          (if gpt
              (list (string->symbol gname2) gnum (if (null? gchar) "" (car gchar)) (xtc:codegen:get-type-from-pretty-str (symbol->string gpt)) gtype)
              (list (string->symbol gname2) gnum (if (null? gchar) "" (car gchar)) '() gtype)))
        #f)))

;; try to find a type for a !bang from a reified type
;;
;; example use is in xtc:desugar:sym-unify
(define xtc:desugar:check-bang-against-reified
  (lambda (bang-sym reified-sym vars)
    (let ((type (xtc:typecheck:vars-ref vars reified-sym)))
      (if (or (not type) (null? type))
          #f
          (let* ((gtd (xtc:desugar:generic-type-details reified-sym))
                 (gtd2 (xtc:desugar:generic-type-details bang-sym))
                 (gtype (cadddr gtd))
                 (pos (cl:position (car gtd2) gtype)))
            (if (and type pos (list? (car type)) (> (length (car type)) pos))
                (let ((val (list-ref (car type) pos)))
                  val)
                (if (regex:match? (symbol->string reified-sym) "^!g(.*)_.*##([0-9]*)$")
                    (let ((l1 (regex:matched (symbol->string bang-sym) "^!g(.*)_.*##([0-9]*)$"))
                          (l2 (regex:matched (symbol->string reified-sym) "^!g(.*)_.*##([0-9]*)$")))
                      (if (and (= (length l1) (length l2))
                               (> (length l1) 2)
                               (and (string=? (cadr l1) (cadr l2))
                                    (string=? (caddr l1) (caddr l2))))
                          type
                          #f))
                    #f)))))))



(define xtc:desugar:sym-unify
  (lambda (sym types vars)
    ;; if sym is a !bang symbol and has no type set
    ;; then we trawl through vars looking for reified
    ;; types which we might be able to match it against.
    (if (and (null? types)
             (char=? (string-ref (symbol->string sym) 0) #\!))
        (let ((gtd (xtc:desugar:generic-type-details sym)))
          (if gtd
              (xtc:typecheck:vars-for-each
               (lambda (k)
                 (let ((k-types (cdr k)))
                   (if (and (not (null? k-types))
                            (xtc:codegen:type? (car k-types)))
                       (let ((gtd2 (xtc:desugar:generic-type-details (car k))))
                         (if (and gtd2 (= (cadr gtd) (cadr gtd2)))
                             (let ((val (xtc:desugar:check-bang-against-reified sym (car k) vars)))
                               (if val
                                   (set! vars (xtc:typecheck:vars-update sym vars '() val)))))))))
               vars))))

    ;; (if (not (cl:find-if list? types))
    ;;    (begin (set! types (cl:remove-duplicates types)) ;; first normalize and check for duplicates
    ;;     (if (= (length types) 1)
    ;;         (car types) ;; if only 1 element in list return as atom
    ;;         (xtc:desugar:complex-unify types types vars)))
    ;;    (xtc:desugar:complex-unify sym types vars))))

    (let ((result (xtc:desugar:complex-unify sym types vars)))
      ;; (println 'sym: sym 't: types 'result result 'vars: vars)
      (if (and (list? result)
               (= (length result) 1))
          (car result)
          (xtc:desugar:type-clean result)))))



;; unify is a little bit ugly
;; 1st it expands all symbols - during this process vars can be modified (force-var, update-var)
;; 2nd because var can change we check result against var to see if any change to var has improved things
;; 3rd because step 2 may have made changes for the better we should do a final symbol check
;; basically means going through the final result list to see if any symbols left in complex
;; types can be given types.
(define xtc:desugar:unify
  (lambda (vars)
    (let* ((pairs (xtc:typecheck:vars->alist vars))
           (result (map (lambda (v)
                          (let* ((sym (car v))
                                 (pre (cdr v))
                                 (types-unified (xtc:desugar:sym-unify sym pre vars)))
                            (cons sym types-unified)))
                        pairs)))
      (let ((result2 (map (lambda (a)
                            (let ((b-types (xtc:typecheck:vars-ref vars (car a))))
                              (if (null? (cdr a))
                                  (if (and b-types (not (null? b-types)))
                                      (if (= (length b-types) 1)
                                          (cons (car a) (car b-types))
                                          (cons (car a) b-types))
                                      a)
                                  a)))
                          result)))
        result2))))


;; checks to see if a type system is completely unified
(define xtc:desugar:unity?
  (lambda (vars)
    (map (lambda (x)
           (if (xtc:codegen:type? (cdr x)) #t #f))
         vars)))


;; join elements into a list (without including nulls)
(define xtc:desugar:join
  (lambda args
    (cl:remove-if null? args)))


;; this function removes any uneccessary lists
;; it just checks for lists of 1 element and
;; extracts the atom from the list
;;
;; i.e. (211 (2) (211 3 3) (xlist*##123)) should be
;; (211 2 (211 3 3) xlist*##123)
;; (define xtc:desugar:type-clean
;;   (lambda (type)
;;     (if (or (null? type)
;;             (atom? type)
;;             (xtc:codegen:type? type)) ;; (note to andrew) remove this line for GC crash!
;;  type
;;         (map (lambda (k)
;;                (if (list? k)
;;                    (if (= (length k) 1)
;;                        (car k)
;;                        k)
;;                    k))
;;              type))))

(define xtc:desugar:type-clean
  (lambda (type)
    (if (or (null? type)
            (atom? type)
            (xtc:codegen:type? type)) ;; (note to andrew) remove this line for GC crash!
        type
        (map (lambda (k)
               (if (list? k)
                   (if (= (length k) 1)
                       (xtc:desugar:type-clean (car k))
                       (xtc:desugar:type-clean k))
                   k))
             type))))

