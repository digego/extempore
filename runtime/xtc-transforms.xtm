;;                       (if (null? t) ;; if it doesn't we might need to reverse match!
;;                           (xtc:desugar:symbol-expand-reverse-check vs vars all-vs)
;;                           t))))
;;             (begin ;(println 'ccc: vs)
;;               vs))
;;         (cons (xtc:desugar:symbol-expand (car vs) vars all-vs)
