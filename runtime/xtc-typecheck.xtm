(define xtc:typecheck:nativef-poly-exact-check
  (lambda (ast vars kts expected)
    ;; (println 'nateivef-poly-exact: ast 'req: expected)
    (if (or (null? expected)
            (let ((rstr (sexpr->string expected)))
              (or (string-contains? rstr "!")
                  (string-contains? rstr "##"))))  ;; must be generic - exit!
        #f
        (let* ((polyf (string->symbol (car (string-split-on (symbol->string (car ast)) "##")))) ;"\\$\\$\\$"))))
               (ftypes (xtc:cache:get-polyfunc-candidate-types (symbol->string polyf)))
               (asttype (cons 213 (cons expected (map (lambda (a)
                                                        (xtc:desugar:type-unify (xtc:typecheck:type-check a vars kts #f) vars))
                                                      (cdr ast))))))
          (if (not ftypes)
              #f
              (begin
                ;; if no return type is ever required
                ;; then we can ignore it for our checks
                (if (and (list? expected)
                         (equal? *xtc:codegen:notype* (car expected)))
                    (for-each (lambda (ft)
                                (if (equal? (cddr asttype) (cddr ft))
                                    (set! asttype ft)))
                              ftypes))
                (if (and (list? ftypes)
                         (member asttype ftypes))
                    (begin
                      ;; (println 'force-poly (car ast) 'to (list asttype))
                      ;; if exact poly should we force var??
                      (set! vars (xtc:typecheck:vars-force (car ast) vars kts (list asttype)))
                      #t)
                    #f)))))))




(define xtc:typecheck:nativef-poly-check-match-ftypes
  (lambda (args ftypes expected)
    (let* ((ftypes2 (cl:remove-if (lambda (x) (<> (length (cddr x)) (length args))) ftypes))
           (results (map (lambda (type)
                           (map (lambda (ct ft) ;; check args aginst ftype
                                  (if (and (number? ct) (number? ft))
                                      (if (= ct ft) #t #f)
                                      (if (and (string? ct) (string? ft))
                                          (if (string=? ct ft) #t #f)
                                          (if (list? ct)
                                              (if (member ft ct) #t #f) ;; #f
                                              #f))))
                                (if expected
                                    (cons expected args)
                                    args)
                                (if expected
                                    (cdr type)
                                    (cddr type))))
                         ftypes2))
           (hits (map (lambda (r) (length (cl:remove #f r))) results))
           (best (if (null? hits) 0 (apply max hits)))
           (res-types (map (lambda (x y) (cons x y)) (if (null? hits) (make-list (length ftypes2) 0) hits) ftypes2))
           (short-list (cl:remove-if (lambda (x) (<> (car x) best)) res-types))
           (valid (map (lambda (x) (cdr x)) short-list)))
      valid)))


(define xtc:typecheck:nativef-poly-check
  (lambda (ast vars kts expected)
    ;; (println 'poly-checking: ast 'req? expected) ;; 'v: vars)
    (cond ((assoc-strcmp (car ast) kts)
           (begin
             (for-each (lambda (a r)
                         (xtc:desugar:type-unify (xtc:typecheck:type-check a vars kts r) vars))
                       (cdr ast)
                       (cddr (xtc:typecheck:vars-ref vars (car ast)) vars))
             (list (cadr (cdr (assoc-strcmp (car ast) kts))))))
          ((and (xtc:codegen:type? (xtc:desugar:type-unify (xtc:typecheck:vars-ref vars (car ast)) vars))
                (or (equal? expected #f)
                    (equal? expected (xtc:desugar:type-unify (xtc:typecheck:vars-ref vars (car ast)) vars))))
           (begin
             (for-each (lambda (a r)
                         (xtc:desugar:type-unify (xtc:typecheck:type-check a vars kts r) vars))
                       (cdr ast)
                       (cddr (xtc:desugar:type-unify (xtc:typecheck:vars-ref vars (car ast)) vars)))
             (list (cadr (xtc:desugar:type-unify (xtc:typecheck:vars-ref vars (car ast)) vars)))))
          (else
           (let* ((polyf (string->symbol (car (string-split-on (symbol->string (car ast)) "##"))))
                  (ftypes (xtc:cache:get-polyfunc-candidate-types (symbol->string polyf)))
                  (args (map (lambda (x) (xtc:desugar:type-unify (xtc:typecheck:type-check x vars kts #f) vars)) (cdr ast)))
                  (valid-polys (xtc:typecheck:nativef-poly-check-match-ftypes args ftypes expected)))
             ;; (println 'valid: ast 'fs: valid-polys 'args: args 'req: expected)
             (if (null? valid-polys) (xtc:diagnostics:print-compiler-error "no valid polymorphic options" ast))
             (let ((returns (map (lambda (t) (cadr t)) valid-polys)))
               ;; if we have a single valid poly
               ;; then we can try type-checking against
               ;; the correct function signature!
               (if (= 1 (length valid-polys))
                   (map (lambda (a t)
                          (let ((t2 (xtc:desugar:type-unify (xtc:typecheck:type-check a vars kts t) vars)))
                            ;; (println 'a: a 't: t 't2: t2)
                            t2))
                        (cdr ast)
                        (cddr (car valid-polys))))
               ;; (println 'updatepoly: (car ast) 'with: valid-polys)
               ;; update valid-polys to reflect return types (from expected)
               (set! vars (xtc:typecheck:vars-update (car ast) vars kts valid-polys))
               ;;(println 'returns: returns)
               (tc-result returns vars)))))))


