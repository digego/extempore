(define xtc:typecheck:make-uf-cell
  (lambda (val)
    (let ((cell (vector #f 0 val)))
      (vector-set! cell 0 cell)
      cell)))

(define xtc:typecheck:uf-find!
  (lambda (cell)
    (if (eq? (vector-ref cell 0) cell)
        cell
        (let ((root (xtc:typecheck:uf-find! (vector-ref cell 0))))
          (vector-set! cell 0 root)
          root))))

(define xtc:typecheck:uf-union!
  (lambda (a b)
    (let ((ra (xtc:typecheck:uf-find! a))
          (rb (xtc:typecheck:uf-find! b)))
      (if (eq? ra rb)
          ra
          (let ((rank-a (vector-ref ra 1))
                (rank-b (vector-ref rb 1))
                (merged (cl:remove-duplicates
                          (append (vector-ref ra 2) (vector-ref rb 2)))))
            (cond ((< rank-a rank-b)
                   (vector-set! ra 0 rb)
                   (vector-set! rb 2 merged)
                   rb)
                  ((> rank-a rank-b)
                   (vector-set! rb 0 ra)
                   (vector-set! ra 2 merged)
                   ra)
                  (else
                   (vector-set! rb 0 ra)
                   (vector-set! ra 1 (+ rank-a 1))
                   (vector-set! ra 2 merged)
                   ra)))))))

(define xtc:typecheck:uf-value
  (lambda (cell)
    (vector-ref (xtc:typecheck:uf-find! cell) 2)))

(define xtc:typecheck:uf-set-value!
  (lambda (cell val)
    (vector-set! (xtc:typecheck:uf-find! cell) 2 val)))

(define *xtc:typecheck:constraints* '())

(define xtc:typecheck:emit-constraint!
  (lambda (kind lhs rhs)
    (set! *xtc:typecheck:constraints*
          (cons (vector kind lhs rhs) *xtc:typecheck:constraints*))))

(define xtc:typecheck:clear-constraints!
  (lambda () (set! *xtc:typecheck:constraints* '())))

(define xtc:typecheck:solve-constraints
  (lambda (constraints vars kts)
    (for-each
      (lambda (c)
        (let ((kind (vector-ref c 0))
              (lhs (vector-ref c 1))
              (rhs (vector-ref c 2)))
          (cond ((eq? kind 'eq) (xtc:typecheck:update-var lhs vars kts rhs))
                ((eq? kind 'force) (xtc:typecheck:force-var lhs vars kts rhs))
                ((eq? kind 'union)
                 (let ((ca (hashtable-ref vars lhs))
                       (cb (hashtable-ref vars rhs)))
                   (if (and ca cb) (xtc:typecheck:uf-union! ca cb)))))))
      constraints)))

(define xtc:typecheck:vars-ref
  (lambda (vars sym)
    (let ((cell (hashtable-ref vars sym)))
      (if cell
          (xtc:typecheck:uf-value cell)
          #f))))

(define xtc:typecheck:vars-for-each
  (lambda (f vars)
    (hashtable-for-each
      (lambda (entry)
        (f (cons (car entry) (xtc:typecheck:uf-value (cdr entry)))))
      vars)))

(define xtc:typecheck:vars->alist
  (lambda (vars)
    (let ((result '()))
      (hashtable-for-each
        (lambda (entry)
          (set! result (cons (cons (car entry)
                                   (xtc:typecheck:uf-value (cdr entry)))
                             result)))
        vars)
      (sort! result (lambda (a b) (string<? (symbol->string (car a))
                                             (symbol->string (car b))))))))

;; this is here for whenever we get
;; new 'argument' information about
;; a locally bound lambda which might help
;; us to derive new return type information
(define xtc:typecheck:type-check-bound-lambda
  (lambda (sym vars kts t)
    (if (not (assoc-strcmp sym *xtc:globals:bound-lambdas*))
        #f
        (let* ((f (cadr (assoc-strcmp sym *xtc:globals:bound-lambdas*)))
               (args (cadr f))
               (body (caddr f))
               (estr (sexpr->string body))
               (recursive? (regex:match? estr (string-append "(" "\\(\\s*" (symbol->string sym) "\\s" ")|(\\(\\s*callback)")))
               (rettype '()))
          (if (not recursive?)
              (begin
                (if (not (null? t))
                    (for-each (lambda (x y)
                                (set! vars (xtc:typecheck:vars-update x vars kts y)))
                              args (cddr t)))
                (set! rettype (xtc:typecheck:type-check (caddr (cadr (assoc-strcmp sym *xtc:globals:bound-lambdas*)))
                                                  vars kts #f))
                (if (null? t)
                    (let ((argtypes (map (lambda (x)
                                           (car (xtc:typecheck:vars-ref vars x)))
                                         args)))
                      (set! vars (xtc:typecheck:vars-update sym vars kts (cons 213 (cons (car rettype) argtypes))))))
                (if (xtc:codegen:type? rettype)
                    rettype
                    #f)))))))

;; don't allow update to add to kts values
(define xtc:typecheck:update-var
  (lambda (sym vars kts t)
    (if (and (list? t)
             (= (length t) 1)
             (or (string? (car t))
                 (xtc:codegen:type? (car t))))
        (set! t (car t)))
    (set! t (xtc:desugar:type-clean t))
    (set! t (xtc:desugar:type-normalize t))
    ;; #315: a type variable is one identity; writing it with pointer stars
    ;; (!a*) is that same variable at a pointer depth, not a second variable.
    ;; So a starred occurrence never holds its own binding --- it is stored
    ;; under the bare/base key (!a) with the value's pointer depth stripped to
    ;; match, at this single chokepoint, and a starred occurrence is rebuilt
    ;; structurally from the base on resolution (see xtc:desugar:type-unify).  The
    ;; key must be a *bare* type variable (starting with !), not a generic-type
    ;; instance such as CsnD0{!a}* whose trailing star is the tuple pointer.
    (if (and (symbol? sym)
             (xtc:type:bare-bang-var? sym)
             (> (xtc:codegen:get-ptr-depth (symbol->string sym)) 0)
             (xtc:codegen:type? t))
        (let ((reduced (xtc:type:reduce-ptr-depth
                        t (xtc:codegen:get-ptr-depth (symbol->string sym)))))
          (cond
            ;; A value shallower than the variable's pointer depth is the #315
            ;; conflation: the base variable's value (i64) handed to a starred
            ;; occurrence (!a*).  Binding !a* to it would lose the star; drop it
            ;; --- the base binding governs and resolution re-applies the depth.
            ((eq? reduced 'fail) (set! t '()))
            ;; A concretely reducible value moves to the base key at its proper
            ;; (shallower) depth.  A still-symbolic value (reduced = t) is left
            ;; under the starred key untouched: redirecting it to the base would
            ;; bind !a to !a*, a cycle that pollutes the union-find.
            ((not (eq? reduced t))
             (set! t reduced)
             (set! sym (xtc:type:bang-base-key sym))))))
    (if (or (null? t)
            (equal? t #f)
            (xtc:desugar:occurs-in-type? sym t)
            (xtc:cache:nativefunc-exists? (symbol->string sym))
            (equal? sym t))
        'exit
        (begin
          (if (member sym kts)
              '()
              (if (and (not (hashtable-ref vars sym))
                       (not (string-contains? (symbol->string sym) ":["))
                       (not (xtc:cache:closure-exists? (symbol->string sym)))
                       (not (xtc:cache:globalvar-exists? (symbol->string sym))))
                  (begin
                    (if (not (string-contains? (symbol->string sym) "!"))
                        (xtc:diagnostics:print-missing-identifier-error sym 'type))
                    'exit)
                  (let ((existing-types (xtc:typecheck:vars-ref vars sym)))
                    (if existing-types
                        (if (and (symbol? t) (hashtable-ref vars t))
                            (begin
                              (xtc:typecheck:emit-constraint! 'union sym t)
                              (xtc:typecheck:uf-union! (hashtable-ref vars sym) (hashtable-ref vars t)))
                            (begin
                              (if (or (xtc:codegen:type? t)
                                      (xtc:desugar:complex-type? t))
                                  (begin
                                    (if (and (xtc:codegen:closure? t)
                                             (not (xtc:codegen:type? t)))
                                        (let ((res (xtc:typecheck:type-check-bound-lambda sym vars kts t)))
                                          (if res
                                              (set-car! (cdr t) res))))
                                    (if (and (string? t)
                                             (string-contains? (symbol->string sym) "##"))
                                        (let ((gtd (xtc:desugar:generic-type-details sym)))
                                          (xtc:typecheck:reverse-set-bangs-from-reified sym t (cadr gtd) vars)))
                                    (xtc:typecheck:emit-constraint! 'eq sym t)
                                    (xtc:typecheck:uf-set-value!
                                      (hashtable-ref vars sym)
                                      (cl:remove-duplicates (append (list t) existing-types))))
                                  (begin
                                    (xtc:typecheck:emit-constraint! 'eq sym t)
                                    (xtc:typecheck:uf-set-value!
                                      (hashtable-ref vars sym)
                                      (cl:remove-duplicates (append t existing-types)))))))
                        '()))))))))


(define xtc:typecheck:force-var
  (lambda (sym vars kts t)
    (if (and (list? t)
             (= (length t) 1)
             (string? (car t)))
        (set! t (car t)))
    (set! t (xtc:desugar:type-clean t))
    (set! t (xtc:desugar:type-normalize t))
    (if (and (not (hashtable-ref vars sym))
             (not (xtc:cache:closure-exists? (symbol->string sym)))
             (not (xtc:cache:globalvar-exists? (symbol->string sym))))
        (xtc:diagnostics:print-missing-identifier-error sym 'variable)
        (let ((cell (hashtable-ref vars sym)))
          (if cell
              (begin
                (xtc:typecheck:emit-constraint! 'force sym t)
                (if (xtc:codegen:type? t)
                    (begin
                      (if (and (string? t)
                               (string-contains? (symbol->string sym) "##"))
                          (let ((gtd (xtc:desugar:generic-type-details sym)))
                            (xtc:typecheck:reverse-set-bangs-from-reified sym t (cadr gtd) vars)))
                      (xtc:typecheck:uf-set-value! cell (list t)))
                    (xtc:typecheck:uf-set-value! cell t)))
              '())))))


(define xtc:typecheck:get-var
  (lambda (sym vars)
    (if (not (symbol? sym))
        (xtc:diagnostics:print-missing-identifier-error sym 'variable)
        (let ((types (xtc:typecheck:vars-ref vars sym)))
          (if (not types)
              (if (xtc:cache:globalvar-exists? (symbol->string sym))
                  (cons sym (xtc:codegen:strip-ptr-depth (xtc:cache:get-globalvar-type (symbol->string sym))))
                  (xtc:diagnostics:print-missing-identifier-error sym 'variable))
              (cons sym types))))))


(define xtc:typecheck:clear-all-vars
  (lambda (vars)
    (hashtable-for-each
      (lambda (entry) (xtc:typecheck:uf-set-value! (cdr entry) '()))
      vars)))

(define tc-result (lambda (type vars) (vector type vars)))
(define tc-type (lambda (r) (vector-ref r 0)))
(define tc-vars (lambda (r) (vector-ref r 1)))
(define tc-unwrap (lambda (r) (if (vector? r) (tc-type r) r)))

(define xtc:typecheck:synth-mode?
  (lambda (expected)
    (or (not expected)
        (null? expected)
        (equal? expected *xtc:codegen:notype*)
        (and (list? expected) (= (length expected) 1)
             (equal? (car expected) *xtc:codegen:notype*)))))

(define xtc:typecheck:normalise-expected
  (lambda (expected)
    (cond ((not expected) #f)
          ((null? expected) #f)
          ((equal? expected *xtc:codegen:notype*) #f)
          ((and (list? expected) (= (length expected) 1)
                (equal? (car expected) *xtc:codegen:notype*)) #f)
          ((and (list? expected) (= (length expected) 1)) (car expected))
          (else expected))))

(define xtc:typecheck:check-type
  (lambda (expected)
    (if (xtc:typecheck:synth-mode? expected) #f expected)))

(define xtc:typecheck:subsume
  (lambda (synthesised expected vars)
    (if (not expected)
        synthesised
        (let ((unified (xtc:desugar:type-unify (list synthesised expected) vars)))
          (if (null? unified) synthesised unified)))))

(define xtc:typecheck:vars-set
  (lambda (sym new-types vars)
    (let ((cell (hashtable-ref vars sym)))
      (if cell
          (xtc:typecheck:uf-set-value! cell new-types)
          (hashtable-set! vars sym (xtc:typecheck:make-uf-cell new-types))))
    vars))

(define xtc:typecheck:vars-update
  (lambda (sym vars kts t)
    (xtc:typecheck:update-var sym vars kts t)
    vars))

(define xtc:typecheck:vars-force
  (lambda (sym vars kts t)
    (xtc:typecheck:force-var sym vars kts t)
    vars))

(define xtc:typecheck:vars-add
  (lambda (sym vars)
    (hashtable-set! vars sym (xtc:typecheck:make-uf-cell '()))
    vars))

(define xtc:typecheck:vars-snapshot
  (lambda (vars)
    (let ((ht (make-hashtable (max 64 (* 2 (hashtable-count vars))))))
      (hashtable-for-each
        (lambda (entry)
          (hashtable-set! ht (car entry)
            (xtc:typecheck:make-uf-cell (xtc:typecheck:uf-value (cdr entry)))))
        vars)
      ht)))

(define xtc:typecheck:vars-clear
  (lambda (vars)
    (let ((ht (make-hashtable (max 64 (* 2 (hashtable-count vars))))))
      (for-each (lambda (key) (hashtable-set! ht key (xtc:typecheck:make-uf-cell '())))
                (hashtable-keys vars))
      ht)))


;; resolve "string" types by looking up get-named-type
;; resolve 'symbol types by looking in vars
;; otherwise just return t
(define xtc:typecheck:try-to-resolve-named-types
  (lambda (t vars)
    (if (string? t)
        (let ((t (xtc:cache:get-namedtype-type t))
              (ptr-level (xtc:codegen:get-ptr-depth t)))
          (dotimes (i ptr-level) (set! t (xtc:codegen:add-ptr-depth t)))
          (list t))
        (if (symbol? t)
            (let ((types (xtc:typecheck:vars-ref vars t)))
              (if (not types) '() types))
            t))))



(define xtc:typecheck:numeric-check
  (lambda (ast vars kts expected)
    ;; (println 'numeric-check 'ast: ast (integer? ast) 'expected expected)
    (if *xtc:globals:print-sub-checks* (println 'num:> 'ast: ast 'expected expected))
    (if (and expected
             (not (null? expected)))
        (cond ((symbol? expected)
               (let* ((t1 (tc-unwrap (xtc:typecheck:symbol-check expected vars kts #f)))
                      (t2 (xtc:typecheck:numeric-check ast vars kts #f))
                      (t3 (cl:intersection t1 t2)))
                 (if (null? t1) t2 t3)))
              ((list? expected)
               (let* ((t1 (xtc:typecheck:numeric-check ast vars kts #f))
                      (t2 (cl:intersection expected t1)))
                 t2))
              ((number? expected)
               (let* ((t1 (xtc:typecheck:numeric-check ast vars kts #f))
                      (t2 (cl:intersection (list expected) t1)))
                 t2))
              ((string? expected)
               (let* ((t1 (xtc:typecheck:numeric-check ast vars kts #f))
                      (t2 (cl:intersection (list expected) t1)))
                 t2))
              (else
               (print-with-colors 'red 'default #t (print "Compiler Error:"))
               (print "shouldn't reach here in numeric check il- expected: ")
               (print-with-colors 'blue 'default #f (print expected))
               (print "\nYou might be using a ")
               (print-with-colors 'blue 'default #t (print "pref"))
               (print " where you should be using a ")
               (print-with-colors 'blue 'default #t (print "tref"))
               (println)
               (throw "")))
        (if (integer? ast)  ;; preference goes to start of list
            (if (or (= 1 ast) (= 0 ast))
                (list *xtc:codegen:si64* *xtc:codegen:si32* *xtc:codegen:si16* *xtc:codegen:ui8* *xtc:codegen:i1*)
                (if (< ast 256)
                    (list *xtc:codegen:si64* *xtc:codegen:si32* *xtc:codegen:si16* *xtc:codegen:ui8*)
                    (list *xtc:codegen:si64* *xtc:codegen:si32* *xtc:codegen:si16*)))  ;*xtc:codegen:fp64* *xtc:codegen:fp32*))
            (list *xtc:codegen:fp64* *xtc:codegen:fp32*)))))





(define xtc:typecheck:symbol-check
  (lambda (ast vars kts expected)
    (if (not (symbol? ast))
        (xtc:diagnostics:print-compiler-error "Trying to symbol check a non-symbol" ast)
        (let ((ast-str (symbol->string ast)))
          (cond ((assoc-strcmp ast kts)
                 (tc-result (list (xtc:typecheck:vars-ref vars ast)) vars))
                ((and
                  (xtc:typecheck:vars-ref vars ast)
                  (xtc:codegen:type? (xtc:desugar:type-unify (xtc:typecheck:vars-ref vars ast) vars))
                  (if expected
                      (equal? expected (xtc:desugar:type-unify (xtc:typecheck:vars-ref vars ast) vars))
                      #t))
                 (tc-result (list (xtc:desugar:type-unify (xtc:typecheck:vars-ref vars ast) vars)) vars))
                ((xtc:cache:globalvar-exists? ast-str)
                 (tc-result (list (xtc:codegen:strip-ptr-depth (xtc:cache:get-globalvar-type ast-str))) vars))
                ((xtc:cache:nativefunc-exists? ast-str)
                 (tc-result (list (xtc:cache:get-nativefunc-type ast-str)) vars))
                ((xtc:cache:closure-exists? ast-str)
                 (tc-result (list (cons (+ *xtc:codegen:closure* *xtc:codegen:pointer* *xtc:codegen:pointer*)
                                        (map xtc:codegen:get-type-from-str (xtc:cache:get-closure-arg-types ast-str)))) vars))
                (else
                 (let ((ast-base (xtc:codegen:get-base-type ast-str)))
                   (if (and (symbol? ast)
                            (xtc:cache:genericfunc-exists? (string->symbol ast-base)))
                       (begin
                         (xtc:diagnostics:print-compiler-error "Try forcing a type? Ambiguous generic function as value" ast)))
                   (if (and (symbol? ast)
                            (xtc:cache:polyfunc-exists? ast-base))
                       (let ((pt (xtc:cache:get-polyfunc-candidate-types ast-base)))
                         (cond ((and (> (length pt) 1)
                                     (assoc expected pt))
                                (if (xtc:typecheck:vars-ref vars ast) (set! vars (xtc:typecheck:vars-update ast vars kts (list expected))))
                                (set! ast (string->symbol (string-append ast-base ":" (xtc:codegen:pretty-print-type expected)))))
                               ((= (length pt) 1)
                                (if (xtc:typecheck:vars-ref vars ast) (set! vars (xtc:typecheck:vars-update ast vars kts pt)))
                                (set! ast (string->symbol (string-append ast-base ":" (xtc:codegen:pretty-print-type (car pt))))))
                               (else
                                (xtc:diagnostics:print-compiler-error
                                 "Try forcing a type? Ambiguous polymorphic function as a value" ast)))))
                   (set! ast-str (symbol->string ast))
                   (if *xtc:globals:print-sub-checks* (println 'sym:> 'ast: ast 'expected expected))
                   (let ((polytype #f))
                     (if (and (not (xtc:typecheck:vars-ref vars ast))
                              (not (xtc:cache:closure-exists? ast-str))
                              (not (xtc:cache:globalvar-exists? ast-str)))
                         (if (string-contains? ast-str ":")
                             (let ((p (regex:type-split ast-str ":")))
                               (if (or (xtc:cache:genericfunc-exists? (string->symbol (car p)))
                                       (xtc:cache:polyfunc-exists? (car p)))
                                   (let* ((t (if (xtc:cache:typealias-exists? (cadr p))
                                                 (xtc:codegen:pretty-print-type (xtc:cache:get-typealias-type (cadr p)))
                                                 (cadr p)))
                                          (etype (cname-encode (xtc:codegen:get-base-type t))))
                                     (set! expected #f)
                                     (if (xtc:cache:polyfunc-exists? (car p))
                                         (set! ast (string->symbol (string-append (car p) "_adhoc_" etype)))
                                         (set! ast (string->symbol (string-append (car p) "_poly_" etype))))
                                     (set! polytype (xtc:codegen:get-type-from-pretty-str t)))
                                   (xtc:diagnostics:print-missing-identifier-error ast 'symbol)))
                             (xtc:diagnostics:print-missing-identifier-error ast 'symbol)))
                     (set! ast-str (symbol->string ast))
                     (let ((type (if polytype polytype
                                     (if (xtc:typecheck:vars-ref vars ast)
                                         (xtc:typecheck:vars-ref vars ast)
                                         (if (xtc:cache:closure-exists? ast-str)
                                             (list (cons (+ *xtc:codegen:closure* *xtc:codegen:pointer* *xtc:codegen:pointer*) (map xtc:codegen:get-type-from-str (xtc:cache:get-closure-arg-types ast-str))))
                                             (list (xtc:codegen:strip-ptr-depth (xtc:cache:get-globalvar-type ast-str))))))))
                       (if (and expected
                                (not (member ast kts))
                                (not (null? expected)))
                           (if (null? type)
                               (begin
                                 (set! vars (xtc:typecheck:vars-update ast vars kts (list expected)))
                                 (tc-result expected vars))
                               (let ((intersection (xtc:desugar:type-unify (list expected type) vars)))
                                 (if (not (null? intersection))
                                     (begin
                                       (set! vars (xtc:typecheck:vars-force ast vars kts (list intersection)))
                                       (tc-result (list intersection) vars))
                                     (tc-result type vars))))
                           (tc-result type vars)))))))))))


(define *math-recursion-check-depth* 0)

(define xtc:typecheck:math-check
  (lambda (ast vars kts expected)
    (if (not expected)
        (begin (if (member (cadr ast) kts) (set! expected (xtc:typecheck:vars-ref vars (cadr ast))))
               (if (member (caddr ast) kts) (set! expected (xtc:typecheck:vars-ref vars (caddr ast))))))
    ;; now start type checking
    (let* ((n1 (cadr ast))
           (n2 (caddr ast))
           (a (xtc:desugar:type-unify (xtc:typecheck:type-check n1 vars kts expected) vars))
           (b (xtc:desugar:type-unify (xtc:typecheck:type-check n2 vars kts expected) vars))
           (t (xtc:desugar:type-unify (cl:remove #f (list (if (null? a) #f a) (if (null? b) #f b))) vars)))
      (if (equal? a #f) (set! a '()))
      (if (equal? b #f) (set! b '()))
      ;; (println 'math: 'a a 'b b 't t 'r expected 'ast: ast *math-recursion-check-depth*)

      (set! *math-recursion-check-depth* (+ *math-recursion-check-depth* 1))
      ;; if we can fully unify on 't'
      ;; then we might need to retypecheck a or b
      (if (xtc:codegen:type? t)
          (begin
            (if (and (list? a)
                     (list? n1)
                     (xtc:typecheck:vars-ref vars (car n1)))
                (begin (set! vars (xtc:typecheck:vars-force (car n1) vars kts '()))
                       (xtc:typecheck:type-check n1 vars kts t)))
            (if (and (list? b)
                     (list? n2)
                     (xtc:typecheck:vars-ref vars (car n2)))
                (begin (set! vars (xtc:typecheck:vars-force (car n2) vars kts '()))
                       (xtc:typecheck:type-check n2 vars kts t)))))
      ;; one more try for equality!
      (if (and
           (not (equal? a b))
           (xtc:codegen:type? t)
           (< *math-recursion-check-depth* 6))
          (begin
            (set! a (xtc:typecheck:type-check n1 vars kts t))
            (set! b (xtc:typecheck:type-check n2 vars kts t))))
      ;; and one more try
      (if (and
           (not (equal? a b))
           (< *math-recursion-check-depth* 6))
          (let* ((a2 (xtc:typecheck:type-check n1 vars kts b))
                 (b2 (xtc:typecheck:type-check n2 vars kts a))
                 (t2 (xtc:desugar:type-unify (list a2 b2) vars)))
            ;; (println 't2 t2 'a a 'b b 'a2 a2 'b2 b2 'ast ast)
            (if (xtc:codegen:type? t2)
                (begin (set! a t2)
                       (set! b t2)))))

      (set! *math-recursion-check-depth* 0)

      (if (and (not (equal? a b))
               (xtc:codegen:type? b)
               (xtc:codegen:type? a)
               (not (or (xtc:codegen:tuple? a)
                        (xtc:codegen:tuple? b)))
               (not (and (xtc:codegen:vector? a)   ;; we are allowed to multiply
                         (xtc:codegen:vector? b)))) ;; a Vector by a Vector*
          (xtc:diagnostics:print-type-conflict-error (xtc:codegen:pretty-print-type a)
                                                   (xtc:codegen:pretty-print-type b)
                                                   ast))
      (if (and (xtc:codegen:type? t)
               (xtc:codegen:pointer? t)
               (not (xtc:codegen:tuple? t))
               (not (xtc:codegen:vector? t)))
          (xtc:diagnostics:print-type-mismatch-error (xtc:codegen:pretty-print-type t) "number" (symbol->string (car ast))))
      (if *xtc:globals:print-sub-checks* (println 'math:> 'ast: ast 'a: a 'b: b 't: t 'expected expected))
      (if (not (null? t))
          (begin (if (and (symbol? (cadr ast)) (not (xtc:codegen:tuple? t))) (set! vars (xtc:typecheck:vars-force (cadr ast) vars kts t)))
                 (if (and (symbol? (caddr ast)) (not (xtc:codegen:tuple? t))) (set! vars (xtc:typecheck:vars-force (caddr ast) vars kts t)))
                 (tc-result
                  (if (and (not (null? t)) ;; this here because math functions always return non-pointer vectors
                           (xtc:codegen:type? t)
                           (xtc:codegen:vector? t) ;; we want to do this because these vectors are always stack allocated
                           (xtc:codegen:pointer? t)) ;; also these vectors are immutable (i.e. cannot use vector-set!)
                      (xtc:codegen:strip-ptr-depth t)
                      t)
                  vars))
          (cond ((xtc:codegen:vector? a)
                 (if (symbol? (cadr ast)) (set! vars (xtc:typecheck:vars-update (cadr ast) vars kts a)))
                 (tc-result (if (xtc:codegen:pointer? a) (xtc:codegen:strip-ptr-depth a) a) vars))
                ((xtc:codegen:vector? b)
                 (if (symbol? (caddr ast)) (set! vars (xtc:typecheck:vars-update (cadr ast) vars kts b)))
                 (tc-result (if (xtc:codegen:pointer? b) (xtc:codegen:strip-ptr-depth b) b) vars))
                ((not (cl:find-if symbol? (cdr ast))) (tc-result t vars)) ;; return t
                ((and (symbol? (cadr ast))
                      (symbol? (caddr ast))
                      (not (null? (cdr (xtc:typecheck:get-var (cadr ast) vars))))
                      (not (null? (cdr (xtc:typecheck:get-var (caddr ast) vars)))))
                 ;; if both are symbols and their types cannot unify on anything
                 ;; then we have a problem!  So force both types to NULL
                 (set! vars (xtc:typecheck:vars-force (cadr ast) vars kts '()))
                 (set! vars (xtc:typecheck:vars-force (caddr ast) vars kts '()))
                 (tc-result t vars)) ;; and return t (which should be NULL)
                ((and (symbol? (cadr ast)) (not (null? b)))
                 (set! vars (xtc:typecheck:vars-update (cadr ast) vars kts b))
                 (tc-result b vars)) ;; return b
                ((and (symbol? (caddr ast)) (not (null? a)))
                 (set! vars (xtc:typecheck:vars-update (caddr ast) vars kts a))
                 (tc-result a vars)) ;; return a
                (else (tc-result t vars)))))))

(define xtc:typecheck:math-intrinsic-check
  (lambda (ast vars kts expected)
    ;; (println 'intrinsic: ast 'r: expected)
    (let* ((args (- (length ast) 1))
           (a (xtc:desugar:type-unify (xtc:typecheck:type-check (cadr ast) vars kts expected) vars))
           (b (if (> args 1)
                  (xtc:desugar:type-unify (xtc:typecheck:type-check (caddr ast) vars kts expected) vars)
                  #f))
           (c (if (> args 2)
                  (xtc:desugar:type-unify (xtc:typecheck:type-check (cadddr ast) vars kts expected) vars)
                  #f)))
      (if (null? a) (set! a b))
      (if (null? b) (set! b a))
      ;; (println 'a a 'b b 'c c 'r: expected 'ast ast)
      ;; if (cadr ast) is a symbol update it
      (if (and (symbol? (cadr ast))
               (xtc:codegen:type? a))
          (set! vars (xtc:typecheck:vars-update (cadr ast) vars kts a)))
      (if (and (not (list? a))
               (xtc:codegen:fixed-point? a))
          (xtc:diagnostics:print-bad-type-error (xtc:codegen:pretty-print-type a)
                                              (string-append "Only real numbers are supported for math intrinsics: "
                                                             (symbol->string (car ast)))))
      (if (and (xtc:codegen:type? a)
               (xtc:codegen:vector? a)
               (xtc:codegen:pointer? a))
          (xtc:diagnostics:print-bad-type-error (xtc:codegen:pretty-print-type a)
                                              (string-append "\nVector math intrinsics do not support pointers\nTry dereferencing your vector: " (sexpr->string ast))))
      (if (and (xtc:codegen:type? a)
               (xtc:codegen:vector? a))
          (if (or (and (= (caddr a) 1)
                       (not (member (cadr a) '(4 8))))
                  (and (= (caddr a) 0)
                       (not (member (cadr a) '(2 4)))))
              (xtc:diagnostics:print-bad-type-error (xtc:codegen:pretty-print-type a)
                                                  (string-append "\nVector size not supported by math intrinsics\nFor floats try 4 or 8 - for doubles try 2 or 4\n" (sexpr->string ast)))))
      (if (and b
               (not (equal? a b))
               (not (number? (cadr ast)))
               (not (number? (caddr ast))))
          (xtc:diagnostics:print-type-conflict-error (xtc:codegen:pretty-print-type a)
                                                   (xtc:codegen:pretty-print-type b)
                                                   ast)
          (if (and b
                   (not (equal? a b))
                   (number? (cadr ast)))
              (tc-result (list b) vars)
              (tc-result (list a) vars))))))

(define xtc:typecheck:compare-check
  (lambda (ast vars kts expected)
    (let* ((n1 (if (number? (cadr ast)) (caddr ast) (cadr ast)))
           (n2 (if (number? (cadr ast)) (cadr ast) (caddr ast)))
           (a (xtc:desugar:type-unify (xtc:typecheck:type-check n1 vars kts #f) vars)) ;; removed expected
           (b (xtc:desugar:type-unify (xtc:typecheck:type-check n2 vars kts #f) vars)) ;; removed expected
           (t (xtc:desugar:type-unify (list a b) vars)))
      ;; (println 'a a 'b b 't t 'req? expected)
      ;; if we can unify on 't'
      ;; then we might need to retypecheck a or b
      (if (xtc:codegen:type? t)
          (begin
            (if (and (list? a)
                     (list? n1)
                     (xtc:typecheck:vars-ref vars (car n1)))
                (begin (set! vars (xtc:typecheck:vars-force (car n1) vars kts '()))
                       (xtc:typecheck:type-check n1 vars kts t)))
            (if (and (list? b)
                     (list? n2)
                     (xtc:typecheck:vars-ref vars (car n2)))
                (begin (set! vars (xtc:typecheck:vars-force (car n2) vars kts '()))
                       (xtc:typecheck:type-check n2 vars kts t)))))
      (if *xtc:globals:print-sub-checks* (println 'compare:> 'ast: ast 'a: a 'b: b 't: t 'expected expected))
      (if (not (null? t))
          (begin (if (symbol? (cadr ast)) (set! vars (xtc:typecheck:vars-force (cadr ast) vars kts t)))
                 (if (symbol? (caddr ast)) (set! vars (xtc:typecheck:vars-force (caddr ast) vars kts t)))
                 (tc-result
                  (if (and (not (null? t))
                           (xtc:codegen:vector? t))
                      (if (xtc:codegen:pointer? t)
                          (list (- (car t) *xtc:codegen:pointer*) (cadr t) *xtc:codegen:i1*)
                          (list (car t) (cadr t) *xtc:codegen:i1*))
                      ;; (if (and (xtc:codegen:tuple? t)
                      ;;          (not (xtc:codegen:pointer? t)))
                      (if (xtc:codegen:tuple? t)
                          t
                          (list *xtc:codegen:i1*)))
                  vars))
          (cond ((xtc:codegen:vector? a)
                 (if (symbol? (cadr ast)) (set! vars (xtc:typecheck:vars-update (cadr ast) vars kts a)))
                 (let ((retvec (if (xtc:codegen:pointer? a) (xtc:codegen:strip-ptr-depth a) a)))
                   (tc-result (list (car retvec) (cadr retvec) *xtc:codegen:i1*) vars)))
                ((xtc:codegen:vector? b)
                 (if (symbol? (caddr ast)) (set! vars (xtc:typecheck:vars-update (cadr ast) vars kts b)))
                 (let ((retvec (if (xtc:codegen:pointer? b) (xtc:codegen:strip-ptr-depth b) b)))
                   (tc-result (list (car retvec) (cadr retvec) *xtc:codegen:i1*) vars)))
                ;; ((or (and (xtc:codegen:tuple? a) (not (xtc:codegen:pointer? a)))
                ;;      (and (xtc:codegen:tuple? b) (not (xtc:codegen:pointer? b))))
                ;;  (list (if (xtc:codegen:tuple? a) a b)))
                ((or (xtc:codegen:tuple? a)
                     (xtc:codegen:tuple? b))
                 (tc-result (list (if (xtc:codegen:tuple? a) a b)) vars))
                ((not (cl:find-if symbol? (cdr ast))) (tc-result (list *xtc:codegen:i1*) vars)) ;; return t
                ((and (symbol? n1)
                      (symbol? n2)
                      (not (null? (cdr (xtc:typecheck:get-var n1 vars))))
                      (not (null? (cdr (xtc:typecheck:get-var n2 vars)))))
                 ;; if both are symbols and their types cannot unify on anything
                 ;; then we have a problem!  So force both types to NULL
                 (set! vars (xtc:typecheck:vars-force n1 vars kts '()))
                 (set! vars (xtc:typecheck:vars-force n2 vars kts '()))
                 (tc-result (list *xtc:codegen:i1*) vars)) ;; and return t (which should be NULL)
                ((and (symbol? n1) (not (null? b)))
                 (set! vars (xtc:typecheck:vars-update n1 vars kts b))
                 (tc-result (list *xtc:codegen:i1*) vars)) ;; return b
                ((and (symbol? n2) (not (null? a)))
                 (set! vars (xtc:typecheck:vars-update n2 vars kts a))
                 (tc-result (list *xtc:codegen:i1*) vars)) ;; return a
                (else (tc-result (list *xtc:codegen:i1*) vars)))))))


;; with _native functions
(define xtc:typecheck:nativef-check
  (lambda (ast vars kts expected)
    ;; (println 'type-checking: (car ast))
    ;; (println 'native-check 'ast: ast 'vars: vars 'request: expected)
    (let* ((name (symbol->string (car ast)))
           (ftype (map xtc:codegen:get-type-from-str
                       (or (xtc:cache:get-nativefunc-arg-types name)
                           (xtc:cache:get-closure-arg-types name)))))
      (if *xtc:globals:print-sub-checks* (println 'ftype:> 'ast: ast 'type: ftype))

      (if (<> (length ftype)
              (length ast))
          (xtc:diagnostics:print-compiler-error "bad arity in call" ast))

      ;; we don't care what we get back because we already know the return type
      (for-each (lambda (a t)
                  ;; if a is a symbol then add type t to a
                  ;; we also know that for native functions there
                  ;; is no choice about the type so we should
                  ;; force it to the type not update it
                                        ;(if (symbol? a) (xtc:typecheck:force-var a vars kts t))
                  (if (and t (symbol? a)) (set! vars (xtc:typecheck:vars-update a vars kts t)))
                  (xtc:typecheck:type-check a vars kts t))
                (cdr ast)
                (cdr ftype))
      (tc-result (list (car ftype)) vars))))


;; this takes a type like
;; "%List--PFBhaXI6PGk2NCxpNjQ_KixMaXN0Kj4*"
;; which decodes to: "<Pair:<i64,i64>*,List*>"
;; and unwraps it into (114 (114 2 2) (114 !a List*))
;; it must be recursive because a naive unwrap gives
;; (114 "%Pair--..." "%List--...")
(define xtc:typecheck:completely-unwrap-named-type
  (lambda (x)
    (if (and (string? x)
             (char=? (string-ref x 0) #\%)
             (string-contains? x "_poly_")
             (if (null? (xtc:cache:get-named-type x))
                 (xtc:diagnostics:print-missing-identifier-error x 'type)
                 #t))
        (let* ((gpolyname (regex:replace-all x "^%(.*)_poly_.*$" "$1"))
               (ptrdepth (xtc:codegen:get-ptr-depth x))
               (gpoly (cons (+ *xtc:codegen:tuple* (* *xtc:codegen:pointer* ptrdepth))
                            (map (lambda (x)
                                   (string->symbol x))
                                 (xtc:codegen:get-pretty-tuple-arg-strings
                                  (symbol->string (xtc:cache:get-generictype-candidate-types gpolyname)))))))
          (xtc:typecheck:completely-unwrap-named-type
           (replace-all (xtc:codegen:get-type-from-str (xtc:cache:get-named-type x)) (list (cons x gpoly)))))
        (if (list? x)
            (map (lambda (y)
                   (xtc:typecheck:completely-unwrap-named-type y))
                 x)
            x))))

(define xtc:typecheck:descending-generic-type-match
  (lambda (a b)
    (cond ((equal? a b) #t)
          ((atom? a)
           (if (and (symbol? a)
                    (char=? (string-ref (symbol->string a) 0) #\!))
               #t
               #f))
          ((atom? b)
           (if (and (symbol? b)
                    (char=? (string-ref (symbol->string b) 0) #\!))
               #t
               #f))
          (else
           (if (member #f
                       (map (lambda (x y)
                              (xtc:typecheck:descending-generic-type-match x y))
                            a b))
               #f #t)))))


;; match two explicit generic types!
;; returns true for a match of false for a fail
(define xtc:typecheck:generic-types-matchup?
  (lambda (aa bb vars)
    ;; (println 'trying 'to 'match 'generic 'type aa 'against 'generic 'type bb)
    (if (or (not (symbol? aa))
            (not (or (string? bb) (symbol? bb)))
            (not (string-contains? (symbol->string aa) ":")))
        #f
        (let* ((a (symbol->string aa))
               (b (if (symbol? bb) (symbol->string bb) bb))
               (p1a (regex:type-split a "##"))
               (p1b (regex:type-split b "##"))
               (p2a (regex:type-split (car p1a) ":"))
               (p2b (regex:type-split (car p1b) ":"))
               (t1a (if (not (null? (cdr p2a)))
                        (xtc:codegen:get-type-from-pretty-str (cadr p2a)) '()))
               (t1b (if (not (null? (cdr p2b)))
                        (xtc:codegen:get-type-from-pretty-str (cadr p2b)) '()))
               (au (if (and (xtc:typecheck:vars-ref vars aa)
                            (= (length (xtc:typecheck:vars-ref vars aa)) 1))
                       (car (xtc:typecheck:vars-ref vars aa))))
               (bu (if (and (xtc:typecheck:vars-ref vars bb)
                            (= (length (xtc:typecheck:vars-ref vars bb)) 1))
                       (car (xtc:typecheck:vars-ref vars bb)))))
          (if (and (null? bu) (char=? (string-ref (car p2b) 0) #\%))
              (set! bu (car p2b)))
          (if (string? au)
              (set! t1a (xtc:typecheck:completely-unwrap-named-type au)))
          (if (string? bu)
              (set! t1b (xtc:typecheck:completely-unwrap-named-type bu)))
          ;; (println 'which 'is 'to 'match:)
          ;; (println t1a)
          ;; (println 'against:)
          ;; (println t1b)
          ;; now try to match on t1a and t1b
          (let* ((res (xtc:typecheck:descending-generic-type-match t1a t1b)))
            ;; this for printing only
            ;; (if (not res)
            ;;     (begin
            ;;       (println 'match-failed: t1a 'vs t1b)
            ;;       (println 'A: aa)
            ;;       (println 'B: bb)))
            res)))))


;; type inferencing for generic functions arguments
(define xtc:typecheck:nativef-generics-check-args
  (lambda (ast gpoly-type vars kts expected)

    ;; type inferencing for generic functions arguments
    (let ((result (map (lambda (a gt)
           ;; gt for generics type
           (let ((tt (xtc:typecheck:type-check a vars kts gt))
                 (subcheck #t))
             ;; (println 'vars: vars)

             ;; generics are unforgiving to choice
             ;; so if we have number choice then
             ;; let's always force i64 or double
             (if (or (equal? tt (list *xtc:codegen:si64* *xtc:codegen:si32*))
                     (equal? tt (list *xtc:codegen:si64* *xtc:codegen:si32* *xtc:codegen:si16*))
                     (equal? tt (list *xtc:codegen:si64* *xtc:codegen:si32* *xtc:codegen:si16* *xtc:codegen:ui8*))
                     (equal? tt (list *xtc:codegen:si64* *xtc:codegen:si32* *xtc:codegen:si16* *xtc:codegen:ui8* *xtc:codegen:i1*)))
                 (set! tt (list *xtc:codegen:si64*)))
             (if (equal? tt (list *xtc:codegen:fp64* *xtc:codegen:fp32*))
                 (set! tt (list *xtc:codegen:fp64*)))

             ;; (println 1 'a: a 'tt: tt 'gt: gt)
             (if (and (list? tt) (= (length tt) 1)) (set! tt (car tt)))

             (if (and (atom? gt)
                      (symbol? gt)
                      (xtc:typecheck:vars-ref vars gt)
                      (if (string-contains? (symbol->string gt) ":")
                          (xtc:typecheck:generic-types-matchup? gt tt vars)
                          #t))
         (begin ;; (println '----matched-polytype-1: gt '-> tt)
           (if (symbol? tt)
               (begin
                 (if (not (xtc:typecheck:vars-ref vars tt))
                     (set! vars (xtc:typecheck:vars-add tt vars)))
                 (if (null? (xtc:typecheck:vars-ref vars tt))
                     (set! vars (xtc:typecheck:vars-update gt vars kts (list tt)))
                     (begin
                       (set! vars (xtc:typecheck:vars-update gt vars kts (xtc:desugar:type-unify (xtc:typecheck:vars-ref vars tt) vars))))))
                 (set! vars (xtc:typecheck:vars-update gt vars kts (xtc:desugar:type-unify tt vars))))))

       (if (atom? tt)
     (set! tt (list tt)))
       (if (and (list? tt)
          (list? (car tt))
          (not (atom? gt)))
     (set! tt (car tt)))
       (if (atom? gt)
     (set! gt (list gt)))
       ;(println 2 'a: a 'tt: tt 'gt: gt)
       ;; if gt and tt still not equal tt maybe a named-type
       (if (<> (length gt) (length tt))
           (if (and
                (not (null? tt))
                (string? (car tt)) ;; named type?
                (not (null? (llvm:get-named-type (car tt))))
        (= (length gt) (length (xtc:codegen:get-type-from-str (llvm:get-named-type (car tt))))))
         (set! tt (xtc:codegen:get-type-from-str (llvm:get-named-type (car tt))))
         (set! subcheck #f)))
         ;;(log-error 'Compiler 'Error: 'type 'mismatch 'in 'generics gt '- tt)))

       ;; GCHANGE
       ;; we might be able to update-vars based by matching our request 'gt vs our result 'tt
       (if subcheck
     (for-each
      (lambda (aa bb)
        ;; (println 'matched-polytype-2: aa '-> bb)
                    ;; (println 'vars: vars)
                    (if (and (atom? aa)
                             (symbol? aa)
                             (xtc:typecheck:vars-ref vars aa)
                             (if (string-contains? (symbol->string aa) ":")
                                 (xtc:typecheck:generic-types-matchup? aa bb vars)
                                 #t))
                        (if (and (symbol? bb) (xtc:typecheck:vars-ref vars bb))
                            (begin
                                        ;(set! tt (xtc:desugar:type-unify (xtc:typecheck:vars-ref vars bb) vars))
                                        ;(xtc:typecheck:update-var aa vars kts tt))
                              (set! vars (xtc:typecheck:vars-update aa vars kts (xtc:typecheck:vars-ref vars bb))))
                            (if (string? bb)
                                (set! vars (xtc:typecheck:vars-update aa vars kts bb))
                                (set! vars (xtc:typecheck:vars-update aa vars kts (list bb)))))))
                  gt tt))
             tt))
         (cdr ast)
         (cddr gpoly-type))))
      (tc-result result vars))))


;; adds ##gnum's to all poly types
(define xtc:typecheck:nativef-generics-make-gtypes-unique
  (lambda (pt gnum)
    (cond ((null? pt) '())
          ((symbol? pt)
           (let ((pt-str (symbol->string pt)))
             (cond ((char=? (string-ref pt-str 0) #\!)
                    (string->symbol (string-append pt-str "##" (number->string gnum))))
                   ((or (if (and (or (string-contains? pt-str ":")
                                     (string-contains? pt-str "{"))
                                  (hashtable-ref *xtc:cache:generictype-cache*
                                                 (car (xtc:desugar:split-namedtype pt))))
                             #t #f)
                         (hashtable-ref *xtc:cache:generictype-cache*
                                        (xtc:codegen:get-base-type pt-str)))
                    (string->symbol (string-append pt-str "##" (number->string gnum))))
                   ((and (string-contains? pt-str "%")
                         (hashtable-ref *xtc:cache:generictype-cache*
                                        (xtc:codegen:get-base-type (car (string-split-on pt-str "%")))))
                    (string->symbol (string-append pt-str "##" (number->string gnum))))
                   (else pt))))
          ((pair? pt)
           (cons (xtc:typecheck:nativef-generics-make-gtypes-unique (car pt) gnum)
                 (xtc:typecheck:nativef-generics-make-gtypes-unique (cdr pt) gnum)))
          (else pt))))


;; this attempts to update-var !bangs from reified types and also GTypes
;; i.e. if we have allready resolved xlist*##289 to %xlist--2812497382948
;; but we have failed to resolve !head##289
;; then we try to get back from %xlist--2812497382948 to set !head##289
(define xtc:typecheck:reverse-set-bangs-from-reified
  (lambda (poly reified gnum vars)
    ;; (println 'reverse-bangs: poly 'gnum: gnum)
    ;; (println 'vars vars)
    ;; (println 'reified: reified)
    ;; (println 'pretty: (xtc:codegen:pretty-print-type reified))
    ;; (println 'okpretty)
    (if (and (not (list? poly))
             (or (not (symbol? poly))
                 (not (or (string-contains? (symbol->string poly) ":")
                         (string-contains? (symbol->string poly) "{")))))
        'done
        (let* ((prettyreified (xtc:codegen:pretty-print-type reified))
               (sss (if (list? poly) "" (car (string-split-on (symbol->string poly) "##"))))
               ;; (gpolytype (if (list? poly) poly (xtc:codegen:get-type-from-pretty-str sss)))
               (namedtype (xtc:codegen:get-type-from-str (xtc:cache:get-named-type reified)))
               (gpolytype (if (list? poly) poly
                              (cons (car namedtype) (xtc:codegen:get-type-from-pretty-tuple
                                        (cadr (xtc:desugar:split-namedtype (xtc:desugar:maximize-generic-type sss))))))))
          (if (<> (length gpolytype)
                  (length namedtype))
              '()
              (for-each (lambda (a b)
                          (if (symbol? b)
                              (if (char=? (string-ref (symbol->string b) 0) #\!)
                                  (set! vars (xtc:typecheck:vars-update
                                   (string->symbol (string-append (symbol->string b) "##" (number->string gnum)))
                                   vars '() a))))
                          (if (and (string? a)
                                   (not (string=? a reified)) ;; watch out for recursive!
                                   (string-contains? a "_poly_"))
                              (xtc:typecheck:reverse-set-bangs-from-reified b a gnum vars)))
                        namedtype gpolytype))))))

;;
;; first for generic functions we do a gnum test
;;
;; basically the gnum test looks to see if all of the types
;; in the gftype are of the same gnum as the generic function
;; if they aren't of the same gnum (i.e. if they are NEW links)
;; then we might be able to do additonal reverse lookups on the
;; OLD gnum vars by looking into NEW gnum vars
;;
;; for example:
;; if ORIGINAL type (gpoly-type) = (211 !head##110 xlist*##110)
;; and NEW type         (gftype) = (211 !head##110 xlist*##109)
;; then we might be able to match !head##110 against !head##109
;;
(define xtc:typecheck:nativef-generics-final-tests
  (lambda (ast gpoly-type gftype gnum vars kts)
    ;; (println 'nativef-generics-final-tests)
    ;; do a final check of all !bang types in original gpoly-type to see
    ;; if we can improve them with any reified types we may have
    (for-each (lambda (k)
                (if (symbol? k)
                    (if (xtc:typecheck:vars-ref vars k) ;;(not (not (xtc:typecheck:vars-ref vars k)))
                        (let ((v (xtc:typecheck:vars-ref vars k)))
                          (if (string? v)
                              (xtc:typecheck:reverse-set-bangs-from-reified k v gnum vars)
                              (if (and (list? v)
                                       (= (length v) 1)
                                       (string? (car v)))
                                  (xtc:typecheck:reverse-set-bangs-from-reified k (car v) gnum vars)))))))
              (cdr gpoly-type))
    ;; attempt to reify any gtype symbols that don't currenty have type values (i.e. not var entry)
    (for-each (lambda (a)
                (if (and (symbol? a)
                         (string-contains? (symbol->string a) "##")
                         (not (xtc:typecheck:vars-ref vars a)))
                    ;; (null? (hashtable-ref vars a)))
                    ;; should call this xtc:typecheck:symbol-tryto-reify-generic-type
                    (let ((res (xtc:desugar:reify-generic-type a vars '())))
                      (if (not (equal? res a))
                          (begin ;; (println 'genupdate: a '-> res)
                            (set! vars (xtc:typecheck:vars-update a vars kts res)))))))
              (cdr gftype))

    #t))


;; recursion test
(define *xtc:typecheck:nativef-generics-recurse-test* 0)

(define xtc:typecheck:nativef-generics-check-return-type
  (lambda (ast lambda-code gpoly-type gnum vars args expected)
    ;; (println 'lambda-code: lambda-code 'gnum: gnum)
    ;; (println 'check-ret-type: gpoly-type 'expected expected)
    ;; (println 'rec: ast *xtc:typecheck:nativef-generics-recurse-test*)
    (let ((grtype '()))
      ;;
      ;; this section is here to check for a return type
      ;; for this generic function.
      ;; we do this by grabbing the gpoly's lambda code and
      ;; sending it through type checking.
      ;;
      (if (< *xtc:typecheck:nativef-generics-recurse-test* 5)
          (begin
            (set! *xtc:typecheck:nativef-generics-recurse-test*
                  (+ *xtc:typecheck:nativef-generics-recurse-test* 1))
            ;; type inferencing for generic functions return argument!
            (let* ((symname 'placeholder)
                   (extantsyms (hashtable-keys vars))
                   (s1 (xtc:desugar:rename-all-shadow-vars symname lambda-code extantsyms))
                   (c1 (xtc:desugar:get-var-types s1))
                   (t1 (xtc:desugar:first-transform (car c1) #t))
                   (s2 (xtc:desugar:rename-all-shadow-vars symname t1 extantsyms))
                   (c2 (xtc:desugar:get-var-types s2)) ;;lambda-code))
                   (t2 (xtc:typecheck:mark-returns (car c2) symname #f #f #f))
                   (t3 (xtc:typecheck:closure:convert t2 (list symname)))
                   (lvarnames (xtc:typecheck:find-all-vars t3 '()))
                   (tr1 (xtc:desugar:type-unify gpoly-type vars))
                   (trequest (if expected expected tr1))
                   (kts (cl:remove #f (map (lambda (x y) (if (xtc:codegen:type? y) x #f)) (cadr s1) args)))
                   (newvars (let ((ht (xtc:typecheck:vars-snapshot vars)))
                              (for-each (lambda (sym) (hashtable-set! ht sym (xtc:typecheck:make-uf-cell '()))) lvarnames)
                              ht))
                   (ttype '()))
              ;; this here as a check (could be removed)
              (if (not (null? (cl:intersection lvarnames extantsyms)))
                  (xtc:diagnostics:print-compiler-error "shadow vars found when specialising generic code" (cl:intersection lvarnames extantsyms)))
              ;; this is another check (could be removed)
              (hashtable-for-each (lambda (x)
                                    (if (member (car x) lvarnames)
                                        (println 'Type 'Collision 'On x)))
                                  vars)

              ;; update newvars to include incoming argument types
              (for-each (lambda (s t a)
                          ;; (println 's: s 't: t 'a: a)
                          (if (and (xtc:codegen:closure? t) (assoc-strcmp a *xtc:globals:bound-lambdas*))
                              (set! *xtc:globals:bound-lambdas*
                                    (cons (cons s (replace-all (cdr (assoc-strcmp a *xtc:globals:bound-lambdas*))
                                                               (list (cons a s))))
                                          *xtc:globals:bound-lambdas*)))
                          (set! newvars (xtc:typecheck:vars-update s newvars '() (xtc:desugar:type-unify t vars)))
                          )
                        (if (eq? (car s1) 'lambda)
                            (cadr s1) ;; lambda arguments
                            (cadr (cl:find-if (lambda (x) (if (and (list? x) (eq? (car x) 'lambda)) #t #f))
                                              s1))) ;; this case here for generic starting with let not a lambda!
                        args
                        (cdr ast))
              ;; NOW DO ACTUAL TYPE CHECK!
              (let ((toplvl? (if *xtc:globals:top-level-generic-error* #f #t)))
                (if toplvl? (set! *xtc:globals:top-level-generic-error*
                                  (cons (car (string-split-on (symbol->string (car ast)) "##"))
                                        (map (lambda (t a)
                                               ;; (println 't: t 'a: a)
                                               (if (null? t)
                                                   (if (atom? a)
                                                       (cons "?" (atom->string a))
                                                       (sexpr->string a))
                                                   (cons (xtc:codegen:pretty-print-type t)
                                                         (if (atom? a)
                                                             (atom->string a)
                                                             (sexpr->string a)))))
                                             args
                                             (cdr ast)))))
                (set! ttype (xtc:typecheck:type-check t1 newvars kts trequest))
                (if toplvl? (set! *xtc:globals:top-level-generic-error* #f)))
              ;; propagate type info from inner type-check back to vars
              ;; (old alist code shared cons cells between newvars and vars,
              ;; so set-cdr! mutations propagated implicitly; with hash tables
              ;; we must propagate explicitly)
              (hashtable-for-each
               (lambda (entry)
                 (let ((val (xtc:typecheck:uf-value (cdr entry))))
                   (if (and (not (member (car entry) lvarnames))
                            (xtc:typecheck:vars-ref vars (car entry))
                            (not (null? val)))
                       (xtc:typecheck:uf-set-value! (hashtable-ref vars (car entry)) val))))
               newvars)
              ;; don't let any local vars (lvars) escape back up to a
              ;; level where they will not mean anything!!!!
              (set! ttype (replace-all ttype (map (lambda (x) (cons x '())) lvarnames)))
              (set! *xtc:typecheck:nativef-generics-recurse-test* (- *xtc:typecheck:nativef-generics-recurse-test* 1))
              (if (< *xtc:typecheck:nativef-generics-recurse-test* 0)
                  (set! *xtc:typecheck:nativef-generics-recurse-test* 0))
              (if (and (not (null? ttype))
                       (xtc:codegen:closure? (car ttype)))
                  ;; (xtc:codegen:type? (cadar ttype)))
                  (begin
                    ;; (println 'done ttype)
                    (set! grtype ttype)))))
          (if (= *xtc:typecheck:nativef-generics-recurse-test* 5)
              (begin
                (set! *xtc:typecheck:nativef-generics-recurse-test*
                      (+ *xtc:typecheck:nativef-generics-recurse-test* 1))
                #f)
              (begin ;; (println 'hit-recursion-limit)
                ;; (println 'vars vars)
                (log-error 'Compiler 'Error: 'hit 'generics 'recursion 'limit 'request expected)
                #f)))
      ;; (if (not (equal? gpoly-type (car grtype)))
      ;;     (begin (println 'RET: gpoly-type '-> grtype)
      ;;            (println '-----------------)))
      (tc-result grtype vars))))


(define xtc:typecheck:strip-named-type
  (lambda (t)
    (if (symbol? t) (set! t (symbol->string t)))
    (if (not (string? t))
        (xtc:diagnostics:print-bad-type-error t "Should be named type!")
        (let ((ptrdepth (xtc:codegen:get-ptr-depth t)))
          (if (string-contains? t ":")
              (apply string-append (car (string-split-on t ":")) (make-list ptrdepth "*"))
              (if (string-contains? t "{")
                  (apply string-append (car (string-split-on t "{")) (make-list ptrdepth "*"))
                  t))))))


(define xtc:typecheck:variable-substitution-pairs
  (lambda (t1 t2)
    (if (or (not (list? t1))
            (not (list? t2))
            (<> (length t1) (length t2)))
        '()
        (let ((pairs
               (flatten (map (lambda (a b)
                               (cond ((list? a)
                                      (xtc:typecheck:variable-substitution-pairs a b))
                                     ((atom? a)
                                      (if (and (xtc:codegen:type? a)
                                               (symbol? b)
                                               (char=? (string-ref (symbol->string b) 0) #\!))
                                          (cons (symbol->string b) (xtc:codegen:pretty-print-type a))
                                          '()))
                                     (else '())))
                             t1 t2))))
          pairs))))

(define xtc:typecheck:variable-substitution
  (lambda (type t1 t2 gnum vars kts)
    ;; (println 'variable-sub-in type)
    (let ((pairs (xtc:typecheck:variable-substitution-pairs t1 t2))
          (newtype (sexpr->string type)))
      (for-each (lambda (x)
                  ;; (println 'updatevar:
                  ;;          (string->symbol (string-append (car x) "##" (number->string gnum)))
                  ;;          'with:
                  ;;          (xtc:codegen:get-type-from-pretty-str (cdr x)))
                  (set! vars (xtc:typecheck:vars-update (string->symbol (string-append (car x) "##" (number->string gnum)))
                                      vars kts (list (xtc:codegen:get-type-from-pretty-str (cdr x)))))
                  ;; (println 'x x (xtc:codegen:get-type-from-pretty-str (cdr x)))
                  (if (xtc:codegen:type? (xtc:codegen:get-type-from-pretty-str (cdr x)))
                      (set! newtype (regex:replace-all newtype
                                                       (string-append (car x) "##" (number->string gnum))
                                                       (if (string? (xtc:codegen:get-type-from-pretty-str (cdr x)))
                                                           (string-append "\""
                                                                          (xtc:codegen:get-type-from-pretty-str (cdr x))
                                                                          "\"")
                                                           (sexpr->string (xtc:codegen:get-type-from-pretty-str (cdr x))))))
                      (set! newtype (regex:replace-all newtype (car x) (cdr x)))))
                pairs)
      ;; (if (not (null? pairs)) (println 'newt: newtype (xtc:codegen:type? newtype)))
      ;; (println 'variable-sub-out (string->sexpr newtype))
      (string->sexpr newtype))))

(define xtc:typecheck:get-type-for-gpoly
  (lambda (t)
    (cons (real->integer (+ *xtc:codegen:closure* (* (+ (xtc:codegen:get-ptr-depth t) 1) *xtc:codegen:pointer*)))
          (map (lambda (k)
                 ;; (println 'kk k)
                 (if (char=? (string-ref k 0) #\[)
                     (xtc:typecheck:get-type-for-gpoly k)
                     (if (string-contains? k ":") ;; if generic either gvar of named type
                         (string->symbol k)
                         (if (string-contains? k "{")
                             (string->symbol k)
                             (xtc:codegen:get-type-from-pretty-str k)))))
               (xtc:codegen:get-pretty-closure-arg-strings t)))))


(define *xtc:typecheck:nativef-generics:calls* 0)

(define xtc:typecheck:nativef-generics-early-exit
  (lambda (ast vars kts)
    (cond ((assoc-strcmp (car ast) kts)
           (for-each (lambda (x r)
                       (xtc:typecheck:type-check x vars kts r))
                     (cdr ast)
                     (cddr (xtc:desugar:type-unify (xtc:typecheck:vars-ref vars (car ast)) vars)))
           (list (cadr (xtc:desugar:type-unify (xtc:typecheck:vars-ref vars (car ast)) vars))))
          ((xtc:codegen:type? (xtc:desugar:type-unify (xtc:typecheck:vars-ref vars (car ast)) vars))
           (for-each (lambda (x r)
                       (xtc:typecheck:type-check x vars kts r))
                     (cdr ast)
                     (cddr (xtc:desugar:type-unify (xtc:typecheck:vars-ref vars (car ast)) vars)))
           (list (cadr (xtc:desugar:type-unify (xtc:typecheck:vars-ref vars (car ast)) vars))))
          (else #f))))

(define xtc:typecheck:nativef-generics-inject-missing-vars
  (lambda (vars gpoly-code gnum)
    (let ((type-strs (xtc:codegen:get-pretty-closure-arg-strings
                      (cadr (string-split-on (symbol->string (cadr gpoly-code)) ":")))))
      (for-each (lambda (a)
                  (if (or (char-alphabetic? (string-ref a 0))
                         (char=? (string-ref a 0) #\!))
                      (if (and (not (xtc:typecheck:vars-ref vars (string->symbol (string-append a "##" (number->string gnum)))))
                               (or (string-contains? a ":")
                                   (string-contains? a "!")
                                   (string-contains? a "{")))
                          (let ((newsymm (string->symbol (string-append a "##" (number->string gnum))))
                                (all-syms (cl:remove-duplicates (map (lambda (aa)
                                                                       (string->symbol (string-append aa "##" (number->string gnum))))
                                                                     (regex:match-all a "![^,}>\\]]*")))))
                            (set! all-syms (remove (symbol->string newsymm) all-syms))
                            (xtc:typecheck:vars-add newsymm vars)))))
                type-strs)
      (for-each (lambda (a)
                  (let ((vs (cl:remove-duplicates (regex:match-all a "(![a-zA-Z0-9]*_[0-9]*)"))))
                    (for-each (lambda (x)
                                (let ((sym (string->symbol (string-append x "##" (atom->string gnum)))))
                                  (if (not (xtc:typecheck:vars-ref vars sym))
                                      (xtc:typecheck:vars-add sym vars))))
                              vs)))
                type-strs))))

(define xtc:typecheck:nativef-generics-check-constraint
  (lambda (ast grtype arity constraint constraint-code)
    (if (and (not (null? grtype)) constraint)
        (let* ((lgrtype (if (= (length grtype) (+ 2 arity))
                            grtype
                            (car (cl:remove-if-not (lambda (x)
                                                     (xtc:codegen:closure? x))
                                                   grtype))))
               (chk (if (and (list? (cadr constraint-code))
                             (<> (length (cdr lgrtype))
                                 (length (cadr constraint-code))))
                        'false
                        (apply (eval constraint)
                               (map (lambda (x)
                                      (if (string? x)
                                          (apply string-append
                                                 (car (string-split-on (xtc:codegen:pretty-print-type x) "{"))
                                                 (make-list (xtc:codegen:get-ptr-depth x) "*"))
                                          x))
                                    (cdr lgrtype))))))
          (if (boolean? chk)
              (if chk
                  grtype
                  (xtc:diagnostics:print-constraint-error
                   (car (string-split-on (atom->string (car ast)) "##"))
                   (xtc:codegen:pretty-print-type grtype)
                   constraint
                   ast))
              (if (xtc:codegen:type? chk)
                  chk
                  (xtc:diagnostics:print-compiler-error
                   (string-append "Poorly defined constraint check: "
                                  (sexpr->string constraint)
                                  " for generic call "
                                  (sexpr->string ast)
                                  " for type "
                                  (if (xtc:codegen:type? grtype)
                                      (xtc:codegen:pretty-print-type grtype)
                                      "<uknown>"))))))
        grtype)))

(define xtc:typecheck:nativef-generics-emit-final
  (lambda (ast vars kts grtype gftype)
    (if (and (xtc:codegen:type? grtype)
             (symbol? (cadr gftype))
             (xtc:typecheck:vars-ref vars (cadr gftype)))
        (xtc:typecheck:vars-update (cadr gftype) vars kts (cadr grtype)))
    (map (lambda (x y)
           (if (symbol? x)
               (xtc:typecheck:vars-update x vars kts (list y))))
         (cdr ast)
         (cddr gftype))
    (if (xtc:codegen:type? grtype)
        (xtc:typecheck:vars-update (car ast) vars kts (list grtype))
        (xtc:typecheck:vars-update (car ast) vars kts (list gftype)))))

;; generics check
(define xtc:typecheck:nativef-generics
  (lambda (ast vars kts expected)
    (set! *xtc:typecheck:nativef-generics:calls* (+ *xtc:typecheck:nativef-generics:calls* 1))
    (set! xtc:codegen:get-type-expand-poly #f)
    (if (not (xtc:codegen:type? expected))
        (set! expected #f))
    ;;
    (let ((early (xtc:typecheck:nativef-generics-early-exit ast vars kts)))
      (if early
          early
          (let* ((args (map (lambda (x)
                               ;; (println ast 'check x)
                               (xtc:desugar:type-unify (xtc:typecheck:type-check x vars kts #f) vars))
                             (cdr ast)))
                  (ast-parts (string-split-on (symbol->string (car ast)) "##"))
                  (gname (string->symbol (car ast-parts)))
                  (gnum (string->number (cadr ast-parts)))
                  (arity (- (length ast) 1))
                  ;; (lll (println 'gname gname arity (if expected (cons expected args) args)))
                  (gpt (xtc:cache:genericfunc-types gname arity (if expected (cons expected args) args)))
                  (gpt-valid (if (equal? #f gpt)
                                 (xtc:diagnostics:print-compiler-error "no valid generic options available for: " ast)
                                 #t))
                  ;; expected expected args)))
                  (gpoly-code (cadr gpt))
                  (constraint (cadddr gpt))
                  (constraint-code (if (not constraint) #f (if (symbol? constraint) (get-closure-code (eval constraint)) constraint)))
                  (lambda-code (caddr gpoly-code))
                  (gtype (xtc:codegen:get-type-from-pretty-str (symbol->string (car gpt))))
                  (gpoly-type (xtc:typecheck:get-type-for-gpoly
                               (cadr (string-split-on (symbol->string (cadr gpoly-code)) ":"))))
                  (gpoly-type-orig (xtc:typecheck:nativef-generics-make-gtypes-unique gpoly-type gnum)))
             ;; (println "gpt:" gpt)
             ;; (println "gtype:" gtype)
             ;; (println "args:" args)
             ;; (println "args2:" args2)
             ;; (println "constraint:" constraint)
             ;; (println "constraint-code:" constraint-code)

             (xtc:typecheck:nativef-generics-inject-missing-vars vars gpoly-code gnum)


             (if (<> (length (cdr gpoly-type))
                     (length ast))
                 (xtc:diagnostics:print-compiler-error "bad arity in generics call" ast))

             ;; add ##gnum's to all gpoly types (both !bangs like !head and gpoly types like xlist*)
             (set! gpoly-type
                   (xtc:desugar:type-unify
                    (xtc:typecheck:nativef-generics-make-gtypes-unique gpoly-type gnum)
                    vars))

             ;; if there is a valid request (return type) add it to gpoly-type!
             ;; (println '--> 'expected expected 'gpolyt gpoly-type)
             (if (and expected (xtc:codegen:type? expected))
                 ;; (set! gpoly-type (cons (car gpoly-type) (cons expected (cddr gpoly-type)))))
                 (begin
                   (if (symbol? (cadr gpoly-type))
                       (begin
                         (if (string? expected)
                             (let ((req (regex:matched expected "^%([^_]*).*"))
                                   (gen (regex:matched (symbol->string (cadr gpoly-type)) "^([A-Za-z][^{:]*).*")))
                                ;; (println 'req req 'gen gen)
                                (if (and (= (length req) 2)
                                         (= (length gen) 2))
                                    (if (and (not (equal? (cadr req) (cadr gen)))
                                             #t) ;; (not (equal? (cadr gen) "_")))
                                         ;; (xtc:diagnostics:print-compiler-error "no valid generic options available for: " ast)))))
                                        (xtc:diagnostics:print-compiler-error (string-append "Return type mismatch for generic function which expected return type '" (cadr gen) "' and got named type '" (cadr req) "'") ast)))))
                        ;; (println 'update 'return 'var 'with  (xtc:typecheck:update-var (cadr gpoly-type) vars kts (list expected)))
                         (if (not (xtc:typecheck:vars-ref vars (cadr gpoly-type)))
                             (set! vars (xtc:typecheck:vars-add (cadr gpoly-type) vars)))
                         (set! vars (xtc:typecheck:vars-update (cadr gpoly-type) vars kts (list expected)))))
                 (set! gpoly-type (cons (car gpoly-type) (cons expected (cddr gpoly-type))))))
             (let* ((a gpoly-type)
                    (b (map (lambda (x)
                              (if (and (string? x)
                                       (string-contains? x "{"))
                                  (xtc:desugar:get-generic-type-as-tuple x)
                                  x))
                            gpoly-type))
                    (c gtype))
               ;; (println 'a a)
               ;; (println 'b b)
               ;; (println 'c c)
               (set! gpoly-type (xtc:typecheck:variable-substitution a b c gnum vars kts))
               ;; (println 'd gpoly-type)
               (set! gpoly-type (map (lambda (x)
                                       (if (symbol? x)
                                           (let ((p (string-split-on (symbol->string x) "##")))
                                             (if (and (string-contains? (car p) "{")
                                                      (xtc:codegen:type? (xtc:codegen:get-type-from-pretty-str (car p))))
                                                 (xtc:codegen:get-type-from-pretty-str (car p))
                                                 x))
                                           x))
                                     gpoly-type))
               ;; (println 'e2 gpoly-type)
               gpoly-type)
             (if (xtc:codegen:type? gpoly-type)
                 (begin
                   ;; (println 'update-a: (car ast) 'with: gpoly-type)
                   (set! vars (xtc:typecheck:vars-update (car ast) vars kts gpoly-type))
                   (cadr gpoly-type))
                 (begin
                   ;; excercise the actual generic code! (if we don't have a type yet!)
                   (let* ((req? (xtc:desugar:type-unify gpoly-type vars))
                          (res (let ((r (xtc:typecheck:nativef-generics-check-args ast gpoly-type vars kts expected)))
                                 (if (vector? r) (tc-type r) r)))
                          (resb (map (lambda (x) (xtc:desugar:type-unify x vars)) res))
                          (newgtype (cons (car req?)
                                          (cons (if (xtc:codegen:type? expected)
                                                    expected
                                                    (cadr req?))
                                                (map (lambda (a b c)
                                                       (if (xtc:codegen:type? a) a
                                                           (if (xtc:codegen:type? b) b
                                                               c)))
                                                     resb args (cddr req?)))))
                          ;; (lll (println 'resb: resb 'req? req? 'requst expected 'args args))
                          (nvars '()) ;; don't do copy unless we need it ;(cl:tree-copy vars))
                          (rtype (cond ((xtc:codegen:type? newgtype)
                                        newgtype)
                                        ((xtc:codegen:type? req?)
                                         newgtype)
                                        ((equal? gpoly-type gpoly-type-orig) ;; no new information!
                                         newgtype)
                                        ((and (equal? gname *xtc:typecheck:type-check-function-symbol-short*) ;; this for recursive generic
                                              (xtc:codegen:type? (car (xtc:typecheck:vars-ref vars *xtc:typecheck:type-check-function-symbol*))))
                                         (car (xtc:typecheck:vars-ref vars *xtc:typecheck:type-check-function-symbol*)))
                                        (else
                                         (set! nvars (xtc:typecheck:vars-snapshot vars))
                                         (let ((r (xtc:typecheck:nativef-generics-check-return-type
                                                   ast lambda-code gpoly-type gnum nvars (cddr newgtype)
                                                   (if (xtc:codegen:type? expected) expected #f))))
                                           (if (vector? r) (tc-type r) r)))))
                          (grtype (xtc:desugar:type-unify rtype vars)))
                     ;; we might have gained something useful in nvars!
                     ;; that we can use for vars!
                     ;; have to be careful that it is a fully valid type though!
                     ;; otherwise we might introduce dependencies from inside
                     ;; a generic call that we should not have access to
                     (if (hash-table? nvars)
                         (hashtable-for-each
                          (lambda (n)
                            (let* ((sym (car n))
                                   (val (xtc:typecheck:uf-value (cdr n)))
                                   (v-types (xtc:typecheck:vars-ref vars sym)))
                              (if (and v-types
                                       (null? v-types)
                                       (= (length val) 1)
                                       (xtc:codegen:type? (car val)))
                                  (set! vars (xtc:typecheck:vars-update sym vars kts val)))))
                          nvars))
                     ;; check to see if for-each is possible (i.e. request and (cadr gpoly-type)) are same length
                     ;; (if (list? expected)
                     ;;     (if (and (list? (cadr gpoly-type))
                     ;;              (<> (length expected) (length (cadr gpoly-type))))
                     ;;         (set! expected #f))
                     ;;     (if (list? (cadr gpoly-type))
                     ;;         (if (and (string? expected) ;; named type?
                     ;;                  (= (length (cadr gpoly-type)) (length (xtc:cache:get-namedtype-type expected))))
                     ;;             (set! expected (xtc:cache:get-namedtype-type expected))
                     ;;             (set! expected #f))
                     ;;         (if (<> (length (list expected)) (length (list (cadr gpoly-type))))
                     ;;             (set! expected #f))))

                     ;; (if (and expected
                     ;;          (not (string? (cadr gpoly-type))))
                     ;;     (if (and (list? expected)
                     ;;              (atom? (cadr gpoly-type))
                     ;;              (symbol? (cadr gpoly-type)))
                     ;;         (begin
                     ;;           ;; (println 'update-c: (cadr gpoly-type) 'with: expected)
                     ;;           (xtc:typecheck:update-var (cadr gpoly-type) vars kts expected))
                     ;;         (if (and (list? expected)
                     ;;                  (number? (cadr gpoly-type))
                     ;;                  (member (cadr gpoly-type) expected))
                     ;;             (set! expected (cadr gpoly-type))
                     ;;             (for-each
                     ;;              (lambda (aa bb)
                     ;;                (if (and (atom? aa)
                     ;;                         (symbol? aa)
                     ;;                         (hashtable-ref vars aa))
                     ;;                    (begin
                     ;;                      ;; (println 'update-d: aa 'with: bb)
                     ;;                      (xtc:typecheck:update-var aa vars kts bb))))
                     ;;              (if (atom? expected)
                     ;;                  (list (cadr gpoly-type))
                     ;;                  (cadr gpoly-type))
                     ;;              (if (atom? expected)
                     ;;                  (list expected)
                     ;;                  expected)))))

                     ;; if expected is not a fully formed type
                     ;; then we will stick to the the current poly type
                     (if (not (xtc:codegen:type? expected))
                         (set! expected #f))

                     ;; (println 'ast: 'preset: vars)
                     ;; set generic functions type ( (cadr gpoly-type)|expected + res)
                     (let ((gftype (if expected
                                       (list (cons (+ *xtc:codegen:closure* (* 2 *xtc:codegen:pointer*))
                                                   (cons (list expected) resb)))
                                       (list (cons (+ *xtc:codegen:closure* (* 2 *xtc:codegen:pointer*))
                                                   (cons (list (cadr gpoly-type)) resb))))))

                       ;; (println 'gftype1: gftype 'gpoly-type gpoly-type)
                       (set! gftype (xtc:desugar:type-clean (car gftype)))
                       ;; (println 'gftype2: gftype)

                       ;; don't seem to need this anymore :(  ???
                       ;; (xtc:typecheck:nativef-generics-final-tests ast gpoly-type gftype gnum vars kts)

                       (if (null? grtype) (set! grtype gftype))
                       (set! grtype (xtc:typecheck:nativef-generics-check-constraint ast grtype arity constraint constraint-code))
                       (xtc:typecheck:nativef-generics-emit-final ast vars kts grtype gftype)))))
             ;; (println 'done-continue ast)
             ;; (println 'gret: expected gpoly-type)
             (tc-result (if expected
                            (list expected)
                            (list (cadr gpoly-type)))
                        vars))))))



