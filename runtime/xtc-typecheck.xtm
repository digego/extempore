(define xtc:typecheck:callback-check
  (lambda (ast vars kts expected)
    (let* ((cbType (xtc:typecheck:type-check (caddr ast) vars kts '()))
           (ftypeA (map xtc:codegen:get-type-from-str
                      (let ((ags (xtc:cache:get-closure-arg-types (symbol->string (caddr ast)))))
                        (if ags ags '()))))
           (ftype (cond ((not (null? ftypeA)) (cons 213 ftypeA))
                        ((and (not (null? cbType)) (pair? (car cbType)))
                         (car cbType))
                        (else cbType))))
      (if *xtc:globals:print-sub-checks* (println 'ftype:> 'ast: ast 'type: ftype))
      (xtc:typecheck:type-check (cadr ast) vars kts *xtc:codegen:si64*)
      (if (null? ftype)
          (begin (let ((fargs (cons 213
                                    (cons -1
                                          (map (lambda (a)
                                                 (xtc:typecheck:type-check a vars kts '()))
                                               (cdddr ast))))))
                   (if (and (xtc:codegen:type? fargs)
                            (xtc:typecheck:vars-ref vars (caddr ast))
                            (null? (xtc:typecheck:vars-ref vars (caddr ast))))
                       (set! vars (xtc:typecheck:vars-update (caddr ast) vars kts fargs))))
                 (tc-result (list *xtc:codegen:void*) vars))
          (begin (if (<> (+ 2 (length ftype))
                         (length ast))
                     (xtc:diagnostics:print-compiler-error "bad arity in call" ast))
                 (if (and (xtc:typecheck:vars-ref vars (caddr ast))
                          (null? (xtc:typecheck:vars-ref vars (caddr ast))))
                     (set! vars (xtc:typecheck:vars-update (caddr ast) vars kts ftype)))
                 ;; we don't care what we get back
                 (for-each (lambda (a t)
                             (if (symbol? a) (set! vars (xtc:typecheck:vars-update a vars kts t)))
                             (xtc:typecheck:type-check a vars kts t))
                           (cdddr ast)
                           (cdr ftype))
                 ;; callback returns void
                 (tc-result (list *xtc:codegen:void*) vars))))))


(define xtc:typecheck:push_new_zone-check
  (lambda (ast vars kts expected)
    (if (<> (length ast) 2)
        (xtc:diagnostics:print-compiler-error "bad arity in call" ast))
    (xtc:typecheck:type-check (cadr ast) vars kts *xtc:codegen:si64*)
    (tc-result (list "%mzone*") vars)))

(define xtc:typecheck:push_zone-check
  (lambda (ast vars kts expected)
    (if (<> (length ast) 2)
        (xtc:diagnostics:print-compiler-error "bad arity in call" ast))
    (xtc:typecheck:type-check (cadr ast) vars kts "%mzone*")
    (tc-result (list "%mzone*") vars)))

(define xtc:typecheck:create_zone-check
  (lambda (ast vars kts expected)
    (if (<> (length ast) 2)
        (xtc:diagnostics:print-compiler-error "bad arity in call" ast))
    (xtc:typecheck:type-check (cadr ast) vars kts *xtc:codegen:si64*)
    (tc-result (list "%mzone*") vars)))

(define xtc:typecheck:pop_zone-check
  (lambda (ast vars kts expected)
    (if (<> (length ast) 1)
        (xtc:diagnostics:print-compiler-error "bad arity in call" ast))
                                        ;(println 'memzonecheck ast (list? (cadr ast)))
    (tc-result (list "%mzone*") vars)))


(define xtc:typecheck:let-check
  (lambda (ast vars kts expected)
    ;; (println 'letchk: ast 'req expected) ; 'vars vars)
    ;; (println 'vars: vars '(cadr ast) (cadr ast))
    ;; for the symbols we want to set each return type
    (let ((internalreq? (cond ((equal? `(begin ,(caar (ast:let-bindings ast)))
                                       (ast:let-body ast))
                               expected)
                              (else #f))))
      (for-each (lambda (e)
                  ;; (println 'e e)
                  (if (and (list? (cadr e))
                           (equal? (caadr e) 'lambda))
                      (set! *xtc:globals:bound-lambdas* (cons e *xtc:globals:bound-lambdas*)))
                  (if (and #f
                           (xtc:typecheck:vars-ref vars (car e))
                           (xtc:codegen:type? (xtc:desugar:type-unify (xtc:typecheck:vars-ref vars (car e)) vars)))
                      (list (xtc:desugar:type-unify (xtc:typecheck:vars-ref vars (car e)) vars))
                      (let ((a (xtc:typecheck:type-check (cadr e) vars kts
                                                   (cond ((assoc-strcmp (car e) kts)
                                                          ;; (println 'retfor (car e) (cadr (assoc-strcmp (car e) kts)))
                                                          (cadr (assoc-strcmp (car e) kts)))
                                                         ((and (not (null? (xtc:typecheck:vars-ref vars (car e))))
                                                               (xtc:codegen:type? (car (xtc:typecheck:vars-ref vars (car e)))))
                                                          ;; (println 'retfor (car e) (car (hashtable-ref vars (car e))))
                                                          (car (xtc:typecheck:vars-ref vars (car e))))
                                                         (else
                                                          ;; (println 'retfor (car e) internalreq?)
                                                          internalreq?)))))
                        ;; (println '---update: (car e) 'with: a)
                        (set! vars (xtc:typecheck:vars-update (car e) vars kts a))
                        ;; (println '---vars: vars)
                        )))
                (ast:let-bindings ast))
      ;; then return the return type for the whole let
      ;; which should have a begin body! so caddr should work
      (let ((ret (xtc:typecheck:type-check (ast:let-body ast) vars kts expected)))
        (tc-result ret vars)))))

(xtc:cache:register-new-builtin
 "let"
 ""
 "let-bind temporary variables

Execute `body' with temporary variables bound as described in `bindings'.

e.g.

(let ((a 3)                  ;; 3 is bound to a
      (b 42)                 ;; 42 is bound to b
      (c:float* (alloc 10))) ;; a pointer to enough memory for 10 floats is bound to c
  (+ a b (ftoi64 (pref c 0))))

xtlang's `let' syntax is the same as Scheme"
 '(bindings body))

(define xtc:typecheck:null?-check
  (lambda (ast vars kts expected)
    (let ((a (xtc:typecheck:type-check (cadr ast) vars kts expected)))
      (tc-result
       (if (or (null? a) ;; couldn't resolve yet!
               (and (pair? a)
                    (null? (car a))))
           (list *xtc:codegen:i1*)
           (if (if (not (xtc:codegen:type? a))
                   (xtc:codegen:pointer? (car a))
                   (xtc:codegen:pointer? a))
               (list *xtc:codegen:i1*)
               (xtc:diagnostics:print-compiler-error "null must take a pointer type" ast)))
       vars))))


(define xtc:typecheck:null-check
  (lambda (ast vars kts expected)
    ;; (println 'null-check 'ast: ast 'expected expected)
    (let ((res (if (and (symbol? expected)
                        (string-contains? (symbol->string expected) "##"))
                   (if (xtc:typecheck:vars-ref vars expected)
                       (if (null? (xtc:typecheck:vars-ref vars expected))
                           expected
                           (xtc:typecheck:vars-ref vars expected)))
                   (if (and expected
                            (xtc:codegen:pointer? expected))
                       (list expected)
                       '())))) ;; forcing to i8* causes problems for generics
                                        ;(list (+ *xtc:codegen:pointer* *xtc:codegen:si8*))))))
      (tc-result res vars))))



(define xtc:typecheck:ret-check
  (lambda (ast vars kts expected)
    ;; (println 'retcheck: expected 'a: ast)
    ;; (println 'vars: vars)
    ;; grab function name from ret->
    (let* ((sym (if (equal? (caddr ast) (cadr ast))
                    '()
                    (xtc:typecheck:get-var (cadr ast) vars)))
           (t (if (null? sym) #f
                  (if (null? (cdr sym))
                      #f
                      (if (xtc:codegen:type? (cdr sym))
                          (cdr sym)
                          (car (cdr sym))))))
           ;;(car (cdr sym)))))
           ;; if closure has a return type set
           ;; pass it as a request
           (a (xtc:desugar:type-unify
               (xtc:typecheck:type-check (caddr ast) vars kts
                                   (if (and t
                                            (xtc:codegen:type? t)
                                            (xtc:codegen:closure? t))
                                       (if (list? t) (cadr t) expected)
                                        ;#f)))) ;; or else pass #f
                                       expected))
               vars))) ;; or pass on request
      ;; (println 'retchecked-> a 'expected expected 'ast: ast 't: t)
      ;; if t is not a closure type we have a problem!
      (if (and t
               (or (not (list? t));(not (xtc:codegen:type? t))
                   (not (xtc:codegen:closure? t))))
          (xtc:diagnostics:print-compiler-error "type error calculating return type - have you specified an incorrect closure type?" ast))
      (if (and (xtc:codegen:type? t)
               (xtc:codegen:closure? t)
               (string? a)
               (string? expected)
               (char=? (string-ref expected 0) #\%)
               (char=? (string-ref a 0) #\%)
               (not (equal? expected a)))
          (xtc:diagnostics:print-compiler-error (string-append "type error calculating return type - expected named type '" a "' got '" expected "'") ast))
      (if *xtc:globals:print-sub-checks* (println 'ret:> 'ast: ast 'a: a 'sym: sym))
      (if (and (xtc:codegen:type? t)
               (xtc:codegen:closure? t))
          (if (symbol? (caddr ast))
              (set! vars (xtc:typecheck:vars-update (caddr ast) vars kts (list (cadr t))))
              ;; else the return value is not a symbol
              ;; and we should use it's value to update the lambda's type
              (set! vars (xtc:typecheck:vars-update (car sym) vars kts
                                  (list (xtc:codegen:add-ptr-depth (xtc:codegen:add-ptr-depth (list* *xtc:codegen:closure* a (cddr t)))))))))
      ;; (println 'ret: a)
      (tc-result a vars))))


(define xtc:typecheck:begin-check
  (lambda (ast vars kts expected)
    ;; we should ONLY use expected on the LAST sexpr in the begin
    ;; i.e. we should only use the LAST begin sexpr for a return type
    (let ((sexplst (reverse (ast:begin-exprs ast))))
      (if (and (list? (car sexplst))
               (member (caar sexplst) '(ifret)))
          (if (<> (length (car sexplst)) 4)
              (xtc:diagnostics:print-compiler-error "Conditional statements in a return position must provide two branches!" (car sexplst))))
      ;; we need type check coverage for ALL sexpr's
      ;; but only the last one counts towards the returned type
      ;; non-final expressions are in synth mode (no expected type)
      (map (lambda (e) (xtc:typecheck:type-check e vars kts #f)) (cdr sexplst))
      ;; now we do the last sexpr in the begin for a return type
      (let ((res (xtc:typecheck:type-check (car sexplst) vars kts expected)))
        (tc-result res vars)))))


(define xtc:typecheck:bitcast-check
  (lambda (ast vars kts expected)
    ;; (println 'bitcastcheck'req: expected)
    (tc-result
     (if (null? (cddr ast))
         (if expected (list expected) (list))
         ;; for the symbols we want to set each return type
         ;;(xtc:typecheck:update-var (cadr ast) vars kts (xtc:codegen:convert-from-pretty-types (caddr ast)))
         (list (xtc:codegen:convert-from-pretty-types (caddr ast))))
     vars)))


(define xtc:typecheck:bitconvert-check
  (lambda (ast vars kts expected)
    ;; don't pass on request because convert
    ;; is by definition expecting a different arg to its return!
    (xtc:typecheck:type-check (cadr ast) vars kts #f)
    (tc-result
     (if (null? (cddr ast))
         (if expected (list expected) (list))
         ;; for the symbols we want to set each return type
         ;;(xtc:typecheck:update-var (cadr ast) vars kts (xtc:codegen:convert-from-pretty-types (caddr ast)))
         (list (xtc:codegen:convert-from-pretty-types (caddr ast))))
     vars)))


(define xtc:typecheck:if-check
  (lambda (ast vars kts expected)
                                        ;(println 'if: ast 'expected expected)
    (let* ((a (xtc:typecheck:type-check (ast:if-test ast) vars kts #f)) ;expected))
           (b (xtc:typecheck:type-check (ast:if-then ast) vars kts expected))
           (c (if (null? (cdddr ast))
                  '()
                  (xtc:typecheck:type-check (ast:if-else ast) vars kts expected)))
           (t (xtc:desugar:type-unify (list b c) vars)))
                                        ;(t (cl:intersection (if (atom? b) (list b) b) (if (atom? c) (list c) c))))
      (if *xtc:globals:print-sub-checks* (println 'if:> 'a: a 'b: b 'c: c 't: t))
      ;; (println 'a: a 'b: b 'c: c 't: t)
      (if (null? b)
          (set! t c))
      (if (null? c)
          (set! t b))
      ;; return intersection of b and c
      (tc-result
       (if (null? t)
           t ;;(log-error 'Compiler 'Error: 'cannot 'unify 'then b 'and 'else c 'in ast) ;(map (lambda (v) (xtc:codegen:get-type-str v)) b) 'and 'else (map (lambda (v) (xtc:codegen:get-type-str v)) c) 'clauses 'in ast)
           t)
       vars))))



(define xtc:typecheck:void-check
  (lambda (ast vars kts expected)
    (if (> (length ast) 1)
        (xtc:diagnostics:print-compiler-error "void does not take any arguments")
        (tc-result (list *xtc:codegen:void*) vars))))


(define xtc:typecheck:make-array-check
  (lambda (ast vars kts expected)
    ;; (println 'make-array expected)
    (let* ((a (xtc:typecheck:type-check (cadr ast) vars kts #f))
           (b (map (lambda (x) (set! a (xtc:typecheck:type-check x vars kts a))) (cddr ast))))
      (tc-result (list *xtc:codegen:array* (length (cdr ast)) a) vars))))

(define xtc:typecheck:array-set-check
  (lambda (ast vars kts expected)
    (if (<> (length ast) 4)
        (xtc:diagnostics:print-bad-arity-error (car ast)))
    (let* ((a (xtc:typecheck:type-check (cadr ast) vars kts #f))
           ;; b should be fixed point types
           (b (xtc:typecheck:type-check (caddr ast) vars kts (list *xtc:codegen:si64* *xtc:codegen:si32*)))
           ;; c should be of type a*
           (c (xtc:typecheck:type-check (cadddr ast) vars kts (if (or (null? a)
                                                                (not (xtc:codegen:type? (car a))))
                                                            #f
                                                            (list (caddr (car a)))))))
      (if (or (and (not (null? a))
                   (xtc:codegen:type? (car a))
                   (not (xtc:codegen:array? (car a))))
              (and (not (null? a))
                   (xtc:codegen:type? (car a))
                   (> (xtc:codegen:get-ptr-depth (car a)) 1)))
          (xtc:diagnostics:print-bad-type-error (xtc:codegen:get-type-str (car a) c)))
      ;; array set check will return the value set
      (tc-result c vars))))


(define xtc:typecheck:array-ref-ptr-check
  (lambda (ast vars kts expected)
    (if (<> (length ast) 3)
        (xtc:diagnostics:print-bad-arity-error ast))
    (let ((a (xtc:typecheck:type-check (cadr ast) vars kts '())) ;expected))
          ;; b should be fixed point
          (b (xtc:typecheck:type-check (caddr ast) vars kts (list *xtc:codegen:si64* *xtc:codegen:si32*))))
      (if (xtc:codegen:type? a) (set! a (list a)))
      (tc-result
      (if (null? a)
          a
          (if (or (not (xtc:codegen:array? (car a)))
                  (> (xtc:codegen:get-ptr-depth (car a)) 1))
              (xtc:diagnostics:print-bad-type-error (xtc:codegen:get-type-str (car a)))
              (list (xtc:codegen:add-ptr-depth (caddr (car a))))))
      vars))))


(define xtc:typecheck:array-ref-check
  (lambda (ast vars kts expected)
    ;;(println 'expected expected)
    ;;(println 'array-ref-check: 'ast: ast 'vars: vars 'kts: kts)
    (if (<> (length ast) 3)
        (xtc:diagnostics:print-bad-arity-error ast))
    (let ((a (xtc:typecheck:type-check (cadr ast) vars kts '()))
          ;; b should be fixed point
          (b (xtc:typecheck:type-check (caddr ast) vars kts (list *xtc:codegen:si64* *xtc:codegen:si32*))))
      (if (xtc:codegen:type? a) (set! a (list a)))
      (tc-result
      (if (null? a)
          a
          (if (or (not (xtc:codegen:array? (car a)))
                  (> (xtc:codegen:get-ptr-depth (car a)) 1))
              (xtc:diagnostics:print-bad-type-error (xtc:codegen:get-type-str (car a)))
              (list (caddr (car a)))))
      vars))))

(define xtc:typecheck:make-vector-check
  (lambda (ast vars kts expected)
    ;; (println 'make-vector expected)
    (let* ((a (xtc:typecheck:type-check (cadr ast) vars kts #f))
           (b (map (lambda (x) (set! a (xtc:typecheck:type-check x vars kts a))) (cddr ast))))
      (tc-result (list *xtc:codegen:vector* (length (cdr ast)) a) vars))))

(define xtc:typecheck:vector-set-check
  (lambda (ast vars kts expected)
                                        ;(println 'ast: ast 'vars: vars)
    (if (<> (length ast) 4)
        (xtc:diagnostics:print-bad-arity-error ast))
    (let* ((a (xtc:typecheck:type-check (cadr ast) vars kts #f))
           ;; b should be i32
           (b (xtc:typecheck:type-check (caddr ast) vars kts (list *xtc:codegen:si32*)))
           ;; c should be of type a*
           (c (xtc:typecheck:type-check (cadddr ast) vars kts (if (null? a) #f (list (caddr (car a)))))))
      (if (or (and (not (null? a))
                   (xtc:codegen:type? (car a))
                   (not (xtc:codegen:vector? (car a))))
              (and (not (null? a))
                   (xtc:codegen:type? (car a))
                   (> (xtc:codegen:get-ptr-depth (car a)) 1)))
          (xtc:diagnostics:print-bad-type-error (xtc:codegen:get-type-str (car a))))
      ;; vector set returns a whole new vector!  check llvm ir doc
      (tc-result a vars))))

(define xtc:typecheck:vector-ref-check
  (lambda (ast vars kts expected)
                                        ;(println 'expected expected)
                                        ;(println 'vector-ref-check: 'ast: ast 'vars: vars 'kts: kts)
    (if (<> (length ast) 3)
        (xtc:diagnostics:print-bad-arity-error ast))
    (let ((a (xtc:typecheck:type-check (cadr ast) vars kts '()))
          ;; b should be i32
          (b (xtc:typecheck:type-check (caddr ast) vars kts (list *xtc:codegen:si32*))))
      (if (xtc:codegen:type? a) (set! a (list a)))
      (tc-result
      (if (null? a)
          a
          (if (or (not (xtc:codegen:vector? (car a)))
                  (> (xtc:codegen:get-ptr-depth (car a)) 1))
              (xtc:diagnostics:print-bad-type-error (xtc:codegen:get-type-str (car a)))
              (list (caddr (car a)))))
      vars))))


(define xtc:typecheck:vector-shuffle-check
  (lambda (ast vars kts expected)
    ;;(println 'vector-ref-check: 'ast: ast 'vars: vars 'kts: kts)
    (let ((a (xtc:typecheck:type-check (cadr ast) vars kts expected))
          (b (xtc:typecheck:type-check (caddr ast) vars kts expected)))
      (if (xtc:codegen:type? a) (set! a (list a)))
      (tc-result
      (if (xtc:codegen:pointer? (car a))
          (xtc:codegen:strip-ptr-depth (car a))
          (car a))
      vars))))


(define xtc:typecheck:pointer-set-check
  (lambda (ast vars kts expected)
    (if (<> (length ast) 4)
        (xtc:diagnostics:print-bad-arity-error ast))
    (let* ((aa (xtc:typecheck:type-check (cadr ast) vars kts #f))
           (a (if (and (list? aa) (= (length aa) 1) (symbol? (car aa))) '() aa))
           ;; b should be fixed point types
           (b (xtc:typecheck:type-check (caddr ast) vars kts (list *xtc:codegen:si64* *xtc:codegen:si32*)))
           ;; c should be of type *a
           (c (xtc:typecheck:type-check (cadddr ast) vars kts (if (null? a) #f
                                                            (if (atom? a)
                                                                (list (xtc:codegen:strip-ptr-depth a))
                                                                (list (xtc:codegen:strip-ptr-depth (car a))))))))
      ;; try running type check on a if C exists! but a does not
      (if (and (null? a)
               (not (null? c)))
           (begin ;; (println 'bingo c)
             (if (atom? c) (set! c (list c)))
            (set! a (xtc:typecheck:type-check (cadr ast) vars kts
                                        (map (lambda (k) (xtc:codegen:add-ptr-depth k))
                                             (cl:remove-if-not xtc:codegen:type? c))))))

      (if (not (null? a))
          (if (and (not (xtc:codegen:pointer? (if (xtc:codegen:type? a) a
                                             (if (list? a) (car a) a))))
                   (not (symbol? (if (xtc:codegen:type? a) a
                                     (if (list? a) (car a) a)))))
              (xtc:diagnostics:print-bad-type-error a "trying to pset! into a value")))

      (if (and (list? c) (= 1 (length c))) (set! c (car c)))

      (if (and (symbol? (cadr ast))
               (xtc:codegen:type? c))
          (if (string? c)
              (set! vars (xtc:typecheck:vars-update (cadr ast) vars kts (string-append c "*")))
              (set! vars (xtc:typecheck:vars-update (cadr ast) vars kts (xtc:codegen:add-ptr-depth c)))))
      ;; array set check will return the type of the value set
      (tc-result c vars))))


(define xtc:typecheck:pointer-ref-ptr-check
  (lambda (ast vars kts expected)
    (if (<> (length ast) 3)
        (xtc:diagnostics:print-bad-arity-error ast))
    (let ((a (xtc:typecheck:type-check (cadr ast) vars kts expected))
          ;; b should be fixed point
          (b (xtc:typecheck:type-check (caddr ast) vars kts (list *xtc:codegen:si64* *xtc:codegen:si32*))))
      (if (xtc:codegen:type? a) (set! a (list a)))
      (if (and (not (null? a))
               (< (xtc:codegen:get-ptr-depth (car a)) 1))
          (xtc:diagnostics:print-bad-type-error (xtc:codegen:pretty-print-type (car a))
                                              "Cannot de-reference non-pointer type"))
      (tc-result
      (if (null? a)
          a
          (list (car a)))
      vars))))


(define xtc:typecheck:pointer-ref-check
  (lambda (ast vars kts expected)
    ;; (println 'pointer-ref-check: 'ast: ast 'expected expected) ;'vars: vars 'kts: kts)
    (if (<> (length ast) 3)
        (xtc:diagnostics:print-bad-arity-error ast))
    (if (or (xtc:codegen:type? expected) (atom? expected)) (set! expected (list expected)))
    (let ((a (xtc:typecheck:type-check (cadr ast) vars kts ;; '())) ;expected))
                                 (map (lambda (k) (xtc:codegen:add-ptr-depth k))
                                      (cl:remove-if-not xtc:codegen:type? expected))))
          ;; b should be fixed point
          (b (xtc:typecheck:type-check (caddr ast) vars kts (list *xtc:codegen:si64* *xtc:codegen:si32*))))
      (if (xtc:codegen:type? a) (set! a (list a)))
      (if (and (not (null? a))
               (< (xtc:codegen:get-ptr-depth (car a)) 1))
          (xtc:diagnostics:print-bad-type-error (xtc:codegen:pretty-print-type (car a))
                                              "Cannot de-reference non-pointer type"))
      (tc-result
      (if (null? a)
          a
          (list (xtc:codegen:strip-ptr-depth (car a))))
      vars))))


;; make should be of the form
;; (halloc type)
;; where type is a valid type
;; (nalloc i64)
;; memory is allocated on the head
(define xtc:typecheck:heap-alloc-check
  (lambda (ast vars kts expected)
    (if (and expected
             (not (xtc:codegen:pointer? expected))
             (not (symbol? expected)))
        (xtc:diagnostics:print-compiler-error "Allocation must return pointer type" ast))
    (tc-result
    (if (= (length ast) 2)
        (let ((a (xtc:typecheck:type-check (cadr ast) vars kts (list *xtc:codegen:si64* *xtc:codegen:si32*))))
          expected)
        expected)
    vars)))


;; make should be of the form
;; (alloc type)
;; where type is a valid type
;; (alloc i64)
;; memory is allocated on the head
(define xtc:typecheck:zone-alloc-check
  (lambda (ast vars kts expected)
    (if (and expected
             (not (xtc:codegen:pointer? expected))
             (not (symbol? expected)))
        (xtc:diagnostics:print-compiler-error "Allocation must return pointer type" ast))
    (tc-result
    (if (= (length ast) 2)
        (let ((a (xtc:typecheck:type-check (cadr ast) vars kts (list *xtc:codegen:si64* *xtc:codegen:si32*))))
          expected)
        expected)
    vars)))



;; make should be of the form
;; (salloc type)
;; where type is a valid type
;; (salloc i64)
;; memory is allocated on the head
(define xtc:typecheck:stack-alloc-check
  (lambda (ast vars kts expected)
    (if (and expected
             (not (xtc:codegen:pointer? expected))
             (not (symbol? expected)))
        (xtc:diagnostics:print-compiler-error "Allocation must return pointer type" ast))
    (tc-result
    (if (= (length ast) 2)
        (let ((a (xtc:typecheck:type-check (cadr ast) vars kts (list *xtc:codegen:si64* *xtc:codegen:si32*))))
          expected)
        expected)
    vars)))

(define xtc:typecheck:num-of-elts-check
  (lambda (ast vars kts expected)
    (tc-result *xtc:codegen:si64* vars)))

(define xtc:typecheck:obj-size-check
  (lambda (ast vars kts expected)
    (tc-result *xtc:codegen:si64* vars)))

(define xtc:typecheck:ref-check
  (lambda (ast vars kts expected)
    (if (not (xtc:typecheck:vars-ref vars (cadr ast)))
        (xtc:diagnostics:print-compiler-error "no valid local variable found in call to ref" ast))
    (tc-result (list (xtc:codegen:add-ptr-depth (car (xtc:typecheck:vars-ref vars (cadr ast))))) vars)))

(define xtc:typecheck:make-tuple-check
  (lambda (ast vars kts expected)
    (let* ((a (map (lambda (x t)
                     (xtc:typecheck:type-check x vars kts t))
                   (cdr ast)
                   (if (and (list? expected)
                            (equal? 14 (car expected)))
                       (cdr expected)
                       (make-list (length (cdr ast)) #f)))))
      (tc-result (cons *xtc:codegen:tuple* a) vars))))


(define xtc:typecheck:tuple-set-check
  (lambda (ast vars kts expected)
    ;;(println 'tsetcheck ast vars kts expected)
    (if (<> (length ast) 4)
        (xtc:diagnostics:print-bad-arity-error ast))
    ;; (caddr ast) must be an integer
    (if (not (integer? (caddr ast)))
        (xtc:diagnostics:print-bad-type-error (caddr ast) "tuple-set! must use a literal integer index"))
    (let* (;; a should be a tuple of some kind
           (a (let ((res (xtc:typecheck:type-check (cadr ast) vars kts #f)))
                (if (null? res) res
                    (if (and (string? (car res))
                             (char=? (string-ref (car res) 0) #\%))
                        (let ((t (xtc:cache:get-namedtype-type (xtc:codegen:get-base-type (car res)))))
                          (dotimes (i (xtc:codegen:get-ptr-depth (car res))) (set! t (xtc:codegen:add-ptr-depth t)))
                          (list t))
                        res))))
           ;; b should be 32bit fixed point type -- llvm structs only support 32bit indexes
           (b (xtc:typecheck:type-check (caddr ast) vars kts (list *xtc:codegen:si32*)))
           (req? (if (and (not (null? a))
                          (list? a))
                     (if (xtc:codegen:tuple? (car a))
                         (if (> (+ 2 (caddr ast)) (length (car a)))
                             (xtc:diagnostics:print-index-oob-error 'tuple ast)
                             (list-ref (car a) (+ 1 (caddr ast))))
                         #f)
                     #f))
                                        ;(llllll (println 'req: req?  'cara: (car a) 'z: (caddr ast) 'list-ref: (+ 1 (caddr ast))))
           ;; c should be an element of a tuple
           (c (xtc:typecheck:type-check (cadddr ast) vars kts req?)))
      ;; (if (and (not (null? a))
      ;;          (list? a))
      ;;     (if (xtc:codegen:tuple? (car a))
      ;;         (list-ref (car a) (+ 1 (caddr ast)))
      ;;         #f)
      ;;     #f))))
      (if (and (not (null? a))
               (not (null? (car a)))
               (not (symbol? (car a))) ;; symbol may not have yet been defined!!
               (not (xtc:codegen:tuple? (car a))))
          (xtc:diagnostics:print-bad-type-error (caddr ast) (string-append "invalid tuple-set-check type " (xtc:codegen:get-type-str (car a)))))
      ;; if (cadddr ast) is a symbol we should update
      ;; it's type with c but for polymorphic cases
      ;; we should ensure that we also do a type-unification
      (if (symbol? (cadddr ast))
          (let* ((types (if (xtc:typecheck:vars-ref vars (cadddr ast))
                            (xtc:typecheck:vars-ref vars (cadddr ast))
                            (xtc:typecheck:type-check (cadddr ast) vars kts req?)))
                 (utype (xtc:desugar:type-unify (list c types) vars)))
                                        ;(println 'types: types 'utype: utype 'c: (list c types))
            (if (null? utype)
                (set! vars (xtc:typecheck:vars-force (cadddr ast) vars kts (list c)))
                (set! vars (xtc:typecheck:vars-force (cadddr ast) vars kts (list utype))))))

      ;; tuple set check will return the type of the value set
      (tc-result c vars))))


(define xtc:typecheck:tuple-ref-ptr-check
  (lambda (ast vars kts expected)
    ;; (caddr ast) must be an integer
    (if (not (integer? (caddr ast)))
        (xtc:diagnostics:print-bad-type-error (caddr ast) "tuple-ref must use a literal integer index"))
    (let* (; a should be a tuple of some kind!
           (a (xtc:typecheck:type-check (cadr ast) vars kts #f)) ;;(if (xtc:codegen:type? expected)
           ;;(xtc:codegen:tuple? expected)
           ;;expected
           ;;#f))) ;expected))
           ;; b should be fixed point -- llvm structs only support 32bit indexes
           (b (xtc:typecheck:type-check (caddr ast) vars kts (list *xtc:codegen:si32*))))
      (if (and (not (null? a)) (or (atom? a) (xtc:codegen:type? a)))  (set! a (list a)))

      ;; check for named types
      (if (not (null? a)) (set! a (xtc:typecheck:try-to-resolve-named-types (car a) vars)))


      ;;(println 'tupref-check 'a: a 'ast: ast (list-ref (car a) (+ 1 (caddr ast))))
      (if (and (not (null? a))
               (list? a)
               (xtc:codegen:tuple? (car a)))
          (list (xtc:codegen:add-ptr-depth (list-ref (car a) (+ 1 (caddr ast)))))
          ;;'()))))
          (tc-result
          (if (null? a)
              '()
              ;; (xtc:diagnostics:print-bad-type-error (caddr ast) (string-append "invalid tuple-ref-ptr type " (xtc:codegen:get-type-str (car a)))))))))
              a)
          vars)))))



(define xtc:typecheck:tuple-ref-check
  (lambda (ast vars kts expected)
    ;; (println 'ref-check ast expected) ;kts vars)
    ;; (caddr ast) must be an integer
    (if (not (integer? (caddr ast)))
        (xtc:diagnostics:print-bad-type-error (caddr ast) "tuple-ref must use a literal integer index"))
    (let* (; a should be a tuple of some kind!
           (a (xtc:typecheck:type-check (cadr ast) vars kts #f)) ;(if (and (xtc:codegen:type? expected)
                                        ;	(xtc:codegen:tuple? expected))
                                        ;  expected
                                        ; #f))) ;expected))
           ;; b should be fixed point -- llvm structs only support 32bit indexes
           (b (xtc:typecheck:type-check (caddr ast) vars kts (list *xtc:codegen:si32*)))
           (idx (eval (caddr ast))))
      (if (and (not (null? a)) (or (atom? a) (xtc:codegen:type? a))) (set! a (list a)))
      ;; unify a?
      (if (not (null? a)) (set! a (xtc:desugar:type-unify (car a) vars)))
      (if (and (not (null? a)) (or (atom? a) (xtc:codegen:type? a))) (set! a (list a)))
      ;; is 'a' still generic? (i.e. not resolved to a named type yet?)
      (if (and (not (null? a))
               (symbol? (car a)))
          (let* ((p1 (string-split-on (symbol->string (car a)) "##"))
                 ;; (lllll (println 'ppp1: p1))
                 (p2 (string-split-on (car p1) ":"))
                 ;; (llllllll (println 'ppp2: p2))
                 (args (map (lambda (x)
                              (if (char=? (string-ref x 0) #\!)
                                  (string->symbol (string-append x "##" (cadr p1)))
                                  (xtc:codegen:get-type-from-pretty-str x)))
                            (if (null? (cdr p2))
                                '()
                                (xtc:codegen:get-pretty-tuple-arg-strings (cadr p2))))))
            (set! a (list (list (cons 114 args))))))
      ;; we MUST expand named types!
      (if (and (not (null? a))
               (not (number? (car a))))
          (set! a (xtc:typecheck:try-to-resolve-named-types (car a) vars)))
      (if (and (not (null? a))
               (or (atom? a)
                   (number? (car a))
                   (xtc:codegen:type? a)))
          (set! a (list a)))
      (if (and (not (null? a))
               (list? a)
               (xtc:codegen:tuple? (car a)))
          (begin (if (>= (caddr ast)
                         (- (length (car a)) 1))
                     (xtc:diagnostics:print-index-oob-error 'tuple ast))
                 (let ((res (list-ref (car a) (+ 1 idx))))
                   (if (not (xtc:codegen:type? res))
                       (if (and (xtc:typecheck:vars-ref vars res) expected)
                           (if (null? (xtc:typecheck:vars-ref vars res))
                               (begin
                                 ;; (println 'updateres: res '-> expected)
                                 (set! vars (xtc:typecheck:vars-update res vars kts expected))
                                 (set! res expected))
                               (set! res '()))
                           (set! res '())))
                   ;; (println 'trefres: res)
                   (tc-result res vars)))
          (tc-result '() vars)))))


;;(closure-set! closure a i32 5)
(define xtc:typecheck:closure-set-check
  (lambda (ast vars kts expected)
    ;;(println 'cset 'ast: ast 'expected expected)
    (if (<> (length ast) 5)
        (xtc:diagnostics:print-bad-arity-error ast))
    (let* (;; a should be a closure of some kind
           (a (if (and (symbol? (cadr ast))
                       (xtc:cache:closure-exists? (symbol->string (cadr ast))))
                  #t ; // yes (cadr ast) is a globally defined closure
                  (xtc:typecheck:type-check (cadr ast) vars kts #f)))
           ;; b should be a string (the var's name)
           (b (xtc:typecheck:type-check (caddr ast) vars kts (list *xtc:codegen:si8*)))
           ;; c should be a value for var's name
           (c (xtc:typecheck:type-check (cadddr ast) vars kts
                                  (if (null? (car (cddddr ast)))
                                      expected
                                      (xtc:codegen:get-type-from-str (car (cddddr ast)))))))
      (tc-result c vars))))

;;(closure-ref closure a i32)
(define xtc:typecheck:closure-ref-check
  (lambda (ast vars kts expected)
    ;; (println 'cls 'ref 'check: ast 'expected expected)
    (if (<> (length ast) 4)
        (xtc:diagnostics:print-bad-arity-error ast))
    (let* (;; a should be a closure of some kind or a single-candidate polyfunc
           (a (if (and (symbol? (cadr ast))
                       (or (xtc:cache:closure-exists? (symbol->string (cadr ast)))
                           (and (xtc:cache:polyfunc-exists? (symbol->string (cadr ast)))
                                (= 1 (length (xtc:cache:get-polyfunc-candidate-names (symbol->string (cadr ast))))))))
                  #t ; // yes (cadr ast) is a globally defined closure or single-candidate polyfunc
                  (xtc:typecheck:type-check (cadr ast) vars kts #f))) ;; do NOT check against request!
           ;; b should be a string (the var's name)
           (b (xtc:typecheck:type-check (caddr ast) vars kts (xtc:codegen:add-ptr-depth (list *xtc:codegen:si8*)))))
      (tc-result
      (if (null? (cadddr ast))
          (if expected
              expected
              '())
          (xtc:codegen:get-type-from-str (cadddr ast)))
      vars))))

;; (closure-ref closure a i32)
(define xtc:typecheck:closure-refcheck-check
  (lambda (ast vars kts expected)
    ;; (println 'cls2 'ref 'check: ast 'expected expected)
    (if (<> (length ast) 3)
        (xtc:diagnostics:print-bad-arity-error ast))
    (let* (;; a should be a closure of some kind or a single-candidate polyfunc
           (a (if (and (symbol? (cadr ast))
                       (or (xtc:cache:closure-exists? (symbol->string (cadr ast)))
                           (and (xtc:cache:polyfunc-exists? (symbol->string (cadr ast)))
                                (= 1 (length (xtc:cache:get-polyfunc-candidate-names (symbol->string (cadr ast))))))))
                  #t ; // yes (cadr ast) is a globally defined closure or single-candidate polyfunc
                  (xtc:typecheck:type-check (cadr ast) vars kts #f))) ;; expected)))
           ;; b should be a string (the var's name)
           (b (xtc:typecheck:type-check (caddr ast) vars kts (list *xtc:codegen:si8*))))
      (tc-result (list *xtc:codegen:i1*) vars))))


(define xtc:typecheck:set-check
  (lambda (ast vars kts expected)
    ;; (println 'ast: ast 'vars: vars 'kts: kts 'expected: expected)
    (let* ((sym (xtc:typecheck:get-var (ast:set!-var ast) vars))
           (a (xtc:typecheck:type-check (ast:set!-expr ast) vars kts (cdr sym))))
      (if *xtc:globals:print-sub-checks* (println 'set!:> 'ast: ast 'a: a))
      ;; (println 'a: a 'sym: sym)
      (if (and (list? a)
               (= (length a) 1)
               (xtc:codegen:type? (car a)))
          (set! a (car a)))
      ;; if sym is not a global var then add return type to sym
      (if (and (xtc:typecheck:vars-ref vars (car sym))
               (member a (xtc:typecheck:vars-ref vars (car sym))))
          (set! vars (xtc:typecheck:vars-force (car sym) vars '() a))
          (if (xtc:typecheck:vars-ref vars (car sym))
              (set! vars (xtc:typecheck:vars-update (car sym) vars kts a))))
      (tc-result a vars))))

(define xtc:typecheck:pdref-check
  (lambda (ast vars kts expected)
    (let* ((a (xtc:typecheck:type-check (cadr ast) vars kts expected)))
      (if *xtc:globals:print-sub-checks* (println 'ptrref:> 'ast: ast 'a: a))
      ;; return type of ptrref is 'a' dereferenced'
      (if (list? a)
          (set! a (car a)))
      (tc-result
       (if (and (xtc:codegen:type? a)
                (xtc:codegen:pointer? a))
           (xtc:codegen:strip-ptr-depth a)
           (xtc:diagnostics:print-bad-type-error a "pref needs a pointer argument"))
       vars))))


(define xtc:typecheck:pref-check
  (lambda (ast vars kts expected)
    (let* ((a (xtc:typecheck:type-check (cadr ast) vars kts expected)))
      (if *xtc:globals:print-sub-checks* (println 'ptrref:> 'ast: ast 'a: a))
      ;; return type of ptrref is 'a' referenced
      (if (list? a)
          (set! a (car a)))
      (tc-result
       (if (and (xtc:codegen:type? a)
                (xtc:codegen:pointer? a))
           (xtc:codegen:add-ptr-depth a)
           (xtc:diagnostics:print-bad-type-error a "pref needs a pointer argument"))
       vars))))


(define xtc:typecheck:lambda-check
  (lambda (ast vars kts expected)
    ;; (println 'lcheck: ast 'expected expected)
    ;; first we check if a type request has been made
    (if (and expected (xtc:codegen:closure? expected))
        ;; if there is a request then cycle through
        ;; and set lambda arg symbols
        (begin
          (if (<> (length (ast:lambda-params ast))
                  (length (cddr expected)))
              (begin
                (xtc:diagnostics:print-compiler-error "Bad request to lambda chk:" ast)))
          (for-each (lambda (sym req)
                     (if (symbol? sym)
                         (if (atom? req)
                             (set! vars (xtc:typecheck:vars-update sym vars kts (list req)))
                             (set! vars (xtc:typecheck:vars-update sym vars kts req)))))
               (ast:lambda-params ast)
               (cddr expected))
          ;; finally set expected to the return type
          (set! expected (cadr expected))))
    ;; run body for type coverage
    ;; grab the last result as return type
    (let ((res (xtc:desugar:type-unify (xtc:typecheck:type-check (ast:lambda-body ast) vars kts expected) vars)))
      ;; if no valid return type rerun type-check for a second time
      (if (not (or (xtc:codegen:type? res)
                   (and (list? res)
                        (= (length res) 1)
                        (xtc:codegen:type? (car res)))))
          (set! res (xtc:desugar:type-unify (xtc:typecheck:type-check (ast:lambda-body ast) vars kts expected) vars)))
      ;; if we have a choice between numeric options we force one!
      (if (and (not (xtc:desugar:complex-type? res))
               (list? res)
               (> (length res) 1)
               (not (member #f (map (lambda (t) (xtc:codegen:floating-point? t)) res))))
          (set! res (list (apply min res)))) ;;(list *xtc:codegen:fp64*))) ;; force doubles
      (if (and (not (xtc:desugar:complex-type? res))
               (list? res)
               (> (length res) 1)
               (not (member #f (map (lambda (t) (xtc:codegen:fixed-point? t)) res))))
          (set! res (list (apply min res)))) ;; (list *xtc:codegen:si64*))) ;; force i64
      ;; if we now have a valid type - then sending type to body!
      (if (and (list? res)
               (= (length res) 1)
               (xtc:codegen:type? (car res)))
          (begin (xtc:typecheck:type-check (ast:lambda-body ast) vars kts (car res))
                 (set! res (car res))))
      ;; #371: if a concrete *pointer* return type was requested (e.g. via a
      ;; bind-func signature) the body must actually produce that pointer type.
      ;; Without this check a mismatch between two concrete pointer/tuple types
      ;; slips through --- the declared type silently wins and the body's value
      ;; is bit-cast to it, an unsoundness. Restricting to pointers leaves the
      ;; legitimate scalar coercions (numeric widening, scalar->vector
      ;; broadcast) to the existing forcing/codegen path, and skips anything
      ;; still generic (a !-type).
      (if (and expected (xtc:codegen:type? expected) (xtc:codegen:type? res)
               (xtc:codegen:pointer? expected) (xtc:codegen:pointer? res)
               (not (xtc:desugar:bang-type? expected)) (not (xtc:desugar:bang-type? res))
               (not (equal? res expected)))
          (xtc:diagnostics:print-compiler-error
           (string-append "function body returns type '"
                          (xtc:codegen:pretty-print-type res)
                          "' but its signature declares a return type of '"
                          (xtc:codegen:pretty-print-type expected) "'")
           (ast:lambda-body ast)))
      ;; return lambda type which is made up of
      ;; argument symbols plus return type from last body expression
      (let* ((ret (list (xtc:codegen:add-ptr-depth (list* *xtc:codegen:closure* res (ast:lambda-params ast)) 2)))
             (uret (xtc:desugar:type-unify ret vars)))
        (if (not (null? uret))
            (for-each (lambda (sym req)
                       ;; (println 'larg: sym 'req: req)
                       (if (symbol? sym)
                           (set! vars (xtc:typecheck:vars-update sym vars kts (xtc:desugar:type-unify req vars)))))
                 (ast:lambda-params ast)
                 (cddr uret)))
        ;; (println 'vars3 vars)
        (tc-result (if (null? uret) ret uret) vars)))))


;; whenever a closure is called we calculate a type for it
;; at the end these possibly multiple views should unify!
(define xtc:typecheck:closure-call-check
  (lambda (ast vars kts expected)
    ;; (println 'cchint 'ast: ast 'vars: vars 'request: expected)
    ;; otherwise we need to try to find a type definition for the closure
    (let* ((ctype (if (xtc:typecheck:vars-ref vars (car ast))
                      (xtc:typecheck:vars-ref vars (car ast))
                      (if (xtc:cache:closure-exists? (symbol->string (car ast)))
                          (list (xtc:cache:get-closure-type (symbol->string (car ast))))
                          ;; check for globalvar closures
                          (if (and (xtc:cache:globalvar-exists? (symbol->string (car ast)))
                                   (xtc:codegen:closure? (xtc:cache:get-globalvar-type (symbol->string (car ast)))))
                              (list (xtc:cache:get-globalvar-type (symbol->string (car ast))))
                              (xtc:diagnostics:print-missing-identifier-error (car ast) 'closure)))))
           ;; (llllllll (println 'ctype: ctype))
           ;; get argument expression types
           (res (map (lambda (e t)
                       ;; (println 'e: e 't: t)
                       (let ((res (xtc:typecheck:type-check e vars kts
                                                      (if (symbol? t)
                                                          (tc-unwrap (xtc:typecheck:symbol-check t vars kts #f))
                                                          t))))
                         ;; if t is a symbol then add res to t
                         (if (and (not (null? res))
                                  (symbol? t))
                             (if (or (and (list? res)
                                          (xtc:codegen:type? (car res)))
                                     (xtc:codegen:type? res))
                                 (set! vars (xtc:typecheck:vars-force t vars kts res))
                                        ;(set! vars (xtc:typecheck:vars-update t vars kts res))
                                 (set! vars (xtc:typecheck:vars-update t vars kts res))))
                                        ;(if (symbol? t) (xtc:typecheck:update-var t vars kts res))

                         res))
                     (cdr ast)
                     (if (or (null? ctype)
                             (and (number? (car ctype))
                                  (= (car ctype) (+ *xtc:codegen:closure* (* 2 *xtc:codegen:pointer*))))
                             (not (xtc:codegen:closure? (car ctype))))
                         (make-list (length (cdr ast)) #f)
                         ;; if we are using an existing definition then check arity
                         (if (<> (length (cddr (car ctype)))
                                 (length (cdr ast)))
                             (xtc:diagnostics:print-bad-arity-error ast)
                             (cddr (car ctype))))))
           ;; if we already have a type defined we can use it's return type
           ;; otherwise
           ;; if there was a request that will be the return type
           ;; otherwise we cannot know it
           (ret (if (and (not (null? ctype))
                         (not (atom? (car ctype)))
                         (xtc:codegen:closure? (car ctype)))
                    (cadr (car ctype))
                    (if (and expected
                             (not (and (list? expected)
                                       (equal? (car expected) *xtc:codegen:notype*)))
                             (not (null? expected)))
                        expected
                        '()))))

      (if *xtc:globals:print-sub-checks* (println 'closure:> 'ast: ast 'res: res 'ret: ret))
      (if (xtc:typecheck:vars-ref vars (car ast))
          (set! vars (xtc:typecheck:vars-update (car ast) vars kts
                              (list (xtc:codegen:add-ptr-depth (list* *xtc:codegen:closure* ret res) 2)))))
      (tc-result (if (list? ret) ret
                     (list ret)) vars))))


;; for fptrcall
;; which has the form
;; (fptrcall fptr ... args)
(define xtc:typecheck:fptrcall-check
  (lambda (ast vars kts expected)
    (let* ((fptr (xtc:typecheck:type-check (cadr ast) vars kts #f)))
      (tc-result
      (if (null? fptr)
          (list)
          (let* ((ctype (if (xtc:codegen:closure? (car fptr))
                            (car fptr)
                            (xtc:diagnostics:print-bad-type-error (car fptr) "bad fptr type in fptrcall")))
                 (res (map (lambda (e t)
                             ;;(println 'e: e 't: t)
                             (let ((res (xtc:typecheck:type-check e vars kts
                                                            (if (symbol? t)
                                                                (tc-unwrap (xtc:typecheck:symbol-check t vars kts #f))
                                                                t))))
                               ;; if t is a symbol then add res to t
                               (if (symbol? t)
                                   (if (or (and (list? res)
                                                (xtc:codegen:type? (car res)))
                                           (xtc:codegen:type? res))
                                       (set! vars (xtc:typecheck:vars-force t vars kts res))
                                       (set! vars (xtc:typecheck:vars-update t vars kts res))))
                               res))
                           (cddr ast)
                           (if (<> (length (cddr ctype))
                                   (length (cddr ast)))
                               (xtc:diagnostics:print-bad-arity-error ast)
                               (cddr ctype)))))
            (cadr ctype)))
      vars))))




(define xtc:typecheck:dotimes-check
  (lambda (ast vars kts expected)
    (let ((a (xtc:typecheck:type-check (car (cadr ast)) vars kts #f))
          (b (xtc:typecheck:type-check (cadr (cadr ast)) vars kts #f)))
      (if (and (not (xtc:codegen:type? b))
               (= (length b) 1))
          (set! b (car b)))
      (if (and (not (xtc:codegen:type? a))
               (= (length a) 1))
          (set! a (car a)))
      (if (and (xtc:codegen:type? a)
               (list? b)
               (member a b))
          (set! b a))
      ;; (car (cadr ast)) should be a symbol that we want to update with a
      (if (not (symbol? (car (cadr ast))))
          (xtc:diagnostics:print-badly-formed-expression-error 'dotimes ast))
      (set! vars (xtc:typecheck:vars-update (car (cadr ast)) vars kts b))
      (if (and (symbol? (cadr (cadr ast)))
               (xtc:codegen:type? a))
          (set! vars (xtc:typecheck:vars-update (cadr (cadr ast)) vars kts a)))
      ;; check over body code but don't worry about return types
      (xtc:typecheck:type-check (caddr ast) vars kts #f)
      ;; dotimes returns void
      (tc-result (list *xtc:codegen:void*) vars))))

(define xtc:typecheck:while-check
  (lambda (ast vars kts expected)
    (if (tree-member 'let (cadr ast))
        (xtc:diagnostics:print-compiler-error "You cannot bind variables within a while condition check!" (cadr ast)))
    (let ((type (xtc:typecheck:type-check (cadr ast) vars kts (list *xtc:codegen:i1*)))
          (body (xtc:typecheck:type-check (caddr ast) vars kts #f)))
      (if (not (or (and (number? type) (= type *xtc:codegen:i1*))
                   (= (car type) *xtc:codegen:i1*)
                   (null? type)))
          (xtc:diagnostics:print-bad-type-error (car type) "test expression in while loop must return a boolean"))
      (tc-result (list *xtc:codegen:void*) vars))))

(define xtc:typecheck:printf-check
  (lambda (ast vars kts expected)
    (let ((a (xtc:typecheck:type-check (cadr ast) vars kts (list (+ *xtc:codegen:si8* *xtc:codegen:pointer*)))))
      ;; run through everything else for completeness but don't care about the results
      (for-each (lambda (x) (xtc:typecheck:type-check x vars kts #f)) (cddr ast))
      ;; printf returns i32
      (tc-result (list *xtc:codegen:si32*) vars))))

(define xtc:typecheck:fprintf-check
  (lambda (ast vars kts expected)
    (let ((a (xtc:typecheck:type-check (cadr ast) vars kts (list (+ *xtc:codegen:si8* *xtc:codegen:pointer*))))
          (b (xtc:typecheck:type-check (cadr ast) vars kts (list (+ *xtc:codegen:si8* *xtc:codegen:pointer*)))))
      ;; run through everything else for completeness but don't care about the results
      (for-each (lambda (x) (xtc:typecheck:type-check x vars kts #f)) (cdddr ast))
      ;; printf returns i32
      (tc-result (list *xtc:codegen:si32*) vars))))

(define xtc:typecheck:sprintf-check
  (lambda (ast vars kts expected)
    (let ((a (xtc:typecheck:type-check (cadr ast) vars kts (list (+ *xtc:codegen:si8* *xtc:codegen:pointer*))))
          (b (xtc:typecheck:type-check (caddr ast) vars kts (list (+ *xtc:codegen:si8* *xtc:codegen:pointer*)))))
      ;; run through everything else for completeness but don't care about the results
      (for-each (lambda (x) (xtc:typecheck:type-check x vars kts #f)) (cdddr ast))
      ;; printf returns i32
      (tc-result (list *xtc:codegen:si32*) vars))))

(define xtc:typecheck:sscanf-check
  (lambda (ast vars kts expected)
    (let ((a (xtc:typecheck:type-check (cadr ast) vars kts (list (+ *xtc:codegen:si8* *xtc:codegen:pointer*))))
          (b (xtc:typecheck:type-check (cadr ast) vars kts (list (+ *xtc:codegen:si8* *xtc:codegen:pointer*)))))
      ;; run through everything else for completeness but don't care about the results
      (for-each (lambda (x) (xtc:typecheck:type-check x vars kts #f)) (cdddr ast))
      ;; printf returns i32
      (tc-result (list *xtc:codegen:si32*) vars))))

(define xtc:typecheck:fscanf-check
  (lambda (ast vars kts expected)
    (let ((a (xtc:typecheck:type-check (cadr ast) vars kts (list (+ *xtc:codegen:si8* *xtc:codegen:pointer*))))
          (b (xtc:typecheck:type-check (caddr ast) vars kts (list (+ *xtc:codegen:si8* *xtc:codegen:pointer*)))))
      ;; run through everything else for completeness but don't care about the results
      (for-each (lambda (x) (xtc:typecheck:type-check x vars kts #f)) (cdddr ast))
      ;; printf returns i32
      (tc-result (list *xtc:codegen:si32*) vars))))

(define xtc:typecheck:string-check
  (lambda (ast vars kts expected)
    (tc-result
     (if (string? ast)
         (list (+ *xtc:codegen:si8* *xtc:codegen:pointer*))
         '())
     vars)))

(define xtc:typecheck:carcdr-check
  (lambda (ast vars kts expected)
    ;; check that we are getter a pair as an argument
    (xtc:typecheck:type-check (cadr ast) vars kts (list (xtc:codegen:add-ptr-depth *xtc:codegen:pair*)))
    ;; don't do anything about return type yet
    (tc-result '() vars)))

(define xtc:typecheck:coerce-check
  (lambda (ast vars kts expected)
    (xtc:typecheck:type-check (cadr ast) vars kts #f)
    (tc-result (list (caddr ast)) vars)))


(define xtc:typecheck:closure-in-first-position
  (lambda (ast vars kts expected)
    ;; (println 'ast ast 'expected expected)
    ;; first check return type of car ast (which will be a closure)
    ;; then check against it's arg types
    (let ((type (xtc:typecheck:type-check (car ast) vars kts expected)))
      (if (and (not (xtc:codegen:closure? type))
               (list? type)
               (xtc:codegen:closure? (car type)))
          (set! type (car type)))
      (tc-result
      (if (not (xtc:codegen:type? type))
          '(()) ;;(list *xtc:codegen:notype*)
          (begin
            (if (null? type)
                (xtc:diagnostics:print-bad-type-error "unknown-type" ast))
            (if (not (list? type))
                (xtc:diagnostics:print-bad-type-error (xtc:codegen:pretty-print-type type) ast))
            (if (<> (length (cddr type)) (length (cdr ast)))
                (xtc:diagnostics:print-bad-arity-error ast))
            (if (<> (+ *xtc:codegen:closure* *xtc:codegen:pointer* *xtc:codegen:pointer*) (car type))
                (xtc:diagnostics:print-bad-type-error (xtc:codegen:pretty-print-type (car type)) ast)
                (begin (map (lambda (a b)
                              (xtc:typecheck:type-check b vars kts a))
                            (cddr type)
                            (cdr ast))
                       (cadr type)))))
      vars))))




(define *xtc:typecheck:type-check:calls* 0)

;; vars is statefull and will be modified in place
(define xtc:typecheck:type-check
  (lambda (ast vars kts expected)
    (set! *xtc:typecheck:type-check:calls* (+ *xtc:typecheck:type-check:calls* 1))
    (set! expected (xtc:typecheck:normalise-expected expected))
    ;; (println 'tc: ast); 'vars: vars)
    ;; (println 'type-check: ast  'vars: vars  'kts: kts 'expected expected)
    (if *xtc:globals:print-main-check* (println 'type-check: ast 'kts: kts 'expected expected))
    (if *xtc:globals:print-main-check* (println 'vars------: vars))
    (let ((result
    (cond ((null? ast) '())
          ((and (atom? ast) (number? ast)) (xtc:typecheck:numeric-check ast vars kts expected))
          ((and (atom? ast) (symbol? ast)) (xtc:typecheck:symbol-check ast vars kts expected))
          ((and (atom? ast) (string? ast)) (xtc:typecheck:string-check ast vars kts expected))
          ((atom? ast) (xtc:diagnostics:print-compiler-error "internal error unhandled atom" ast))
          ((ast:let? ast) (xtc:typecheck:let-check ast vars kts expected))
          ((ast:lambda? ast) (xtc:typecheck:lambda-check ast vars kts expected))
          ((and (list? ast) (equal? (car ast) 't:))
           (xtc:typecheck:type-check (cadr ast) vars kts
                               (xtc:codegen:get-type-from-pretty-str
                                (symbol->string (caddr ast)))))
          ((and (list? ast) (member (car ast) *xtc:globals:mathbinaryaritylist*))
           ;; '(* / + - % modulo bitwise-and bitwise-or bitwise-eor bitwise-shift-left bitwise-shift-right bitwise-not)))
           (let ((r (let ((res (xtc:typecheck:math-check ast vars kts expected)))
                      (if (vector? res) (tc-type res) res))))
             (if (xtc:codegen:tuple? r)
                 (begin
                   (set! *unique-polynum* (+ 1 *unique-polynum*))
                   (let ((m (string->symbol (string-append (cond ((eq? (car ast) '*) "xtm_multiplication##")
                                                                 ((eq? (car ast) '+) "xtm_addition##")
                                                                 ((eq? (car ast) '/) "xtm_division##")
                                                                 ((eq? (car ast) '-) "xtm_subtraction##")
                                                                 ((eq? (car ast) '%) "xtm_modulo##")
                                                                 (else (log-error "Error in math overloading")))
                                                           (number->string *unique-polynum*)))))
                     (set! vars (xtc:typecheck:vars-add m vars))
                     (set-car! ast m)
                     (set! r (xtc:typecheck:type-check ast vars kts expected)))))
             r))
          ((and (list? ast) (member (car ast) '(< > = <>)))
           (let ((r (let ((res (xtc:typecheck:compare-check ast vars kts expected)))
                      (if (vector? res) (tc-type res) res))))
             (if (xtc:codegen:tuple? r)
                 (begin
                   (set! *unique-polynum* (+ 1 *unique-polynum*))
                   (let ((m (string->symbol (string-append (cond ((eq? (car ast) '<) "xtm_lessthan##")
                                                                 ((eq? (car ast) '>) "xtm_greaterthan##")
                                                                 ((eq? (car ast) '=) "xtm_equal##")
                                                                 ((eq? (car ast) '<>) "xtm_notequal##")
                                                                 (else (log-error "Error in math overloading")))
                                                           (number->string *unique-polynum*)))))
                     (set! vars (xtc:typecheck:vars-add m vars))
                     (set-car! ast m)
                     (set! r (xtc:typecheck:type-check ast vars kts expected)))))
             *xtc:codegen:i1*))
          ((and (list? ast) (member (car ast) *xtc:globals:mathintrinsicslist*)) (xtc:typecheck:math-intrinsic-check ast vars kts expected))
          ((and (list? ast) (member (car ast) '(dotimes))) (xtc:typecheck:dotimes-check ast vars kts expected))
          ((and (list? ast) (member (car ast) '(while))) (xtc:typecheck:while-check ast vars kts expected))
          ((and (list? ast) (member (car ast) '(printf))) (xtc:typecheck:printf-check ast vars kts expected))
          ((and (list? ast) (member (car ast) '(sprintf))) (xtc:typecheck:sprintf-check ast vars kts expected))
          ((and (list? ast) (member (car ast) '(fprintf))) (xtc:typecheck:fprintf-check ast vars kts expected))
          ((and (list? ast) (member (car ast) '(sscanf))) (xtc:typecheck:sscanf-check ast vars kts expected))
          ((and (list? ast) (member (car ast) '(fscanf))) (xtc:typecheck:fscanf-check ast vars kts expected))
          ((and (list? ast) (member (car ast) '(push_zone))) (xtc:typecheck:push_zone-check ast vars kts expected))
          ((and (list? ast) (member (car ast) '(pop_zone))) (xtc:typecheck:pop_zone-check ast vars kts expected))
          ((and (list? ast) (member (car ast) '(push_new_zone))) (xtc:typecheck:push_new_zone-check ast vars kts expected))
          ((and (list? ast) (member (car ast) '(create_zone))) (xtc:typecheck:create_zone-check ast vars kts expected))
          ;;((and (list? ast) (member (car ast) '(memzone))) (xtc:typecheck:memzone-check ast vars kts expected))
          ((and (list? ast) (member (car ast) '(llvm_callback))) (xtc:typecheck:callback-check ast vars kts expected))
          ((and (list? ast) (member (car ast) '(make-vector))) (xtc:typecheck:make-vector-check ast vars kts expected))
          ((and (list? ast) (member (car ast) '(vector-set!))) (xtc:typecheck:vector-set-check ast vars kts expected))
          ((and (list? ast) (member (car ast) '(vector-ref))) (xtc:typecheck:vector-ref-check ast vars kts expected))
          ((and (list? ast) (member (car ast) '(vector-shuffle))) (xtc:typecheck:vector-shuffle-check ast vars kts expected))
          ((and (list? ast) (member (car ast) '(make-array))) (xtc:typecheck:make-array-check ast vars kts expected))
          ((and (list? ast) (member (car ast) '(array-set!))) (xtc:typecheck:array-set-check ast vars kts expected))
          ((and (list? ast) (member (car ast) '(array-ref))) (xtc:typecheck:array-ref-check ast vars kts expected))
          ((and (list? ast) (member (car ast) '(array-ref-ptr))) (xtc:typecheck:array-ref-ptr-check ast vars kts expected))
          ((and (list? ast) (member (car ast) '(pointer-set!))) (xtc:typecheck:pointer-set-check ast vars kts expected))
          ((and (list? ast) (member (car ast) '(pointer-ref))) (xtc:typecheck:pointer-ref-check ast vars kts expected))
          ((and (list? ast) (member (car ast) '(pointer-ref-ptr))) (xtc:typecheck:pointer-ref-ptr-check ast vars kts expected))
          ((and (list? ast) (member (car ast) '(stack-alloc))) (xtc:typecheck:stack-alloc-check ast vars kts expected))
          ((and (list? ast) (member (car ast) '(heap-alloc))) (xtc:typecheck:heap-alloc-check ast vars kts expected))
          ((and (list? ast) (member (car ast) '(zone-alloc))) (xtc:typecheck:zone-alloc-check ast vars kts expected))
          ((and (list? ast) (member (car ast) '(make-tuple))) (xtc:typecheck:make-tuple-check ast vars kts expected))
          ((and (list? ast) (member (car ast) '(num-of-elts))) (xtc:typecheck:num-of-elts-check ast vars kts expected))
          ((and (list? ast) (member (car ast) '(obj-size))) (xtc:typecheck:obj-size-check ast vars kts expected))
          ((and (list? ast) (member (car ast) '(ref))) (xtc:typecheck:ref-check ast vars kts expected))
          ((and (list? ast) (member (car ast) '(tuple-set!))) (xtc:typecheck:tuple-set-check ast vars kts expected))
          ((and (list? ast) (member (car ast) '(tuple-ref))) (xtc:typecheck:tuple-ref-check ast vars kts expected))
          ((and (list? ast) (member (car ast) '(tuple-ref-ptr))) (xtc:typecheck:tuple-ref-ptr-check ast vars kts expected))
          ((and (list? ast) (member (car ast) '(closure-set!))) (xtc:typecheck:closure-set-check ast vars kts expected))
          ((and (list? ast) (member (car ast) '(closure-ref))) (xtc:typecheck:closure-ref-check ast vars kts expected))
          ((and (list? ast) (member (car ast) '(closure-refcheck))) (xtc:typecheck:closure-refcheck-check ast vars kts expected))
          ((and (list? ast) (member (car ast) '(pref))) (xtc:typecheck:pref-check ast vars kts expected))
          ((and (list? ast) (member (car ast) '(pdref))) (xtc:typecheck:pdref-check ast vars kts expected))
          ((and (list? ast) (member (car ast) '(null?))) (xtc:typecheck:null?-check ast vars kts expected))
          ((and (list? ast) (member (car ast) '(impc_null))) (xtc:typecheck:null-check ast vars kts expected))
          ((and (list? ast) (member (car ast) '(bitcast))) (xtc:typecheck:bitcast-check ast vars kts expected))
          ((and (list? ast) (member (car ast) '(bitconvert))) (xtc:typecheck:bitconvert-check ast vars kts expected))
          ((and (list? ast) (member (car ast) '(void))) (xtc:typecheck:void-check ast vars kts expected))
          ((and (list? ast) (member (car ast) '(fptrcall))) (xtc:typecheck:fptrcall-check ast vars kts expected))
          ((and (list? ast) ;; poly func (specific match)
                (symbol? (car ast))
                expected
                (string-contains? (symbol->string (car ast)) "##") ;"\\$\\$\\$")
                (xtc:typecheck:nativef-poly-exact-check ast vars kts expected))
           ;; (println 'poly-exact: ast 'r: expected)
           expected)
          ((and (list? ast) ;; generic function
                (symbol? (car ast))
                (string-contains? (symbol->string (car ast)) "##") ;"\\$\\$\\$")
                (xtc:cache:genericfunc-exists? (string->symbol (car (string-split-on (symbol->string (car ast)) "##")))
                                             (length (cdr ast))))
           ;; (println 'generic: ast 'r: expected)
           (xtc:typecheck:nativef-generics ast vars kts expected))
          ((and (list? ast) ;; poly func (closest match)
                (symbol? (car ast))
                (string-contains? (symbol->string (car ast)) "##") ;"\\$\\$\\$")
                (xtc:cache:get-polyfunc-candidate-types (car (string-split-on (symbol->string (car ast)) "##"))))
           ;; (println 'poly: ast 'r: expected)
           (let ((reses (xtc:typecheck:nativef-poly-check ast vars kts expected)))
             ;; (println 'polyclosest 'ast: ast reses 'r: expected)
             reses))
          ((and (list? ast) ;; native function
                (symbol? (car ast))
                (or (xtc:cache:nativefunc-exists? (symbol->string (car ast)))
                    (xtc:cache:closure-exists? (symbol->string (car ast)))))
           ;; (println 'native: ast 'r: expected)
           (xtc:typecheck:nativef-check ast vars kts expected))
          ((ast:begin? ast) (xtc:typecheck:begin-check ast vars kts expected))
          ((ast:if? ast) (xtc:typecheck:if-check ast vars kts expected))
          ((ast:set!? ast) (xtc:typecheck:set-check ast vars kts expected))
          ((and (list? ast) (member (car ast) '(ret->))) (xtc:typecheck:ret-check ast vars kts expected))
          ((and (list? ast) (xtc:typecheck:vars-ref vars (car ast))) (xtc:typecheck:closure-call-check ast vars kts expected))
          ((and (list? ast) (list? (car ast))) (xtc:typecheck:closure-in-first-position ast vars kts expected))
          ((and (list? ast) ;; this is here to check against closures as global vars (i.e. not in local environment)
                (symbol? (car ast))
                (or (xtc:cache:closure-exists? (symbol->string (car ast)))
                    (let ((gvar-type (xtc:cache:get-globalvar-type (symbol->string (car ast)))))
                      (and gvar-type (xtc:codegen:closure? gvar-type)))))
           (xtc:typecheck:closure-call-check ast vars kts expected))
          (else
           (xtc:desugar:join (xtc:typecheck:type-check (car ast) vars kts expected)
                         (xtc:typecheck:type-check (cdr ast) vars kts expected)))))) ;; end cond
      (if (vector? result) (tc-type result) result))))


(define xtc:typecheck:find-unresolved-simple-types
  (lambda (union)
    (let ((unresolved (cl:remove #f (map (lambda (x) ;; return the first bad variable that is not a closure
                                           (if (null? (cdr x)) #f
                                               (if (and (list? (cdr x)) ;; check there are multiple choices
                                                        (number? (cadr x))
                                                        (not (member (modulo (cadr x) *xtc:codegen:pointer*)
                                                                     (list *xtc:codegen:tuple* *xtc:codegen:closure* *xtc:codegen:array* *xtc:codegen:vector*))) ;; make sure it's a base type (not closure or tuple)
                                                        (cl:every xtc:codegen:type? (cdr x))) ;; check that it's choices are valid (not null)
                                                   x #f)))
                                         union))))
      (if (null? unresolved) #f
          unresolved))))


(define xtc:typecheck:remove-single-element-lists
  (lambda (l)
    (map (lambda (k)
           ;; (println 'k k)
           (if (list? k)
               (if (= (length k) 1)
                   (car k)
                   (xtc:typecheck:remove-single-element-lists k))
               k))
         l)))






(define *type-check-continuation* '())

(define xtc:typecheck:run-type-check
  (lambda (vars forced-types ast)
    ;; (println '====================================)
    ;; (println 'run-type-check 'ast: ast)
    ;; (println 'forced-types forced-types)
    ;; (println 'vars: vars)
    ;; TASK-059 increment 3 stage 3d: when the constraint path is live, IT
    ;; produces the result --- the old candidate-list traversal and its retry loop
    ;; are bypassed entirely.  Default off until a full shadow-clean build clears
    ;; the flip; until then the old path runs and shadow mode (above) cross-checks.
    (if *xtc:infer:live?*
        (or (xtc:infer:check-function vars forced-types ast)
            ;; a solver conflict: the constraints are unsatisfiable
            (xtc:diagnostics:print-could-not-resolve-type-error (caaadr ast)))
        (let ((typelist (call/cc (lambda (k) (set! *type-check-continuation* k) '()))))
          (if (null? typelist)
              (set! typelist (xtc:typecheck:run-type-check* vars forced-types ast)))
          ;; (println 'unified 'types: typelist)
          (if *xtc:infer:shadow?*
              (xtc:infer:shadow-check vars forced-types ast typelist (caaadr ast)))
          typelist))))

(define *xtc:typecheck:type-check-function-symbol* #f)
(define *xtc:typecheck:type-check-function-symbol-short* #f)

;; run the type checker
;; if we fail to unify completely the first time
;; try some possible substitutions!
(define xtc:typecheck:run-type-check*
  (lambda (vars forced-types ast . cnt)
    (set! *xtc:typecheck:nativef-generics:calls* 0)
    (set! *xtc:typecheck:type-check:calls* 0)
    ;; (println '------------------------------------)
    ;; (println 'run-type-check*: (caaadr ast))
    ;; (println 'forced-types* forced-types)
    ;; (println 'ast: ast)
    ;; (println 'vars*: vars)
    (define *xtc:typecheck:nativef-generics-recurse-test* 0)
    (set! *xtc:typecheck:type-check-function-symbol* (caaadr ast))
    (set! *xtc:typecheck:type-check-function-symbol-short*
          (let ((s (symbol->string *xtc:typecheck:type-check-function-symbol*)))
            (string->symbol
             (car (if (string-contains? s "_poly_")
                      (string-split-on s "_poly_")
                      (string-split-on s "_adhoc_"))))))
    ;; (if (null? cnt) (sys:clear-log-view))
    (let* ((fvars (let ((ht (xtc:typecheck:vars-snapshot vars)))
                    (for-each (lambda (ft)
                                (let ((cell (hashtable-ref ht (car ft))))
                                  (if cell
                                      (xtc:typecheck:uf-set-value! cell (list (cdr ft))))))
                              forced-types)
                    ht))
           ;; (lll (println 'vars1: vars))
           (kts (map (lambda (x) (car x)) forced-types)) ;; just need symbols from forced-types
           ;; fvars gets modified 'in place' during this next
           ;; operation
           (t1 (begin (if (null? cnt) (xtc:typecheck:clear-constraints!)) (clock:clock)))
           (ret (xtc:typecheck:type-check ast fvars kts #f))
           (t2 (clock:clock))
           (u1 (xtc:desugar:unify fvars))
           (u (cl:remove-if (lambda (x)
                              (and (not (xtc:codegen:type? (cdr x)))
                                   (let ((s (symbol->string (car x))))
                                     (or (char=? (string-ref s 0) #\!)
                                         (string-contains? s ":<")
                                         (string-contains? s "{")))))
                            u1))
           (t3 (clock:clock))
           (t (xtc:desugar:unity? u))
           (t4 (clock:clock))
           ;; (lllllll (println (println 'cccccc)))
           (tt (cl:every (lambda (x) x) t))
           (a (if tt #t
                  (xtc:typecheck:find-unresolved-simple-types u))))
                                        ;(println 'fvars: fvars)
                                        ;(println 'types: u)
      (if *xtc:globals:print-unifications* (println 'tirun:> a '-> u))

      ;; (println (caaadr ast) 'type-check: (- t2 t1) 'unify: (- t3 t2) 'unity: (- t4 t3))
      ;; (println (caaadr ast)
      ;;          'num-vars: (length vars)
      ;;          'num-kvar: (length forced-types)
      ;;          'tc-calls: *xtc:typecheck:type-check:calls*
      ;;          'gencalls: *xtc:typecheck:nativef-generics:calls*)

      ;; (println 'tt tt)
      ;; (println 'u u)
      ;; (println '-------------------------------------)

      ;; if we have unified types then return them through continuation
      (if (or tt
              (and (not (null? cnt))
                   (list? (car cnt))
                   (member u (car cnt))))
          (*type-check-continuation* u))

      (cond ((and (not (null? cnt))
                  (eq? #f (car cnt)))
             u)
            ((not a) ;; this run is for generics
             (xtc:typecheck:clear-all-vars fvars)
             (let* ((ret (xtc:typecheck:run-type-check* fvars
                                                  ;; kts for all solved types
                                                  (cl:remove #f (map (lambda (k)
                                                                       (if (xtc:codegen:type? (cdr k)) k #f))
                                                                     u))
                                                  ast (cons u (if (null? cnt) cnt (car cnt))))))
               ret))
            (else ;; I think this whole section might be a waste of time!
             (let ((res (map (lambda (x) ;; call run-type-check for each version of a simple type
                               ;; first clear vars
                               (xtc:typecheck:clear-all-vars fvars)
                               (let* ((newforced (append (cl:remove-if-not (lambda (z) (and (not (list? z)) (pair? z))) u)
                                                         ;; and any simple types that unify on x
                                                         (cl:remove 'failed
                                                                    (map (lambda (k)
                                                                           (if (null? (cl:intersection (list x) (cdr k)))
                                                                               'failed
                                                                               (cons (car k) x)))
                                                                         (xtc:typecheck:find-unresolved-simple-types u)))
                                                         forced-types))
                                      (newkts (cl:remove-if (lambda (x) (and (assoc-strcmp (car x) forced-types)
                                                                     (not (equal? (assoc-strcmp (car x) forced-types) x))))
                                                         newforced)))
                                 (xtc:typecheck:run-type-check* fvars newkts ast #f)))
                             ;; ast (cons u (if (null? cnt) cnt (car cnt)))))
                             (cdr (car a)))))
               ;; then see what versions might be OK?
               (let* ((rr (map (lambda (y)
                                 (cl:remove-if (lambda (x)
                                                 (let ((s (symbol->string (car x))))
                                                   (or (char=? (string-ref s 0) #\!)
                                                       (string-contains? s ":<")
                                                       (string-contains? s "{"))))
                                                 ;; (regex:match? (symbol->string (car x)) "^!" ))
                                               y))
                               res))
                      (r (cl:find-if (lambda (x)
                                       (cl:every (lambda (x) x) (xtc:desugar:unity? x)))
                                     rr)))
                 (if (not r) ;; if no options are any good then :(
                     u
                     r))))))))
                     ;; (xtc:diagnostics:print-could-not-resolve-types
                     ;;  u
                     ;;  ast))
                 ;; (begin r))))))))


;;
;;
;; Other utility code
;;
;;
(define xtc:typecheck:add-types-to-source-atom
  (lambda (symname ast types envvars . prev)
    (if (not (symbol? ast))
        ast
        (let ((ast-str (symbol->string ast)))
          (cond ((and (not (string-contains? ast-str ":"))
                      (xtc:cache:polyfunc-exists? ast-str))
                 (let ((names (xtc:cache:get-polyfunc-candidate-names ast-str)))
                   (if (and names (= (length names) 1))
                       (string->symbol (car names))
                       (xtc:diagnostics:print-compiler-error "Try forcing a type. Ambiguous polymorphic function" ast))))
                ((string-contains? ast-str ":")
                 (let ((p (string-split-on ast-str ":")))
                   (cond ((xtc:cache:polyfunc-exists? (car p))
                          (let* ((pname (car p))
                                 (ptype-str (cadr p))
                                 (ptype (xtc:codegen:get-type-from-pretty-str
                                         (if (xtc:cache:typealias-exists? ptype-str)
                                             (xtc:codegen:pretty-print-type (xtc:cache:get-typealias-type ptype-str))
                                             ptype-str)))
                                 (candidate (xtc:cache:get-polyfunc-candidate pname ptype)))
                            (if candidate
                                candidate
                                (string->symbol (string-append pname "_adhoc_" (cname-encode (xtc:codegen:get-base-type ptype-str)))))))
                         (else
                          (let* ((ptrs (xtc:codegen:get-ptr-depth ast))
                                 (gpoly? (xtc:cache:genericfunc-exists? (string->symbol (car p))))
                                 (apoly? (xtc:cache:polyfunc-exists? (car p)))
                                 (etype (cname-encode (xtc:codegen:get-base-type (cadr p)))))
                            (if gpoly?
                                (let ((pfunc-str (string-append (car p) "_poly_" etype)))
                                  (if (not (xtc:cache:closure-exists? pfunc-str))
                                      (let* ((arity (xtc:codegen:get-arity-from-pretty-closure (cadr p)))
                                             (ptypes (xtc:cache:genericfunc-types (string->symbol (car p)) arity (cadr p)))
                                             (tmp (if (not ptypes)
                                                      (xtc:diagnostics:print-bad-arity-error ast)))
                                             (code (caddr (cadr (xtc:cache:genericfunc-types (string->symbol (car p)) arity (cadr p)))))
                                             (pfunc (string->symbol pfunc-str)))
                                        (if (not (xtc:cache:closure-exists? pfunc-str))
                                            (xtc:cache:register-new-closure pfunc-str
                                                                          '()
                                                                          *xtc:globals:default-zone-size*
                                                                          ""
                                                                          code))
                                        (set! code `(let ((,pfunc ,code)) ,pfunc))
                                        (xtc:driver:run pfunc code *xtc:globals:default-zone-size* #f #f (cons pfunc (string->symbol (cadr p))))
                                        (xtc:cache:register-new-polyfunc (car p)
                                                                       pfunc-str
                                                                       (xtc:codegen:get-type-from-pretty-str (cadr p))
                                                                       "")
                                        (xtc:bind:initialize-closure-with-new-zone pfunc-str
                                                                                  *xtc:globals:default-zone-size*)
                                        pfunc))
                                  (string->symbol pfunc-str))
                                (if apoly?
                                    (string->symbol (string-append (car p) "_adhoc_" etype))
                                    (xtc:diagnostics:print-missing-identifier-error ast 'variable))))))))
                ((and (string-contains? ast-str "##")
                      (assoc-strcmp ast types)
                      (xtc:cache:polyfunc-exists? (xtc:codegen:get-base-type ast-str)))
                 (let* ((nm (string-split-on ast-str "##"))
                        (n1 (car nm))
                        (type (cdr (assoc-strcmp ast types)))
                        (candidate (xtc:cache:get-polyfunc-candidate n1 type)))
                   (if (not candidate)
                       (xtc:diagnostics:print-compiler-error (string-append "Bad type: " (xtc:codegen:pretty-print-type type) " for polymorphic function " (car nm)) ast))
                   candidate))
                ((and (string-contains? ast-str "##")
                      (assoc-strcmp ast types))
                 (let* ((nm (string-split-on ast-str "##"))
                        (n1 (car nm))
                        (type (cdr (assoc-strcmp ast types)))
                        (ptype (xtc:codegen:pretty-print-type type))
                        (cn (cname-encode ptype))
                        (newn (string-append n1 "_poly_" cn)))
                   (if (not (xtc:cache:closure-exists? newn))
                       (let* ((arity (xtc:codegen:get-arity-from-pretty-closure ptype))
                              (ptypes (xtc:cache:genericfunc-types (string->symbol n1) arity ptype))
                              (tmp (if (not ptypes)
                                       (xtc:diagnostics:print-bad-arity-error ast)))
                              (code (caddr (cadr (xtc:cache:genericfunc-types (string->symbol n1) arity ptype))))
                              (pfunc (string->symbol newn)))
                         (if (not (xtc:cache:closure-exists? newn))
                             (xtc:cache:register-new-closure newn
                                                           '()
                                                           *xtc:globals:default-zone-size*
                                                           ""
                                                           code))
                         (set! code `(let ((,pfunc ,code)) ,pfunc))
                         (xtc:driver:run pfunc code *xtc:globals:default-zone-size* #f #f (cons pfunc (string->symbol ptype)))
                         (xtc:cache:register-new-polyfunc n1
                                                        newn
                                                        (xtc:codegen:get-type-from-pretty-str ptype)
                                                        "")
                         (xtc:bind:initialize-closure-with-new-zone newn
                                                                   *xtc:globals:default-zone-size*)
                         pfunc))
                   (string->symbol newn)))
                (else ast))))))



;; add types to source
;; also add clrun for closure application
;; and inject polymorphic functions
(define xtc:typecheck:add-types-to-source
  (lambda (symname ast types envvars . prev)
    ;; (println 'symname: symname)
    ;; (println 'ast: ast)
    ;; (println 'types: types)
    ;; (println 'envvars: envvars 'prev: prev)
    (if (atom? ast) ;; ast
        (apply xtc:typecheck:add-types-to-source-atom symname ast types envvars prev)
        (cond ((member (car ast) '(__make-closure __make-closure-s __make-closure-h __make-closure-z))
               (if *xtc:diagnostics:print-work-names
                   (println '>> 'worker: (string-append (symbol->string symname) "__"
                                                        (number->string (+ 1 (llvm:count))))))
               (list (car ast)
                     (cadr ast)
                     ;; global name
                     (string-append (symbol->string symname) "__" (number->string (llvm:count++)))
                     (if (or (null? prev) ;; this adds return type
                             (null? (cdr (assoc-strcmp (car prev) types))))
                         *xtc:codegen:other*
                         (caddr (assoc-strcmp (car prev) types)))
                     (map (lambda (v) ;; environment types
                            (if (member v envvars)
                                (let ((p (assoc-strcmp v types)))
                                  (cons (string->symbol (string-append (symbol->string (car p)) "__sub"))
                                        (cdr p)))
                                (assoc-strcmp v types)))
                          (cons symname (caddr ast)))
                     (map (lambda (v) ;; argument types
                            (assoc-strcmp v types))
                          (cadddr ast))
                     (xtc:typecheck:add-types-to-source symname (car (cddddr ast)) types (append envvars (caddr ast)))))
              ((equal? (car ast) 'clrun->)
               (if (and (assoc-strcmp (cadr ast) types)
                        (<> (length (cdddr (assoc-strcmp (cadr ast) types)))
                            (length (cddr ast))))
                   (xtc:diagnostics:print-compiler-error "You must provide a full type for this call" (cdr ast)))
               (list* (car ast)
                      (cadr ast)
                      (map (lambda (arg type)
                             ;;(print 'clrunargs-> arg type)
                             (let ((a (xtc:typecheck:add-types-to-source symname arg types envvars ast)))
                               (if (null? type)
                                   (xtc:diagnostics:print-could-not-resolve-type-error
                                    (symbol->string (cadr ast)))
                                   a)))
                           (cddr ast)
                           (cdddr (if (not (assoc-strcmp (cadr ast) types)) ;; if not in local env then get types from global var
                                      (if (xtc:cache:globalvar-exists? (symbol->string (cadr ast)))
                                          (cons (cadr ast) (xtc:cache:get-globalvar-type (symbol->string (cadr ast))))
                                          (cons (cadr ast) (xtc:cache:get-closure-type (symbol->string (cadr ast)))))
                                      (assoc-strcmp (cadr ast) types))))))

              ;; inject (and potential compile) generic functions
              ;; do generic functions before polys
              ((and (symbol? (car ast))
                    (string-contains? (symbol->string (car ast)) "##") ;"\\$\\$\\$")
                    (xtc:cache:genericfunc-exists? (string->symbol (car (string-split-on (symbol->string (car ast)) "##")))
                                                 (length (cdr ast))))
               ;; (println 'types types)
               ;; (println 'gpoly: (car ast))
               ;; (println 'gpoly: (xtc:cache:genericfunc-types (string->symbol (car (string-split-on (symbol->string (car ast)) "##")))))
               ;; (println 'compile 'generic? ast)
               ;; (println 'types types)
               (if (null? (cdr (assoc-strcmp (car ast) types)))
                   (xtc:diagnostics:print-could-not-resolve-generic-type-error types ast))

               (let* ((polyname-str (car (string-split-on (symbol->string (car ast)) "##")))
                      (polyname (string->symbol polyname-str))
                      (type (xtc:codegen:pretty-print-type (cdr (assoc-strcmp (car ast) types))))
                      (cname (cname-encode type))
                      (symp (string-split-on (symbol->string symname) "_poly_"))
                      (symcname (if (null? (cdr symp)) "" (cadr symp)))
                      (recursive? (and (string=? polyname-str (car symp))
                                       (string=? cname symcname)))
                      (arity (xtc:codegen:get-arity-from-pretty-closure type))
                      (code (caddr (cadr (xtc:cache:genericfunc-types polyname arity type))))
                      (exists (if (string=? type "") #f (xtc:cache:get-polyfunc-candidate (symbol->string polyname) (xtc:codegen:get-type-from-pretty-str type)))))
                 (if (or (if exists
                             (if (and (string-contains? (symbol->string exists) "_poly_")
                                      (not *xtc:aot:current-output-port*)
                                      (xtc:cache:genericfunc-src-changed polyname arity))
                                 #f
                                 #t)
                             #f)
                         recursive?)
                     (if recursive?
                         (cons 'clrun-> (cons symname
                                              (map (lambda (jj)
                                                     (xtc:typecheck:add-types-to-source symname jj types envvars ast))
                                                   (cdr ast))))
                         (cons exists
                               (map (lambda (jj)
                                      (xtc:typecheck:add-types-to-source symname jj types envvars ast))
                                    (cdr ast))))
                     (let* ((pfunc-str (string-append polyname-str "_poly_" (cname-encode type)))
                            (pfunc (string->symbol pfunc-str)))
                       (xtc:cache:genericfunc-src-compiled polyname arity)
                       (if (not (xtc:cache:closure-exists? pfunc-str))
                           (xtc:cache:register-new-closure pfunc-str
                                                         '()
                                                         *xtc:globals:default-zone-size*
                                                         ""
                                                         code))
                       (set! code `(let ((,pfunc ,code)) ,pfunc))
                       (xtc:driver:run pfunc code *xtc:globals:default-zone-size* #f #f (cons pfunc (string->symbol type)))
                       (xtc:cache:register-new-polyfunc (symbol->string polyname)
                                                      pfunc-str
                                                      (xtc:codegen:get-type-from-pretty-str type)
                                                      "")
                       (xtc:bind:initialize-closure-with-new-zone pfunc-str
                                                                 *xtc:globals:default-zone-size*)
                       (cons pfunc
                             (map (lambda (jj)
                                    (xtc:typecheck:add-types-to-source symname jj types envvars ast))
                                  (cdr ast)))))))
              ;; inject polymorphic functions
              ((and (symbol? (car ast))
                    (string-contains? (symbol->string (car ast)) "##")) ;"\\$\\$\\$"))
               (let* ((pname (car (string-split-on (symbol->string (car ast)) "##")))
                      (type (cdr (assoc-strcmp (car ast) types)))
                      (polyname (xtc:cache:get-polyfunc-candidate pname type)))
                 (cons polyname
                       (map (lambda (jj)
                              (xtc:typecheck:add-types-to-source symname jj types envvars ast))
                            (cdr ast)))))
              ;; environments
              ((member (car ast) '(__make-env __make-env-zone))
               (list (car ast)
                     (cadr ast)
                     (map (lambda (p)
                            (list (assoc-strcmp (car p) types)
                                  (xtc:typecheck:add-types-to-source symname (cadr p) types envvars (car p))))
                          (caddr ast))
                     (xtc:typecheck:add-types-to-source symname (cadddr ast) types envvars)))
              ((and
                (symbol? (car ast))
                (xtc:cache:globalvar-exists? (symbol->string (car ast)))
                (xtc:codegen:closure? (xtc:cache:get-globalvar-type (symbol->string (car ast)))))
               (xtc:typecheck:add-types-to-source symname (cons 'clrun-> ast) types envvars))
              ((and (assoc-strcmp (car ast) types)
                    (xtc:codegen:closure? (cdr (assoc-strcmp (car ast) types))))
               (xtc:typecheck:add-types-to-source symname (cons 'clrun-> ast) types envvars))
              ((list? ast)
               (map (lambda (x)
                      (xtc:typecheck:add-types-to-source symname x types envvars ast))
                    ast))
              (else (cons (apply xtc:typecheck:add-types-to-source symname (car ast) types envvars)
                          (apply xtc:typecheck:add-types-to-source symname (cdr ast) types envvars)))))))


;; this is uggglly and needs to be redone!!!!!!!
;; adds ret tags
(define xtc:typecheck:mark-returns
  (lambda (ast name in-body? last-pair? blocked?)
    (cond ((atom? ast)
           (if (and in-body? last-pair?)
               (if blocked? ast (list 'ret-> name ast))
               ast))
          ((pair? ast)
           (cond ((equal? (car ast) 'if)
                  (if (or (< (length ast) 3) (> (length ast) 4))
                      (xtc:diagnostics:print-compiler-error "Badly formed conditional" ast))
                  ;; if statement need special syntax adjustments for returns
                  (append (if blocked? (list 'if) (list 'ifret)) (list (cadr ast))
                          (list (xtc:typecheck:mark-returns (caddr ast) name in-body? last-pair? blocked?))
                          (if (not (null? (cdddr ast)))
                              (list (xtc:typecheck:mark-returns (cadddr ast) name in-body? last-pair? blocked?)))))
                 ((member (car ast) *xtc:globals:letslist*)
                  (append (list (car ast))
                          (list (map (lambda (a)
                                       ;; let assigns always block (lambda can override but nothing else)
                                       (list (car a) (xtc:typecheck:mark-returns (cadr a) (car a) #f #f #t)))
                                     (cadr ast)))
                          (xtc:typecheck:mark-returns (cddr ast) name #t #f blocked?)))
                 ((member (car ast) *xtc:globals:lambdaslist*)
                  (append (list (car ast)) (list (cadr ast))
                          ;; lambda always unblocks because lambdas always need a return
                          (xtc:typecheck:mark-returns (cddr ast) name #t #f #f)))
                                        ;((equal? (car ast) 'dotimes)
                                        ; (append '(dotimes) (list (cadr ast)) (xtc:typecheck:mark-returns (cddr ast) name #t #f blocked?)))
                 ((equal? (car ast) 'begin)
                  (if (null? (cdr ast))
                      (xtc:diagnostics:print-no-retval-error ast))
                  (let* ((rev (reverse (cdr ast)))
                         (last (car rev))
                         (rest (reverse (cdr rev)))
                         (newast (append '(begin)
                                         (append (map (lambda (a)
                                                        ;; block everything except ...
                                                        (xtc:typecheck:mark-returns a name in-body? #f #t))
                                                      rest)
                                                 ;; the last one which we let through
                                                 ;; ONLY if it hasn't been blocked higher up!
                                                 (list (xtc:typecheck:mark-returns last name in-body?
                                                                             (if blocked? #f #t)
                                                                             blocked?))))))
                    newast))
                 ((equal? (car ast) 'begin)
                  (append '(begin) (xtc:typecheck:mark-returns (cdr ast) name in-body? #f blocked?)))
                 ((and in-body? last-pair? (not blocked?)) ;; if everything is good add a return!
                  (list 'ret-> name (cons (car ast) (xtc:typecheck:mark-returns (cdr ast) name in-body? #f #t))))
                                        ;(list 'ret-> name ast))
                 (else (cons (xtc:typecheck:mark-returns (car ast) name in-body? #f blocked?)
                             (xtc:typecheck:mark-returns (cdr ast) name in-body? #f blocked?))))))))


;; this is a dodgy flatten :(
(define xtc:typecheck:flatten-1
  (lambda (lst)
    (cond ((null? lst) '())
          ((list? (car lst))
           (append (car lst) (xtc:typecheck:flatten-1 (cdr lst))))
          (else (list lst)))))


(define xtc:typecheck:find-all-vars
  (lambda (full-ast syms)
    (letrec ((f (lambda (ast)
                  (cond ((pair? ast)
                         (cond ((and (symbol? (car ast)) ;; this for generics
                                     (string-contains? (symbol->string (car ast)) "##")
                                     (xtc:cache:genericfunc-exists? (string->symbol (car (string-split-on (symbol->string (car ast)) "##")))
                                                                  (length (cdr ast))))
                                (let* ((ast-str (symbol->string (car ast)))
                                       (ast-parts (string-split-on ast-str (if (string-contains? ast-str "_poly_") "_poly_" "##")))
                                       (gname (string->symbol (car ast-parts)))
                                       (gnum (string->number (cadr ast-parts)))
                                       (arity (length (cdr ast)))
                                       (typestrs (cl:remove-duplicates
                                                  (xtc:codegen:get-pretty-closure-arg-strings
                                                   (symbol->string (car (xtc:cache:genericfunc-types gname arity #f))))))
                                       (types (map (lambda (x) (xtc:codegen:get-type-from-pretty-str x)) typestrs))
                                       (newsyms (cl:remove-duplicates
                                                 (map (lambda (a b)
                                                        ;(println 'finding: a ': b)
                                                        (if (or (xtc:codegen:type? b)
                                                                (not (xtc:codegen:tuple? b)))
                                                            #f
                                                            (if (string-contains? a "{")
                                                                (string->symbol (string-append a "##" (number->string gnum)))
                                                                (if (string-contains? a ":")
                                                                    (string->symbol (string-append a "##" (number->string gnum)))
                                                                    (if (not (null? (xtc:codegen:pretty-print-type b)))
                                                                        (string->symbol (string-append (xtc:codegen:get-base-type a)
                                                                                                       ":"
                                                                                                       (xtc:codegen:pretty-print-type b)
                                                                                                       "##" (number->string gnum)))
                                                                        #f)))))
                                                      typestrs types)))
                                       ;; (ll (println 'new1: newsyms))
                                       ;; (lll (println 'tstrings: typestrs))
                                       ;; (llll  (println 'types: types))
                                       (gvars
                                        (cl:remove-duplicates
                                         (cl:remove-if-not (lambda (x)
                                                             (and (symbol? x) (char=? (string-ref (symbol->string x) 0) #\!)))
                                                           (flatten types))))
                                       (newsyms_gvars (map (lambda (k)
                                                             (string->symbol (string-append (symbol->string k) "##" (number->string gnum))))
                                                           gvars)))
                                  (set! syms (append syms (list (car ast)) (cl:remove #f (cl:remove-duplicates (append newsyms newsyms_gvars)))))
                                  ;; (println 'newsyms: syms)
                                  (f (cdr ast))))
                               ((and (symbol? (car ast)) ;; this for polys
                                     (string-contains? (symbol->string (car ast)) "##")
                                     (xtc:cache:get-polyfunc-candidate-types (car (string-split-on (symbol->string (car ast)) "##")))) ;"\\$\\$\\$")))))
                                ;(println 'poly!var (car ast))
                                (set! syms (append (list (car ast)) syms))
                                (f (cdr ast)))
                               ((member (car ast) '(__make-closure __make-closure-s __make-closure-h __make-closure-z))
                                (if (not (null? (cl:intersection (cadddr ast) syms)))
                                    (xtc:diagnostics:print-shadow-var-error (car (cl:intersection (cadddr ast) syms)) 'as 'a 'shadow 'variable))
                                (set! syms (cl:remove-duplicates (append (caddr ast) (cadddr ast) syms)))
                                (f (car (cddddr ast))))
                               ((member (car ast) '(__make-env __make-env-zone))
                                (set! syms
                                      (append (map (lambda (p)
                                                     (if (member (car p) syms)
                                                         (xtc:diagnostics:print-shadow-var-error (car p)))
                                                     (car p))
                                                   (caddr ast))
                                              syms))
                                (for-each (lambda (p)
                                            (f (cadr p)))
                                          (caddr ast))
                                (f (cadddr ast)))
                               (else (f (car ast))
                                     (f (cdr ast)))))
                        ((atom? ast) '())))))
      (f full-ast)
      syms)))



(define xtc:typecheck:block:check-for-free-syms
  (lambda (ast esyms)
                                        ;(print 'check: 'ast: ast 'esyms: esyms)
    (cl:remove-duplicates (let loop ((lst ast))
                            (cond ((pair? lst)
                                   (append (loop (car lst))
                                           (loop (cdr lst))))
                                  ((atom? lst)
                                   (if (member lst esyms)
                                       (list lst)
                                       '())))))))

;;
;; adds make-closure and make-env tags
;;

(define xtc:typecheck:allocate-var?
  (lambda (ast)
    (cond ((null? ast) 0)
          ((member ast '(lambda lambdaz)) 3)
          ((eq? ast 'lambdah) 1)
          ((eq? ast 'lambdas) 2)
          ((pair? ast)
           (let ((a (xtc:typecheck:allocate-var? (car ast)))
                 (b (xtc:typecheck:allocate-var? (cdr ast))))
             (if (> a b) a b)))
          (else 0))))

;; adds make-closure and make-env tags
(define xtc:typecheck:closure:convert
  (lambda (ast esyms)
    (cond ((pair? ast)
           (if (member (car ast) *xtc:globals:lambdaslist*)
               (let (;(env (xtc:typecheck:block:check-for-free-syms ast esyms))
                     (allocate-mem-for-vars? (xtc:typecheck:allocate-var? (cdr ast))))
                 (list (cond ((eq? (car ast) 'lambdah) '__make-closure-h)
                             ((eq? (car ast) 'lambdas) '__make-closure-s)
                             (else '__make-closure-z))
                       allocate-mem-for-vars?
                       ;; name of compiled function is always last
                       ;; so we can remove it by dropping it off the end
                       (cdr (reverse (cl:remove-duplicates esyms))) ;env
                       (cadr ast)
                       (xtc:typecheck:closure:convert (caddr ast) (append (cadr ast) esyms))))
               (if (member (car ast) *xtc:globals:letslist*)
                   (let* ((allocate-mem-for-vars? (xtc:typecheck:allocate-var? ast))
                          (bindings (map (lambda (binding)
                                           (car binding))
                                         (cadr ast))))
                                        ;(free-syms (xtc:typecheck:block:check-for-free-syms (cddr ast) (append bindings esyms))))
                     (cons '__make-env
                           (cons allocate-mem-for-vars?
                                 (list (xtc:typecheck:closure:convert (cadr ast) (append bindings esyms))
                                       (xtc:typecheck:closure:convert (caddr ast) (append bindings esyms))))))
                   (cons (xtc:typecheck:closure:convert (car ast) esyms)
                         (xtc:typecheck:closure:convert (cdr ast) esyms)))))
          ((atom? ast) ast))))



;; expects t1 (i.e. original untransformed code)
(define xtc:typecheck:get-closure-arg-symbols
  (lambda (closure-sym ast)
                                        ;(print 'ast: ast)
    (cond ((null? ast) '())
          ((atom? ast) '())
          ((vector? ast) '())
          ((and (pair? ast)
                (eq? (car ast) closure-sym))
           (if (and (not (null? (cdr ast)))
                    (list? (cadr ast))
                    (member (caadr ast) *xtc:globals:lambdaslist*))
               (cadr (cadr ast))
               '()))
          (else (append (xtc:typecheck:get-closure-arg-symbols closure-sym (car ast))
                        (xtc:typecheck:get-closure-arg-symbols closure-sym (cdr ast)))))))


(define xtc:typecheck:spec-new-type?
  (lambda (x)
    ;; (println 'newspec? x)
    (if (and (string? x)
             (string-contains? x "_poly_")
             (not (xtc:cache:namedtype-exists? x)))
        (let* ((p (string-split-on x "_poly_"))
               (basename (substring (xtc:codegen:get-base-type x) 1
                                    (string-length (xtc:codegen:get-base-type x))))
               (name (substring (car p) 1 (string-length (car p))))
               (ptrd (xtc:codegen:get-ptr-depth (cadr p)))
               (t1 (cname-decode (xtc:codegen:get-base-type (cadr p))))
               (t2 (xtc:codegen:get-pretty-tuple-arg-strings t1))
               ;; (gt (xtc:cache:get-generictype-candidate-types name))
               (t3 (xtc:desugar:maximize-generic-type
                    (apply string-append name "{" (substring t1 1 (- (string-length t1) 1)) "}"
                           (make-list ptrd "*"))))
               (t3b (xtc:codegen:get-pretty-tuple-arg-strings (cadr (xtc:desugar:split-namedtype t3))))
               (t3c (cons 14 (map (lambda (x)
                                    (if (string? (xtc:codegen:get-type-from-pretty-str x))
                                        (xtc:codegen:get-type-from-pretty-str x)
                                        (if (regex:match? x (string-append "^" name "\\**"))
                                            (xtc:codegen:add-ptr-depth (string-append "%" basename)
                                                               (xtc:codegen:get-ptr-depth x))
                                            (xtc:codegen:get-type-from-pretty-str x))))
                                  t3b)))
               (t3d (xtc:codegen:get-type-str t3c)))
          ;; (println 'newspec name basename t3c t3d)
          ;; (println 'compile:
          (if (llvm:compile-ir (string-append "%" basename " = type " t3d))
              (begin
                (xtc:cache:register-new-polytype name
                                               basename
                                               t3c
                                               "")
                #t)
              #f))
        #f)))


(define xtc:typecheck:handle-forced-types
  (lambda (t1 . args)
    (if (null? args) '()
        (let* ((forced-types (map (lambda (t)
                                    (map (lambda (tt)
                                           ;; (println 'tt: tt)
                                           (if (not (or (symbol? tt)
                                                        (list? tt)))
                                               (xtc:diagnostics:print-bad-type-error t "bad fixed type")))
                                         (if (list? t) (cdr t) (list (cdr t))))
                                    (cons (car t) (xtc:codegen:convert-from-pretty-types (cdr t))))
                                  args))
               ;; (llllll (println 'ft forced-types))
               (forced-types-updated (apply append (list)
                                            (map (lambda (t)
                                                   ;; first off we might be introducing a new spec'd type here!
                                                   (if (string? (cdr t))
                                                      (xtc:typecheck:spec-new-type? (cdr t)))
                                                   ;; on with the show!
                                                   (if (and (xtc:codegen:closure? (cdr t))
                                                            (not (null? (xtc:typecheck:get-closure-arg-symbols (car t) t1))))
                                                       (if (<> (length (cdddr t))
                                                               (length (xtc:typecheck:get-closure-arg-symbols (car t) t1)))
                                                           (xtc:diagnostics:print-bad-type-error (cdr t) (car t))
                                                           (append (map (lambda (sym type)
                                                                          (cons sym type))
                                                                        (xtc:typecheck:get-closure-arg-symbols (car t) t1)
                                                                        (cdddr t))
                                                                   (list t)))
                                                       (list t)))
                                                 forced-types)))
               ;; (lllllllllllll (println 'typesupdated forced-types-updated))
               (checked-for-duplicates (let loop ((types forced-types-updated))
                                         (if (null? types) (cl:remove-duplicates forced-types-updated)
                                             (if (and (assoc-strcmp (caar types) (cdr types))
                                                      (not (equal? (cdr (assoc-strcmp (caar types) (cdr types)))
                                                                   (cdr (car types)))))
                                                 (xtc:diagnostics:print-type-mismatch-error
                                                  (cdar types)
                                                  (cdr (assoc-strcmp (caar types) (cdr types)))
                                                  (caar types))
                                                 (loop (cdr types))))))
               (fullyqualified (cl:remove-if-not (lambda (t) (xtc:codegen:type? (cdr t))) checked-for-duplicates)))
          ;; return fully qualified types
          fullyqualified))))





(define xtc:typecheck:get-closure-names
  (lambda (ast . args)
    (let ((blst '()))
      (let loop ((alst ast))
        (cond ((null? alst) '())
              ((atom? alst) '())
              ((pair? alst)
               (if (member (car alst) '(__make-closure __make-closure-h __make-closure-z __make-closure-s))
                   (set! blst (cons (caddr alst) blst)))
               (loop (car alst))
               (loop (cdr alst)))))
      blst)))


(define xtc:typecheck:numeric-cast-operator
  (lambda (a b)
    (let* ((lowest (if (< a b) a b))
           (highest (if (= a lowest) b a))
           (caststr (string-append (if (xtc:codegen:floating-point? highest)
                                       (if (= highest *xtc:codegen:fp64*) "d" "f")
                                       (xtc:codegen:pretty-print-type highest))
                                   "to"
                                   (if (xtc:codegen:floating-point? lowest)
                                       (if (= lowest *xtc:codegen:fp64*) "d" "f")
                                       (xtc:codegen:pretty-print-type lowest)))))
      caststr)))


;; an optional compiler stage to support some basic type coercions
;; particular math coercions of forced types
(define xtc:typecheck:coercion-run
  (lambda (ast forced-types)
    ;; (println 'ast: ast)
    (if (pair? ast)
        (cond ((member (car ast) '(< > * / = + - <>))
               (let ((a (assoc-strcmp (cadr ast) forced-types))
                     (b (assoc-strcmp (caddr ast) forced-types)))
                 (if (and (and a b)
                          (not (xtc:codegen:tuple? (cdr a)))
                          (not (xtc:codegen:vector? (cdr a)))
                          (<> (cdr a) (cdr b)))
                     (let ((ret (string->symbol (xtc:typecheck:numeric-cast-operator (cdr a) (cdr b)))))
                       ;; (println '> (cdr a) (cdr b))
                       (if (> (cdr a) (cdr b))
                           `(,(car ast) (,ret ,(cadr ast)) ,(caddr ast))
                           `(,(car ast) ,(cadr ast) (,ret ,(caddr ast)))))
                     (if (and a (number? (caddr ast)))
                         (if (and (xtc:codegen:floating-point? (cdr a))
                                  (integer? (caddr ast)))
                             `(,(car ast) ,(cadr ast) ,(integer->real (caddr ast)))
                             ast)
                         (if (and b (number? (cadr ast)))
                             (if (and (xtc:codegen:floating-point? (cdr b))
                                      (integer? (cadr ast)))
                                 `(,(car ast) ,(integer->real (cadr ast)) ,(caddr ast))
                                 ast)
                             ast)))))
              (else (cons (xtc:typecheck:coercion-run (car ast) forced-types)
                          (xtc:typecheck:coercion-run (cdr ast) forced-types))))
        ast)))


;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(define xtc:typecheck:scm_rt_check_string
  (lambda (n closure-name)
    (let* ((os (make-string 0))
           (n1 (substring n 1 (string-length n)))
           (name-str (xtc:codegen:make-const-string (string-append closure-name " Scheme wrapper error: check the arg arity and types\n")))
           (name (xtc:codegen:ssa-temp)))
      (emit n "_bool = icmp ne i32 " n "_rt_check, 0\n" os)
      (emit "br i1 " n "_bool, label " n "_true, label " n "_false\n" os)
      (emit "\n" n1 "_true:\n" os)
      (emit "br label " n "_continue\n" os)
      (emit "\n" n1 "_false:\n" os)
      (emit name-str os)
      (emit "call i32 (i8*, ...) @printf(i8* " (car name) ")\n" os)
      (emit n "_errret = call ccc i8* @mk_i64(i8* %_sc, i64 0)\n" os)
      (emit "ret i8* " n "_errret\n" os)
      (emit "\n" n1 "_continue:\n" os)
      ;;(emit n " = call ccc double @r64value(i8* " n "_val)\n" os)
      (xtc:codegen:strip-space os))))

