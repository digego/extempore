            (xtc:codegen:queue-ir-for-compilation getter-ir))
        (if *xtc:globals:print*
            (println '--------------------------------compiling 'stubs----------------------------------->))
        (if *xtc:globals:print* (print-full-nq stub-ir))
        (if *xtc:globals:print* (print-full-nq native-ir))
        (if *xtc:globals:print* (print-full-nq scheme-stub-ir))
        (if (and *xtc:globals:compile* compile-stub?)
            (begin (xtc:codegen:queue-ir-for-compilation stub-ir)
                   (xtc:codegen:queue-ir-for-compilation native-ir)
                   (if (and scheme-stub-valid? *xtc:globals:scheme-stubs*)
                       (xtc:codegen:queue-ir-for-compilation scheme-stub-ir) #t)))
        (if *xtc:globals:print*
            (println '----------------------------compiling 'callback----------------------------------->))
        (if *xtc:globals:print* (print-full-nq callback-ir))
        (if (and *xtc:globals:compile* compile-stub?)
            (xtc:codegen:queue-ir-for-compilation callback-ir))
        (if (not (xtc:aot:currently-compiling?))
            (if (not (xtc:codegen:flush-jit-compilation-queue))
                (xtc:diagnostics:print-compiler-error "could not compile helper functions" symname)))
        (if *xtc:globals:compile*
            ;; make sure the (now resolved) function types hit the
            ;; closure/nativefunc cache
            (let ((closure-type-list (xtc:codegen:get-type-from-str closure-type)))
              (if (and (xtc:cache:closure-exists? symname-string)
                       (xtc:aot:currently-compiling?))
                  (if (not (equal? closure-type-list (xtc:cache:get-closure-type symname-string)))
                      (xtc:diagnostics:print-no-redefinitions-error symname
                                                                  (xtc:cache:get-closure-type symname-string)
                                                                  closure-type-list))
                  (begin
                    (if (and *xtc:globals:implicit-adhoc-compiles*
                             (not (regex:match? adhoc-poly-name-string "(_poly_|_adhoc_)")))
                        (begin
                          (xtc:cache:update-closure-name adhoc-poly-name-string symname-string)
                          (xtc:cache:set-closure-type symname-string closure-type-list)
                          (xtc:cache:set-closure-body symname-string code)
                          ;; add to the AOT-header if we're precompiling
                          (xtc:aot:insert-closure-binding-details symname-string
                                                                   closure-type-list
                                                                   (xtc:cache:get-closure-zone-size symname-string)
                                                                   (xtc:cache:get-closure-docstring symname-string)
                                                                   (xtc:cache:get-closure-body symname-string))
                          ;; Clear old polyfunc candidates of same type before adding new one
                          ;; This prevents accumulation of candidates that causes "ambiguous wrapper" errors
                          (let ((pfdata (hashtable-ref *xtc:cache:polyfunc-cache* adhoc-poly-name-string)))
                            (if pfdata
                                (vector-set! pfdata 0
                                             (cl:remove-if (lambda (x) (equal? (vector-ref x 1) closure-type-list))
                                                           (vector-ref pfdata 0)))))
                          (eval `(bind-poly ,adhoc-poly-name ,symname) (interaction-environment)))
                        (begin
                          (xtc:cache:set-closure-type symname-string closure-type-list)
                          ;; add to the AOT-header if we're precompiling
                          (xtc:aot:insert-closure-binding-details symname-string
                                                                   closure-type-list
                                                                   (xtc:cache:get-closure-zone-size symname-string)
                                                                   (xtc:cache:get-closure-docstring symname-string)
                                                                   (xtc:cache:get-closure-body symname-string))))))
              (cond ((regex:match? symname-string "_poly_")
                     ;; (println 'spec: symname-string)
                     (xtc:diagnostics:print-bind-func-details-to-log
                      "Spec'zed:"
                      (string->symbol (car (regex:split symname-string "_poly_")))
                      (xtc:codegen:pretty-print-type closure-type)
                      zone-size))
                    ((regex:match? symname-string "_adhoc_")
                     (xtc:diagnostics:print-bind-func-details-to-log
                      "Compiled:"
                      (string->symbol (car (regex:split symname-string "_adhoc_")))
                      (xtc:codegen:pretty-print-type closure-type)
                      zone-size))
                    (else
                     (xtc:diagnostics:print-bind-func-details-to-log
                      "Compiled:"
                      symname
                      (xtc:codegen:pretty-print-type closure-type)
                      zone-size)))))
        symname-string)))))

(define-macro (xtm-closure-doc name)
  `(let ((docstring (xtc:cache:get-closure-docstring ,name))
         (types (xtc:cache:get-closure-type ,name))
         (form (xtc:cache:get-closure-body ,name)))
     (if docstring
         (list (cdr docstring) (cdr types) (cdr form))
         (if types
             (list '() (cdr types) (cdr form))
             (if form
                 (list '() '() (cdr form))
                 #f)))))

(define-macro (define-static symname . args)
  (let ((types (cdr (reverse args)))
        (expr (car (reverse args)))
        (aot_sexpr '()))
    (if (regex:match? (symbol->string symname) ":")
        (let ((sres (regex:type-split (symbol->string symname) ":")))
          (set! symname (string->symbol (car sres)))
          (set! types (cons (cons symname (string->symbol (cadr sres))) types))))
    ;; (print-full symname 'types: types 'e: expr 'args: args)
    `(let* ((newname (xtc:driver:run ',symname
                                  '(let ((,symname ,expr)) ,symname)
                                  0
                                  #f
                                  #t
                                  ,@(if (null? types)
                                        '()
                                        (map (lambda (k) (list 'quote k)) types)))))
        newname)))

(define-macro (bind-static . args)
  (if (string? (cadr args))
      (if (not (equal? (caaddr args) 'lambda))
        (xtc:diagnostics:print-compiler-error "static functions cannot be closures!"))
      (if (not (equal? (caadr args) 'lambda))
        (xtc:diagnostics:print-compiler-error "static functions cannot be closures!")))
  ;; if aot and func already exists then bomb out
  (if (and (output-port? *xtc:aot:current-output-port*)
           (xtc:cache:closure-exists? (symbol->string (car args))))
      (begin ;; (xtc:aot:insert-sexpr `(println 'Warning: ',(car args) 'is 'overriden)) ;; insert warning into aot file
             #t)
      ;; if doc-string exists!
      (let ((func-name (car (regex:type-split (symbol->string (car args)) ":")))
            (zone-size (if (number? (cadr args)) (cadr args) *xtc:globals:default-zone-size*))
            (poly (if (boolean? (cadr args)) (cadr args) #t))
            (docstring (if (string? (cadr args))
                           (cadr args)
                           (if (and (not (null? (cddr args))) (string? (caddr args)))
                               (caddr args)
                               "")))
            ;; closure body is always in last position, preceeded by zone
            ;; size and/or docstring
            (closure-body (car (reverse args))))
        (if (member func-name *xtc:globals:reserved-keywords*)
            (begin (println "ERROR: " func-name " is a reserved keyword") (error "")))
        ;; strip docstring
        (set! args (cl:remove-if string? args))
        ;; strip poly
        (set! args (cl:remove-if boolean? args))
        (if (xtc:cache:polyfunc-exists? (car args))
            (xtc:diagnostics:print-already-bound-error (car args) " static function"))
        ;; (if (xtc:cache:genericfunc-exists? (car args))
        ;;     (xtc:diagnostics:print-already-bound-error (car args) "generic closure"))
        (if (regex:match? (symbol->string (car args)) ":")
            (let* ((res (regex:type-split (symbol->string (car args)) ":"))
                   (name (car res))
                   (type1 (cadr res))
                   (type (if (char=? (string-ref type1 0) #\[)
                             (if (= (xtc:codegen:get-ptr-depth type1) 1)
                                 type1
                                 (xtc:diagnostics:print-bad-type-error type1 "must be a closure pointer"))
                             (if (xtc:cache:typealias-exists? type1)
                                 (xtc:cache:get-typealias-type-pretty type1)
                                 (xtc:diagnostics:print-bad-type-error type1 "Bad closure type for bind-static"))))
                   (ags (xtc:codegen:get-pretty-closure-arg-strings type))
                   ;; expand all non-explict generic types
                   ;; i.e. expand list* into list:<!a,list*>*
                   (expand-polys (map (lambda (k)
                                        (if (xtc:cache:get-generictype-candidate-types (xtc:codegen:get-base-type k))
                                            (xtc:codegen:pointer++
                                             (string-append (xtc:codegen:get-base-type k) ":"
                                                            (symbol->string (xtc:cache:get-generictype-candidate-types (xtc:codegen:get-base-type k))))
                                             (xtc:codegen:get-ptr-depth k))
                                            k))
                                      ags))
                   (newtype (string-append "[" (string-join expand-polys ",") "]*"))
                   (newnametype (string->symbol (string-append name ":" newtype))))
              ;; (println 'oldargs: args)
              ;; (println 'newargs: (cons newnametype (cdr args)))
              (if (xtc:desugar:bang-type? newtype)
                  (begin
                    (xtc:diagnostics:print-compiler-error "static functions cannot be generic!"))
                  (begin
                    (if (xtc:cache:closure-or-nativefunc-exists? func-name)
                        (xtc:diagnostics:print-compiler-error "static functions cannot be redefined!")
                        (xtc:cache:register-new-closure func-name '() zone-size docstring closure-body))
                    `(eval '(define-static ,(car args) ,@(cdr args)) (interaction-environment)))))
            (begin
              (if ;; (xtc:cache:closure-exists? func-name)
                  (xtc:cache:closure-or-nativefunc-exists? func-name)
                  (xtc:diagnostics:print-compiler-error "static functions cannot be redefined!")
                  (xtc:cache:register-new-closure func-name '() zone-size docstring closure-body))
              `(eval '(define-static ,(car args) ,@(cdr args)) (interaction-environment)))))))

(define-macro (definec symname poly . args)
  (let ((zone-size *xtc:globals:default-zone-size*))
    (if (number? (car args))
        (begin (set! zone-size (car args))
               (set! args (cdr args))))
    (let ((types (cdr (reverse args)))
          (expr (car (reverse args)))
          (aot_sexpr '()))
      (if (regex:match? (symbol->string symname) ":")
          (let ((sres (regex:type-split (symbol->string symname) ":")))
            (set! symname (string->symbol (car sres)))
            (set! types (cons (cons symname (string->symbol (cadr sres))) types))))
      (let ((base-symname-str (symbol->string symname)))
        ;; (print-full symname 'types: types 'e: expr 'args: args)
        `(let* ((newname (xtc:driver:run ',symname
                                      '(let ((,symname ,expr)) ,symname)
                                      ,zone-size
                                      ,poly
                                      #f
                                      ,@(if (null? types)
                                            '()
                                            (map (lambda (k) (list 'quote k)) types)))))
           (xtc:bind:initialize-closure-with-new-zone newname *xtc:globals:default-zone-size*)
           (xtc:bind:create-scheme-wrapper newname))))))

(define-macro (bind-closure . args)
  ;; if aot and func already exists then bomb out
  (if (and (output-port? *xtc:aot:current-output-port*)
           (xtc:cache:closure-exists? (symbol->string (car args))))
      (begin ;; (xtc:aot:insert-sexpr `(println 'Warning: ',(car args) 'is 'overriden)) ;; insert warning into aot file
             #t)
      ;; if doc-string exists!
      (let ((func-name (car (regex:type-split (symbol->string (car args)) ":")))
            (zone-size (if (number? (cadr args)) (cadr args) *xtc:globals:default-zone-size*))
            (poly (if (boolean? (cadr args)) (cadr args) #t))
            (docstring (if (string? (cadr args))
                           (cadr args)
                           (if (and (not (null? (cddr args))) (string? (caddr args)))
                               (caddr args)
                               "")))
            ;; closure body is always in last position, preceeded by zone
            ;; size and/or docstring
            (closure-body (car (reverse args))))
        (if (member func-name *xtc:globals:reserved-keywords*)
          (begin (println "ERROR: " func-name " is a reserved keyword") (error "")))
        ;; strip docstring
        (set! args (cl:remove-if string? args))
        ;; strip poly
        (set! args (cl:remove-if boolean? args))
        ;; (if (xtc:cache:polyfunc-exists? (car args))
        ;;     (xtc:diagnostics:print-already-bound-error (car args) "polymorphic closure"))
        ;; (if (xtc:cache:genericfunc-exists? (car args))
        ;;     (xtc:diagnostics:print-already-bound-error (car args) "generic closure"))
        (if (regex:match? (symbol->string (car args)) ":")
            (let* ((res (regex:type-split (symbol->string (car args)) ":"))
                   (name (car res))
                   (type1 (cadr res))
                   (type (if (char=? (string-ref type1 0) #\[)
                             (if (= (xtc:codegen:get-ptr-depth type1) 1)
                                 type1
                                 (xtc:diagnostics:print-bad-type-error type1 "must be a closure pointer"))
                             (if (xtc:cache:typealias-exists? type1)
                                 (xtc:cache:get-typealias-type-pretty type1)
                                 (xtc:diagnostics:print-bad-type-error type1 "Bad closure type for bind-func"))))
                   (ags (xtc:codegen:get-pretty-closure-arg-strings type))
                   ;; expand all non-explict generic types
                   ;; i.e. expand list* into list:<!a,list*>*
                   (expand-polys (map (lambda (k)
                                        (if (xtc:cache:get-generictype-candidate-types (xtc:codegen:get-base-type k))
                                            (xtc:codegen:pointer++
                                             (string-append (xtc:codegen:get-base-type k) ":"
                                                            (symbol->string (xtc:cache:get-generictype-candidate-types (xtc:codegen:get-base-type k))))
                                             (xtc:codegen:get-ptr-depth k))
                                            k))
                                      ags))
                   (newtype (string-append "[" (string-join expand-polys ",") "]*"))
                   (newnametype (string->symbol (string-append name ":" newtype))))
              ;; (println 'oldargs: args)
              ;; (println 'newargs: (cons newnametype (cdr args)))
              (if (xtc:desugar:bang-type? newtype)
                  (begin
                    (xtc:aot:insert-generic-func (cons 'bind-func (cons newnametype (cdr args))))
                    (xtc:cache:register-new-genericfunc (cons 'bind-func (cons newnametype (cdr args))))
                    ;;(xtc:cache:register-new-genericfunc (cons 'bind-func args))
                    `(xtc:diagnostics:print-binding-details-to-log "GenrFunc:" ,(car res) ,(cadr res)))
                  (begin
                    (if (xtc:cache:closure-exists? func-name)
                        (begin
                          (xtc:cache:set-closure-docstring func-name docstring)
                          (xtc:cache:set-closure-body func-name closure-body))
                        (xtc:cache:register-new-closure func-name '() zone-size docstring closure-body))
                    `(eval '(definec ,(car args) ,poly ,@(cdr args)) (interaction-environment)))))
            (begin
              (if (xtc:cache:closure-exists? func-name)
                  (begin
                    (xtc:cache:set-closure-docstring func-name docstring)
                    (xtc:cache:set-closure-body func-name closure-body))
                  (xtc:cache:register-new-closure func-name '() zone-size docstring closure-body))
              `(eval '(definec ,(car args) ,poly ,@(cdr args)) (interaction-environment)))))))

(define-macro (bind-func . args)
  (if (< (length args) 2)
      (xtc:diagnostics:print-compiler-error "Poorly formed bind-func expression"))
  (if (and (= (length args) 2) (not (symbol? (car args))) (not (or (string? (cadr args)) (list? (cadr args)))))
      (xtc:diagnostics:print-compiler-error "Poorly formed bind-func expression"))
  (if (and (= (length args) 3)
           (not (symbol? (car args)))
           (not (symbol? (cadr args)))
           (not (or (string? (caddr args))
                    (list (caddr args)))))
      (xtc:diagnostics:print-compiler-error "Poorly formed bind-func expression"))
  (if (equal? (car args) 'static)
      `(bind-static ,@(cdr args))
      `(bind-closure ,@args)))


(xtc:cache:register-new-builtin
 "bind-func"
 ""
 "compile an xtlang closure"
 '(closure-name optional-zone-size optional-docstring closure-body))

;; bind-func-ipc is for passing an already compiled (and setter'd)
;; native function across to a non-primary process
(define bind-func-ipc
  (lambda (symname)
    (let ((zone-size *xtc:globals:default-zone-size*))
      (eval
       `(define ,symname
          (xtc:bind:create-scheme-wrapper (symbol->string ',symname)))
       (interaction-environment)))))

(define ipc:bind-func
  (lambda (procname symname)
    (if (regex:match? (symbol->string symname) "_adhoc_")
        (ipc:call procname 'bind-func-ipc symname)
        (let* ((polyname (symbol->string symname))
               (polytypes (xtc:cache:get-polyfunc-candidate-list polyname)))
          (if (and (list? polytypes)
                   (= (length polytypes) 1))
              (begin (ipc:call procname 'bind-func-ipc
                               (string->symbol (vector-ref (car polytypes) 0)))
                     (ipc:define procname symname (eval symname)))
              (log-error "Not a monomorphic xtlang function:" symname))))))

(define ipc:load
  (lambda (process-name file)
    (ipc:call process-name 'sys:load file)))

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(define-macro (bind-alias symbol type . docstring)
  `(begin (xtc:cache:register-new-typealias
           ,(symbol->string symbol)
           ',(xtc:codegen:get-type-from-pretty-str (symbol->string type))
           ,(if (null? docstring) "" (car docstring)))
          (xtc:diagnostics:print-binding-details-to-log
           "SetAlias:"
           ',symbol
           ;;(print ',type)
           (begin
             (set! *xtc:codegen:get-type-callback-off* #t) ;; don't wait, do it immediately
             (let ((r (xtc:codegen:pretty-print-type ,(symbol->string symbol))))
               (set! *xtc:codegen:get-type-callback-off* #f)
               r))
           )))

(xtc:cache:register-new-builtin
 "bind-alias"
 ""
 "bind an xtlang type alias"
 '(alias-name alias-target optional-docstring))

(define xtc:bind:word-upcase
  (lambda (w)
    (let* ((n (string->list w))
           (u (char-upcase (car n)))
           (n1 (list->string (cons u (cdr n)))))
      n1)))

(define xtc:bind:word-downcase
  (lambda (w)
    (let* ((n (string->list w))
           (u (char-downcase (car n)))
           (n1 (list->string (cons u (cdr n)))))
      n1)))

;; #316: a tuple field that is a pointer to a named type is normally deep
;; copied/freed/zcopied via that type's hcopy/hfree/zcopy poly. Opaque runtime
;; pointers such as mzone* have no such poly candidate, so emitting the deep call
;; would reference a symbol that doesn't exist (a link-time "cannot find symbol"
;; error). Detect that case so the generator can fall back to the shallow
;; handling it already uses for primitive-pointer fields (i.e. share the
;; pointer). `field-type' is the field's "%Name*" pretty type; `subject-index'
;; is the position of the operated-on type in a candidate's closure-type list
;; (1 = return type for hcopy/zcopy, 2 = first arg for hfree, whose return is
;; void). A recursive self-reference always has the function --- it is the very
;; one being defined.
(define xtc:bind:tuple-field-deep-op?
  (lambda (field-type namestr polyname subject-index)
    (let ((t (substring field-type 1 (- (string-length field-type) 1))))
      (or (string=? namestr t)
          (let ((cands (xtc:cache:get-polyfunc-candidate-types polyname)))
            (if (and cands
                     (cl:find-if
                      (lambda (ct)
                        (and (list? ct)
                             (> (length ct) subject-index)
                             (string? (list-ref ct subject-index))
                             (string=? (list-ref ct subject-index) field-type)))
                      cands))
                #t #f))))))

(define xtc:bind:compile-type-dataconstructors
  (lambda (name type generic printer? copy? constructor?)
    (if (or (not (string? type)) ;; if not already a pretty type
            (regex:match? type "^\\s*{"))
        (set! type (xtc:codegen:pretty-print-type type)))
    ;; (println 'DataConstructor: 'name: name 'type type 'gen generic 'print: printer? 'const: constructor?)
    ;; (println 'xtc:bind:compile-type-dataconstructors name type generic)
    (let* ((tsplit (car (regex:type-split (symbol->string name) "_poly_")))
           (a (map (lambda (x)
                     (if (and (string=? tsplit (xtc:codegen:get-base-type x))
                              (= 1 (xtc:codegen:get-ptr-depth x)))
                         (string-append (symbol->string name) "*")
                         x))
                   (xtc:codegen:get-pretty-tuple-arg-strings type)))
           (arglst1 (make-list-with-proc (length a) (lambda (i) (string->symbol (string-append "arg_" (atom->string i))))))
           (arglst2 (range (length a)))
           (namestr (symbol->string name))
           ;;(namestrup (xtc:bind:word-upcase (symbol->string name)))
           ;;(namestrdown (xtc:bind:word-downcase (symbol->string name)))
           (ctype (string-append "["
                                 (if generic
                                     ;(apply string-append namestr ":" type "*"
                                     (apply string-append namestr
                                            "{"
                                            ;; #315: the type parameters are the
                                            ;; template's free type variables by
                                            ;; identity (depth-independent), so the
                                            ;; constructor returns Box{!a}*, not
                                            ;; Box{!a*}*.  Routed through the
                                            ;; canonical core (free-vars) rather
                                            ;; than gathering bang symbols and
                                            ;; stripping their stars by hand.
                                            (string-join
                                             (xtc:type:pretty-type-params type)
                                             ",")
                                            "}*"

                                            (map (lambda (x)
                                                   (string-append
                                                    ","
                                                    (if (regex:match? x (string-append namestr "([{<:*)|$"))
                                                        (regex:replace x
                                                                       (string-append namestr "([*]*)")
                                                                       (string-append namestr ":" type "$1"))
                                                        x)))
                                                 a))
                                     (apply string-append (symbol->string name) "*"
                                            (map (lambda (x) (string-append "," x)) a)))
                                 "]*"))
           (argslist (map (lambda (a b) b) a arglst1))
           (hcopy_body (if generic #f
                           (map (lambda (a b c)
                                  (set! a (xtc:codegen:get-type-from-pretty-str a))
                                  (if (and (xtc:codegen:tuple? a)
                                           (string? a) ;; i.e. must be a named type "%Pair*" NOT <i32,i32>* (for example)
                                           (= 1 (xtc:codegen:get-ptr-depth a))
                                           (xtc:bind:tuple-field-deep-op? a namestr "hcopy" 1))
                                      (let* ((t (substring a 1 (- (string-length a) 1)))
                                             (fname (if (string=? namestr t)
                                                        'hcopy
                                                        (string->symbol (string-append "hcopy:[" t "*," t "*]*")))))
                                        ;; (println 't: t 'name: name 'type: type)
                                        `(if (not (null? (tref x ,c)))
                                             (tset! obj ,b (,fname (tref x ,c)))))
                                      ;; scalar, primitive pointer, or opaque pointer (e.g. mzone*): shallow copy
                                      `(tset! obj ,b (tref x ,c))))
                                a arglst2 (range (length a)))))
           (hfree_body (if generic #f
                           (map (lambda (a c)
                                  (set! a (xtc:codegen:get-type-from-pretty-str a))
                                  (if (and (xtc:codegen:tuple? a)
                                           (string? a) ;; i.e. must be a named type "%Pair*" NOT <i32,i32>* (for example)
                                           (= 1 (xtc:codegen:get-ptr-depth a))
                                           (xtc:bind:tuple-field-deep-op? a namestr "hfree" 2))
                                      (let* ((t (substring a 1 (- (string-length a) 1)))
                                             (fname (if (string=? namestr t)
                                                        'hfree
                                                        (string->symbol (string-append "hfree:[void," t "*]*")))))
                                        `(if (not (null? (tref x ,c)))
                                             (,fname (tref x ,c))))
                                      ;; opaque pointer (e.g. mzone*): not owned, don't free
                                      ))
                                a (range (length a)))))
           (zcopy_body (if generic #f
                           (map (lambda (a b c)
                                  (define aa a)
                                  (set! a (xtc:codegen:get-type-from-pretty-str a))
                                  (if (and (xtc:codegen:tuple? a)
                                           (string? a) ;; i.e. must be a named type "%Pair*" NOT <i32,i32>* (for example)
                                           (= 1 (xtc:codegen:get-ptr-depth a))
                                           (xtc:bind:tuple-field-deep-op? a namestr "zcopy" 1))
                                      (let* ((t (substring a 1 (- (string-length a) 1)))
                                             (fname (if (string=? namestr t)
                                                        'zcopy
                                                        (string->symbol (string-append "zcopy:[" t "*," t "*,mzone*,mzone*]*")))))
                                        `(if (not (null? (tref x ,c)))
                                             (tset! obj ,b (,fname (tref x ,c) fromz toz))))
                                      ;; opaque pointer (e.g. mzone*) falls through here: shared unless it
                                      ;; points into the from-zone (zone structs never do)
                                      (if (and (xtc:codegen:pointer? a)
                                               (= 1 (xtc:codegen:get-ptr-depth a)))
                                          `(if (llvm_ptr_in_zone fromz (cast (tref x ,c) i8*))
                                               (let ((,(string->symbol (string-append "newptr:" aa)) (zalloc)))
                                                 (memcpy (cast newptr i8*) (cast (tref x ,c) i8*)
                                                         ,(xtc:codegen:get-type-size (xtc:codegen:pointer-- a)))
                                                 (tset! obj ,b newptr))
                                               (tset! obj ,b (tref x ,c)))
                                          `(begin
                                             (tset! obj ,b (tref x ,c))))))
                                a arglst2 (range (length a)))))
           (body (map (lambda (a b c) `(tset! obj ,b ,c)) a arglst2 arglst1)))
      ;;(println 'hcopy: hcopy_body)
      (sys:with-quiet-compiler
       (if constructor?
           (begin
             (eval `(bind-func ,(string->symbol (string-append namestr ":" ctype)) #t
                      (lambda ,argslist
                        (let ((obj (zalloc)))
                          ,@body
                          obj)))
                   (interaction-environment))))
       ;; (eval `(bind-func ,(string->symbol (string-append namestr (if generic ":" "_z:") ctype)) #t
       (eval `(bind-func ,(string->symbol (string-append namestr "_z:" ctype)) #t
                (lambda ,argslist
                  (let ((obj (zalloc)))
                    ,@body
                    obj)))
             (interaction-environment))
       (eval `(bind-func ,(string->symbol (string-append namestr "_h:" ctype)) #t
                (lambda ,argslist
                  (let ((obj (halloc)))
                    ,@body
                    obj)))
             (interaction-environment))
       (if (and generic printer?)
           (begin
             (eval `(bind-func ,(string->symbol (string-append "toString:[String*," namestr "*]*")) #t
                      (lambda (x)
                        (if (null? x)
                            (sprintout ,(string-append "<" namestr ":null"))
                            (sprintout ,(string-append "<" namestr ":")
                                       ,@(cdr (apply append '() (map (lambda (n) (list "," (list 'tref 'x n))) (range (length a)))))
                                       ">"))))
                   (interaction-environment))
             (eval `(bind-func ,(string->symbol (string-append "print:[void," namestr "*]*")) #t
                      (lambda (x)
                        (if (null? x)
                            (printout ,(string-append "<" namestr ":null"))
                            (printout ,(string-append "<" namestr ":")
                                      ,@(cdr (apply append '() (map (lambda (n) (list "," (list 'tref 'x n))) (range (length a)))))
                                      ">"))
                        void))
                   (interaction-environment))))
       (if (not generic)
           (begin
             (if (and (not (regex:match? namestr "_poly_")) printer?)
                 (begin
                   (eval `(bind-func ,(string->symbol (string-append "toString:[String*," namestr "*]*")) #t
                            (lambda (,(string->symbol (string-append "x:" namestr "*")))
                              (if (null? x)
                                  (sprintout ,(string-append "<" namestr ":null>"))
                                  (sprintout ,(string-append "<" namestr ":")
                                             ,@(cdr (apply append '() (map (lambda (n) (list "," (list 'tref 'x n)))
                                                                           (range (length a)))))
                                             ">"))))
                         (interaction-environment))
                   (eval `(bind-func ,(string->symbol (string-append "print:[void," namestr "*]*")) #t
                            (lambda (,(string->symbol (string-append "x:" namestr "*")))
                              (if (null? x)
                                  (printout ,(string-append "<" namestr ":null>"))
                                  (printout ,(string-append "<" namestr ":")
                                            ,@(cdr (apply append '() (map (lambda (n) (list "," (list 'tref 'x n)))
                                                                          (range (length a)))))
                                            ">"))
                              void))
                         (interaction-environment))))
             (eval `(bind-func ,(string->symbol (string-append namestr "_val"))
                      (lambda ,argslist
                        (let ((,(string->symbol (string-append "obj:" namestr "*")) (salloc)))
                          (tfill! obj ,@argslist)
                          (pref obj 0))))
                   (interaction-environment))
             (if copy?
                 (begin
                   (eval `(bind-func ,(string->symbol (string-append "hcopy:[" namestr "*," namestr "*]*"))
                      (lambda (,(string->symbol (string-append "x:" namestr "*")))
                        (let ((obj (halloc)))
                          ,@hcopy_body
                          obj)))
                   (interaction-environment))
                  (eval `(bind-func ,(string->symbol (string-append "hfree:[void," namestr "*]*"))
                      (lambda (,(string->symbol (string-append "x:" namestr "*")))
                        ,@hfree_body
                        (free x)
                        void))
                   (interaction-environment))
                 (eval `(bind-func ,(string->symbol (string-append "zcopy:[" namestr "*," namestr "*,mzone*,mzone*]*"))
                      (lambda (,(string->symbol (string-append "x:" namestr "*")) fromz toz)
                        (if (llvm_ptr_in_zone fromz (cast x i8*))
                            (begin (push_zone toz)
                              (let ((obj (zalloc)))
                                 ,@zcopy_body
                                 (pop_zone)
                                 obj))
                            x)))
                   (interaction-environment))))
             )))
      ;; (println 'dc-out: name)
      #t)))

;; bind-type expects: (symbol type [docstring])
(define-macro (bind-type . args)
  ;; (println 'bind-type args)
  (if (null? args)
      (xtc:diagnostics:print-compiler-error "Bind type missing arguments! (symbol type [docstring])"))
  (let* ((symbol (car args))
         (type_1 (cadr args))
         (type (string->symbol
                (string-append "<"
                 (string-join
                  (map (lambda (x)
                         (if (xtc:cache:typealias-exists? x)
                             (xtc:codegen:pretty-print-type (xtc:cache:get-typealias-type x))
                             x))
                       (xtc:codegen:get-pretty-tuple-arg-strings (symbol->string type_1)))
                  ",")
                 ">")))
         (docstring (if (string? (car (reverse args))) (car (reverse args)) ""))
         (extras (cl:remove #f (map (lambda (x) (if (pair? x) x #f)) args)))
         (printer? (if (assoc-strcmp 'printer? extras)
                       (cdr (assoc-strcmp 'printer? extras))
                       #t))
         (copy? (if (assoc-strcmp 'copy? extras)
                       (cdr (assoc-strcmp 'copy? extras))
                       #t))
         (constructor? (if (assoc-strcmp 'constructor? extras)
                           (cdr (assoc-strcmp 'constructor? extras))
                           #t)))
    (if (not (char=? (string-ref (symbol->string type_1) (- (string-length (symbol->string type_1)) 1)) #\>))
        (xtc:diagnostics:print-bad-type-error type_1 "is a malformed tuple type"))
    (if (xtc:desugar:bang-type? type) ;; send generic named types to aot
        (xtc:aot:insert-generic-type `(bind-type ,@args)))
    (if (<> (xtc:codegen:get-ptr-depth type) 0)
        (xtc:diagnostics:print-bad-type-error type "cannot be a pointer"))
    (if (not (char=? (string-ref (symbol->string type) 0) #\<))
        (xtc:diagnostics:print-bad-type-error type "must be a tuple type"))
    `(begin
       (set! *xtc:codegen:get-type-callback-off* #t)
       (let* ((ags (xtc:codegen:get-pretty-tuple-arg-strings ,(symbol->string type)))
              ;; expand all non-explict generic types
              ;; i.e. expand list* into list:<!a,list*>*
              (expand-polys (map (lambda (k)
                                   (if (and (xtc:cache:get-generictype-candidate-types (xtc:codegen:get-base-type k))
                                            (not (equal? (xtc:codegen:get-base-type k) ,(symbol->string symbol)))) ;; for recursive case!
                                       (xtc:codegen:pointer++
                                        (string-append (xtc:codegen:get-base-type k) ":"
                                                       (symbol->string (xtc:cache:get-generictype-candidate-types (xtc:codegen:get-base-type k))))
                                        (xtc:codegen:get-ptr-depth k))
                                       k))
                                 ags))
              (newtype (string-append "<" (string-join expand-polys ",") ">")))
         ;; (println 'authors_type: ,(symbol->string type))
         ;; (println 'transformed_type: newtype)
         ;; and on with the show!
         (if (xtc:desugar:bang-type? newtype) ;; then must be poly type
             (begin
               (xtc:cache:register-new-generictype ',symbol (string->symbol newtype))
               (xtc:diagnostics:print-binding-details-to-log "GenrType:" ',symbol ',type))
             (let ((typelist (cons *xtc:codegen:tuple* (xtc:codegen:get-type-from-pretty-tuple ,(symbol->string type)
                                                                                       ,(symbol->string symbol)))))
               (if (llvm:compile-ir (string-append "%" ,(symbol->string symbol) " = type "
                                                   (xtc:codegen:get-type-str typelist)))
                   (begin (xtc:cache:register-new-namedtype ,(symbol->string symbol) typelist ,docstring)
                          (xtc:diagnostics:print-binding-details-to-log "DataType:" ',symbol ',type))
                   (xtc:diagnostics:print-compiler-error "could not compile IR for type" ',type)))))
       ;; the next line is to help specialize any element types that may not already be specialized!
       (map (lambda (a) (xtc:codegen:get-type-from-pretty-str a (symbol->string ',(car args)))) (xtc:codegen:get-pretty-tuple-arg-strings ,(symbol->string type)))
       (set! *xtc:codegen:get-type-callback-off* #f)
       ;; (sys:wait (now))
       ;; now compile data constructor
       (xtc:bind:compile-type-dataconstructors
        ',symbol
        (if (xtc:cache:get-generictype-candidate-types ',symbol)
            (symbol->string (xtc:cache:get-generictype-candidate-types ',symbol))
            (xtc:codegen:pretty-print-type (xtc:cache:get-namedtype-type ,(symbol->string symbol))))
        (if (xtc:cache:get-generictype-candidate-types ',symbol) #t #f)
        ,printer?
        ,copy?
        ,constructor?))))

(xtc:cache:register-new-builtin
 "bind-type"
 ""
 "bind an xtlang named type"
 '(name type optional-docstring))

(define-macro (xtc:diagnostics:pretty-print-vars . varlist)
  (map (lambda (var)
         `(begin (println '--- (quote ,var) '---)
                 (println ,var)))
       varlist))

(define xtc:bind:construct-generic-type-if-valid
  (lambda (t)
    ;; named type might need to be constructed!
    (if (and (string? t)
             (char=? (string-ref t 0) #\%)
             (regex:match? t "_poly_"))
        (if (xtc:cache:namedtype-exists? t)
            #t ;; if 't' exists don't do anything else
            (let* ((p (regex:split t "_poly_"))
                   (n (substring (car p) 1 (string-length (car p)))))
              (if (not (xtc:cache:get-generictype-candidate-types n))
                  #f  ;; if not a generic type then bad :(
                  (begin
                    #t))))
        #t)))


;; bind-val takes an optional argument, the meaning of which depends
;; on the type of the val, and also an optional docstring
(define-macro (bind-val symbol type . args)
  (let* ((string-literal? (and (equal? 'i8* type)
                               (not (null? args))
                               (string? (car args))))
         (value (if string-literal?
                    (car args)
                    (if (not (or (null? args) (string? (car args))))
                        (car args)
                        #f)))
         (docstring (if (or (null? args)
                            (not (string? (car (reverse args))))
                            (and string-literal? (= (length args) 1)))
                        ""
                        (car (reverse args))))
         (t (xtc:codegen:get-type-from-pretty-str (atom->string type)))
         (oldt (xtc:cache:get-globalvar-type (symbol->string symbol))))
    ;; this next line looks superflous but isn't!
    ;; 't' maybe a %blah_poly_Hldkfjs* etc. that is not
    ;; yet "constructed". calling get-type-from-pretty-str
    ;; will construct it if it doesn't yet exist
    (if (string? t) (xtc:codegen:get-type-from-pretty-str t))
    (cond (oldt
           `(xtc:diagnostics:print-already-bound-error ',symbol ,(xtc:codegen:pretty-print-type (xtc:codegen:pointer-- oldt))))
          ;; string literal
          (string-literal?
           `(begin
              (llvm:compile-ir (string-append "@" ,(symbol->string symbol)
                                              " = dllexport global i8* zeroinitializer"))
              ;; we should really take the globalvar out of the cache
              ;; if the previous steps failed
              (xtc:cache:register-new-globalvar ,(symbol->string symbol) ',t ,docstring)
              (xtc:aot:insert-globalvar-binding-details *xtc:aot:current-lib-name*
                                                         ,(symbol->string symbol)
                                                         ,(symbol->string type)
                                                         ,docstring)
              (xtc:aot:do-or-emit
               (call-as-xtlang (set! ,symbol ,value) void))
              (xtc:diagnostics:print-binding-details-to-log "SetValue:"
                                                          ,(symbol->string symbol)
                                                          ,(xtc:codegen:pretty-print-type t))))
          ;; non-pointer values
          ((and (or (xtc:codegen:number? t)
                    (xtc:codegen:boolean? t)
                    (not (xtc:codegen:pointer? t))))
           `(begin
              (llvm:compile-ir (string-append "@" ,(symbol->string symbol)
                                              " = dllexport global "
                                              ,(xtc:codegen:get-type-str t) " "
                                              ,(if (number? value)
                                                   ;; can we serialise the value straight into the
                                                   ;;  IR? (e.g. i32/i64/float/double)
                                                   (if (equal? t *xtc:codegen:fp32*)
                                                       (llvm:convert-float (atom->string value))
                                                       (atom->string value))
                                                   ;; otherwise use zeroinitializer and we'll just use a
                                                   ;; set! inside a call-as-xtlang a bit further down
                                                   "zeroinitializer")))
              (xtc:cache:register-new-globalvar ,(symbol->string symbol) ',t ,docstring)
              (xtc:aot:insert-globalvar-binding-details *xtc:aot:current-lib-name*
                                                         ,(symbol->string symbol)
                                                         ,(symbol->string type)
                                                         ,docstring)
              ;; set value for non int/float literals
              ,(if (and value (not (number? value)))
                   `(xtc:aot:do-or-emit
                     (call-as-xtlang (set! ,symbol (convert ,value ,type)) void)))
              ;; we should really take the globalvar out of the
              ;; cache if any of the previous steps failed
              (xtc:diagnostics:print-binding-details-to-log "SetValue:"
                                                          ,(symbol->string symbol)
                                                          ,(xtc:codegen:pretty-print-type t))))
          ;; pointer
          ((xtc:codegen:pointer? t)
           (if (or (not value) (integer? value))
               `(begin
                  (llvm:compile-ir (string-append "@" ,(symbol->string symbol)
                                                  " = dllexport global "
                                                  ,(xtc:codegen:get-type-str t)
                                                  " zeroinitializer"))
                  (xtc:cache:register-new-globalvar ,(symbol->string symbol) ',t ,docstring)
                  (xtc:aot:insert-globalvar-binding-details *xtc:aot:current-lib-name*
                                                             ,(symbol->string symbol)
                                                             ,(symbol->string type)
                                                             ,docstring)
                  (xtc:aot:do-or-emit
                   (call-as-xtlang (set! ,symbol (cast (malloc ,(* (or value 1)
                                                                   (if (xtc:codegen:number? t)
                                                                       (xtc:codegen:get-type-size t)
                                                                       (/ (sys:pointer-size) 8))))
                                                       ,type))
                                   void))
                  ;; we should really take the globalvar out of the cache
                  ;; if the previous steps failed
                  (xtc:diagnostics:print-binding-details-to-log "SetValue:"
                                                              ,(symbol->string symbol)
                                                              ,(xtc:codegen:pretty-print-type t)))
               (if (list? value)
                   `(begin
                      (llvm:compile-ir (string-append "@" ,(symbol->string symbol)
                                                      " = dllexport global "
                                                      ,(xtc:codegen:get-type-str t)
                                                      "zeroinitializer"))
                      (xtc:cache:register-new-globalvar ,(symbol->string symbol) ',t ,docstring)
                      (xtc:aot:insert-globalvar-binding-details *xtc:aot:current-lib-name*
                                                                 ,(symbol->string symbol)
                                                                 ,(symbol->string type)
                                                                 ,docstring)
                      (xtc:aot:do-or-emit
                       (call-as-xtlang (set! ,symbol ,value) void))
                      ;; we should really take the globalvar out of the cache
                      ;; if the previous steps failed
                      (xtc:diagnostics:print-binding-details-to-log "SetValue:"
                                                                  ,(symbol->string symbol)
                                                                  ,(xtc:codegen:pretty-print-type t)))
                   `(xtc:diagnostics:print-compiler-error "when binding global pointers, third argument should be size of buffer to allocate or a valid xtlang sexpr"))))
          ;; tuple/array/vector
          ((or (xtc:codegen:tuple? t) (xtc:codegen:array? t) (xtc:codegen:vector? t))
           `(begin
              (llvm:compile-ir
               (string-append
                "@" ,(symbol->string symbol)
                " = dllexport global "
                ,(xtc:codegen:get-type-str t) " zeroinitializer"))
              (xtc:cache:register-new-globalvar ,(symbol->string symbol) ',t ,docstring)
              (xtc:aot:insert-globalvar-binding-details *xtc:aot:current-lib-name*
                                                         ,(symbol->string symbol)
                                                         ,(symbol->string type)
                                                         ,docstring)
              ;; we should really take the globalvar out of the cache
              ;; if the previous steps failed
              (xtc:diagnostics:print-binding-details-to-log "SetValue:"
                                                          ,(symbol->string symbol)
                                                          ,(xtc:codegen:pretty-print-type t))))
          (else (xtc:diagnostics:print-missing-identifier-error type 'type)))))

(xtc:cache:register-new-builtin
 "bind-val"
 ""
 "bind a global variable"
 '(variable-name type optional-value optional-docstring))

(define-macro (bind-ext-val symname type . docstring)
  `(let* ((type-str ,(if (xtc:cache:typealias-exists? (symbol->string type))
                         (xtc:cache:get-typealias-ground-type-pretty (symbol->string type))
                         (symbol->string type)))
          (type-list (xtc:codegen:get-type-from-pretty-str type-str))
          (ds ,(if (null? docstring) "" (car docstring))))
      (llvm:compile-ir
        (string-append "@" ,(symbol->string symname) " = external global " (xtc:codegen:get-type-str type-list)))
      (xtc:cache:register-new-globalvar ,(symbol->string symname) type-list ds)
      (xtc:aot:insert-ext-globalvar-binding-details ,(symbol->string symname) ,(symbol->string type) ds)
      (xtc:diagnostics:print-binding-details-to-log "bind-ext-val:" ,(symbol->string symname) ,(symbol->string type))))

(xtc:cache:register-new-builtin
 "bind-ext-val"
 ""
 "bind an external global variable"
 '(variable-name type optional-value optional-docstring))

(define-macro (register-ext-val symname type . docstring)
  `(let* ((type-str ,(if (xtc:cache:typealias-exists? (symbol->string type))
                         (xtc:cache:get-typealias-ground-type-pretty (symbol->string type))
                         (symbol->string type)))
          (type-list (xtc:codegen:get-type-from-pretty-str type-str))
          (ds ,(if (null? docstring) "" (car docstring))))
      ; (llvm:compile-ir
      ;   (string-append "@" ,(symbol->string symname) " = external global " (xtc:codegen:get-type-str type-list)))
      (xtc:cache:register-new-globalvar ,(symbol->string symname) type-list ds)
      (xtc:aot:insert-ext-globalvar-binding-details ,(symbol->string symname) ,(symbol->string type) ds)
      (xtc:diagnostics:print-binding-details-to-log "register-ext-val:" ,(symbol->string symname) ,(symbol->string type))))

(define-macro (bind-poly poly_sym implementation_sym . docstring)
  (if (xtc:cache:genericfunc-exists? implementation_sym)
      (xtc:diagnostics:print-compiler-error (string-append "bind-poly only accepts monomorphic functions, not " (symbol->string implementation_sym))))
  (if (not (xtc:cache:closure-or-nativefunc-exists? (symbol->string implementation_sym)))
      (xtc:diagnostics:print-missing-identifier-error implementation_sym 'closure))
  (let ((type (xtc:cache:get-closure-or-nativefunc-type (symbol->string implementation_sym))))
    (if type
        `(begin
           (xtc:cache:register-new-polyfunc ,(symbol->string poly_sym) ,(symbol->string implementation_sym) ',type ,(if (null? docstring) "" (car docstring)))
           (xtc:bind:create-scheme-wrapper (symbol->string ',implementation_sym))
           (if (not (regex:match? ,(symbol->string implementation_sym) "(_adhoc_|_poly_)"))
               (xtc:diagnostics:print-polying-details-to-log "PolyFunc:"
                                                           ,(symbol->string poly_sym)
                                                           ,(symbol->string implementation_sym)
                                                           ,(xtc:codegen:pretty-print-type type))))
        `(xtc:diagnostics:print-missing-identifier-error ',implementation_sym 'closure))))

(xtc:cache:register-new-builtin
 "bind-poly"
 ""
 "bind a polymorphic symbol"
 '(poly-name closure-name optional-docstring))

(define xtc:bind:search-for-dylib
  (lambda (path)
    (let loop ((candidate-paths
                (append
                 (list
                  path
                  (sanitize-platform-path (string-append (sys:share-dir) "/libs/aot-cache/" path))
                  (sanitize-platform-path (string-append (sys:share-dir) "/libs/platform-shlibs/" path)))
                 (unix-or-Windows (map
                                   (lambda (x)
                                     (sanitize-platform-path
                                      (string-append x "/" path)))
                                   (append (regex:split
                                            (sys:command-output
                                             "echo $LD_LIBRARY_PATH")
                                            ":")
                                           '("/usr/local/lib/"
                                             "/usr/lib/"
                                             "/opt/local/lib/"
                                             ;; Linux
                                             "/usr/lib/x86_64-linux-gnu"
                                             "/usr/lib/aarch64-linux-gnu"
                                             ;; macOS
                                             "/opt/homebrew/lib/"
                                             "/usr/local/Cellar/"
                                             "/opt/homebrew/Cellar/")))
                                  (list (sanitize-platform-path (string-append "C:/Windows/System32/" path)))))))
      (if (null? candidate-paths)
          #f
          (let ((dylib (sys:open-dylib (car candidate-paths) #f)))
            (if dylib
                (cons dylib (car candidate-paths))
                (if (file-exists? (car candidate-paths))
                    ;; if sys:open-dylib failed bu the file is there, something's gone wrong
                    (begin
                      (print-with-colors *xtc:globals:pretty-print-error-color* 'default #t
                                         (print "Error"))
                      (print ": could not open ")
                      (print-with-colors *xtc:globals:pretty-print-type-color* 'default #t (car candidate-paths))
                      (print " dynamic library\n")
                      (error ""))
                    (loop (cdr candidate-paths)))))))))

(define xtc:bind:bind-dylib
  (lambda (library lib-paths)
    (let ((dylib-pair
           (let loop ((paths lib-paths))
             (if (null? paths)
                 #f
                 (or (xtc:bind:search-for-dylib (car paths))
                     (loop (cdr paths)))))))
      (if dylib-pair
          (begin
            (eval (list 'define library (car dylib-pair))
                  (interaction-environment))
            (set! *xtc:aot:current-load-dylib-info*
                  (cons library (cdr dylib-pair)))
            (xtc:aot:add-win-link-library (cdr dylib-pair))
            (xtc:diagnostics:print-dylib-loading-details-to-log (cdr dylib-pair))
            #t)
          (begin
            (print-with-colors *xtc:globals:pretty-print-error-color* 'default #t
                               (print "Error"))
            (print ": could not find ")
            (print-with-colors *xtc:globals:pretty-print-type-color* 'default #t (print library))
            (print " dynamic library\n")
            (error ""))))))

(define-macro (bind-dylib library lib-path . args)
  (let ((path (eval lib-path)))
    (if (string? path)
        (set! path (list path)))
    (apply xtc:aot:insert-load-dylib-details library path args)
    `(xtc:bind:bind-dylib ',library ',path)))

(xtc:cache:register-new-builtin
 "bind-dylib"
 ""
 "load a dynamic library

e.g.

(bind-dylib lib \"libGL.so\")

@param lib-symbol - symbol to refer to the library
@param lib-paths - a string (or list of strings) of paths to search for the dylib"
 '(lib-symbol lib-paths))

;; this here for wrapping llvm dynamic binds
(define-macro (bind-lib library symname type . args)
  `(xtc:bind:bind-lib ',library ',symname ',type
                     ;; calling convention
                     ,(if (and (not (null? args)) (number? (car args)))
                          (car args)
                          0) ;; 0=ccc
                     ;; docstring
                     ,(if (and (not (null? args)) (string? (car (reverse args))))
                          (car (reverse args))
                          "")))

(xtc:cache:register-new-builtin
 "bind-lib"
 ""
 "bind a C function from a shared library"
 '(libname function-name type optional-docstring))

;; this was previously called __dynamic-bind
(define xtc:bind:bind-lib
  (lambda (library symname type calling-convention docstring)
    (if (llvm:get-function (symbol->string symname)) ;; if already bound!
        (begin
          (xtc:cache:register-new-nativefunc (symbol->string symname) (xtc:codegen:get-type-from-pretty-str (symbol->string type)) "" '())
          (xtc:diagnostics:print-lib-binding-details-to-log library symname type)
          (xtc:aot:insert-nativefunc-binding-details library symname type docstring))
        (if (not (eval library))
            (xtc:diagnostics:print-compiler-error
              (string-append "the " (symbol->string library) " dynamic library appears to have not been loaded correctly"))
            (let* ((ctype (cdr (xtc:codegen:get-type-from-pretty-str (symbol->string type))))
                  (ir-string (string-append "declare "
                                            "cc " (atom->string calling-convention)
                                            " "
                                            (xtc:codegen:get-type-str (car ctype))
                                            " @"
                                            (symbol->string symname)
                                            "("
                                            (if (null? (cdr ctype))
                                                ""
                                                (apply string-append
                                                        (xtc:codegen:get-type-str (cadr ctype))
                                                        (map (lambda (v)
                                                              (string-append "," (xtc:codegen:get-type-str v)))
                                                            (cddr ctype))))
                                            ") nounwind")))
              (if (and (llvm:compile-ir ir-string)
                      (llvm:bind-symbol (eval library) (symbol->string symname)))
                  (begin
                    (if (output-port? *xtc:aot:current-output-port*) ;; *xtc:aot:dll*)
                        (begin (write `(llvm:bind-symbol ,library ,(symbol->string symname)) *xtc:aot:current-output-port*)
                              (newline *xtc:aot:current-output-port*)))
                    (xtc:cache:register-new-nativefunc (symbol->string symname) (xtc:codegen:get-type-from-pretty-str (symbol->string type)) "" '())
                    (xtc:diagnostics:print-lib-binding-details-to-log library symname type)
                    (xtc:aot:insert-nativefunc-binding-details library symname type docstring))
                  (xtc:diagnostics:print-compiler-error (string-append "could not bind " (symbol->string symname)))))))))

(define-macro (unbind-func symname)
  `(begin
     (llvm:remove-globalvar ,(string-append (symbol->string symname) "_var"))
     (llvm:erase-function ,(symbol->string symname))
     (llvm:erase-function ,(string-append (symbol->string symname) "_setter"))
     (llvm:erase-function ,(string-append (symbol->string symname) "_getter"))
     (llvm:erase-function ,(string-append (symbol->string symname) "_maker"))
     (llvm:erase-function ,(string-append (symbol->string symname) "_callback"))
     (llvm:erase-function ,(string-append (symbol->string symname) "_native"))
     (llvm:erase-function ,(string-append (symbol->string symname) "_maker"))
     (llvm:remove-globalvar ,(string-append (symbol->string symname) "_var_zone"))
     (if (llvm:get-function ,(string-append (symbol->string symname) "_scheme"))
         (llvm:erase-function ,(string-append (symbol->string symname) "_scheme")))))

(define-macro (bind-lib-type library name type docstring)
  (let* ((a (xtc:codegen:get-pretty-tuple-arg-strings (symbol->string type)))
         (namestr (symbol->string name))
         (typestr (symbol->string type)))
    `(begin
       (if (llvm:compile-ir ,(string-append "%" namestr " = type " (xtc:codegen:get-type-str (xtc:codegen:get-type-from-pretty-str typestr namestr))))
           (xtc:cache:register-new-namedtype ,namestr
                                           ',(xtc:codegen:get-type-from-pretty-str typestr namestr)
                                           ,docstring)
           (xtc:diagnostics:print-compiler-error "bind-lib-type failed" ,name)))))

(define-macro (register-lib-type library name type docstring)
  (if (xtc:aot:currently-compiling?)
      (set! *xtc:globals:suppress-ir-generation* #t)
      (set! *xtc:globals:suppress-ir-generation* #f))
  (let* ((a (xtc:codegen:get-pretty-tuple-arg-strings (symbol->string type)))
         (namestr (symbol->string name))
         (typestr (symbol->string type)))
    `(begin
       (xtc:cache:register-new-namedtype ,namestr
                                      ',(xtc:codegen:get-type-from-pretty-str typestr namestr)
                                      ,docstring)
       (set! *xtc:globals:suppress-ir-generation* #f))))


;;; this here for binding to CLOSURE in dylib
;;
;; arg is for *optional* zone size arg
(define-macro (bind-lib-func library symname type zone-size docstring body)
  `(begin
     (bind-lib ,library ,symname ,type fastcc)
     (bind-lib ,library ,(string->symbol (string-append (symbol->string symname) "_setter")) [void]*)
     (bind-lib ,library ,(string->symbol (string-append (symbol->string symname) "_getter")) [i8*]*)
     (bind-lib ,library ,(string->symbol (string-append (symbol->string symname) "_callback")) [void,i8*]*)
     (if (xtc:bind:create-scm-wrapper? ,(symbol->string symname))
         (bind-lib ,library ,(string->symbol (string-append (symbol->string symname) "_scheme")) [i8*,i8*,i8*]*))
     (bind-lib ,library ,(string->symbol (string-append (symbol->string symname) "_native")) ,type)
     (bind-lib ,library ,(string->symbol (string-append (symbol->string symname) "_maker"))
               ,(string->symbol (string-append "[" (symbol->string type) ",i8*]*")))
     (if (not (llvm:compile-ir
               (string-append "@" ,(symbol->string symname) "_var = external global [1 x i8*]\n\n"
                              "@" ,(symbol->string symname) "_var_zone = external global [1 x i8*]\n\n")))
         (xtc:diagnostics:print-compiler-error "failed to compile IR in bind-lib-func" ,symname))
     (llvm:bind-symbol ,library ,(string-append (symbol->string symname) "_var"))
     (llvm:bind-symbol ,library ,(string-append (symbol->string symname) "_var_zone"))
     ;; bind scheme function
     (if (xtc:bind:create-scm-wrapper? ,(symbol->string symname))
         (eval (define ,symname
                 (xtc:bind:create-scheme-wrapper (symbol->string ',symname)))
               (interaction-environment))
         (xtc:diagnostics:print-no-scheme-stub-notification (symbol->string ',symname)))
     (xtc:cache:register-new-closure ,(symbol->string symname)
                                   (xtc:codegen:get-type-from-pretty-str ,(symbol->string type))
                                   ,zone-size
                                   ,docstring
                                   ,body)
     (xtc:diagnostics:print-binding-details-to-log "LibBound:"
                                                 ,(symbol->string symname)
                                                 ,(symbol->string type))
     (xtc:bind:initialize-closure-with-new-zone ,(symbol->string symname)
                                               ,zone-size)))

(define-macro (register-lib-func library symname type zone-size docstring body)
  `(begin
     ;; bind scheme function
     (xtc:cache:register-new-closure ,(symbol->string symname)
                                   (xtc:codegen:get-type-from-pretty-str ,(symbol->string type))
                                   ,zone-size
                                   ,docstring
                                   ,body)
     (xtc:diagnostics:print-binding-details-to-log "Lib Registered:"
                                                 ,(symbol->string symname)
                                                 ,(symbol->string type))
     (xtc:bind:initialize-closure-with-new-zone ,(symbol->string symname) ,zone-size)))


(define-macro (bind-lib-val library symname type . docstring)
  `(let* ((type-str ,(if (xtc:cache:typealias-exists? (symbol->string type))
                         (xtc:cache:get-typealias-ground-type-pretty (symbol->string type))
                         (symbol->string type)))
          (type-list (xtc:codegen:get-type-from-pretty-str type-str))
          (ds ,(if (null? docstring) "" (car docstring))))
     (if (and (llvm:compile-ir
               (string-append "@" ,(symbol->string symname) " = external global "
                              (xtc:codegen:get-type-str type-list)))
              (llvm:bind-symbol ,library ,(symbol->string symname)))
         (begin
           (xtc:cache:register-new-globalvar ,(symbol->string symname)
                                           type-list
                                           ds)
           (xtc:aot:insert-globalvar-binding-details ,(symbol->string library)
                                                      ,(symbol->string symname)
                                                      ,(symbol->string type)
                                                      ds)
           (xtc:diagnostics:print-binding-details-to-log "LibBound:"
                                                       ,(symbol->string symname)
                                                       ,(symbol->string type)))
         (xtc:diagnostics:print-compiler-error (string-append "could not bind-lib-val "
                                                            ,(symbol->string symname)
                                                            " from library "
                                                            ,(symbol->string library))))))

(define-macro (register-lib-val library symname type . docstring)
  `(let* ((type-str ,(if (xtc:cache:typealias-exists? (symbol->string type))
                         (xtc:cache:get-typealias-ground-type-pretty (symbol->string type))
                         (symbol->string type)))
          (type-list (xtc:codegen:get-type-from-pretty-str type-str))
          (ds ,(if (null? docstring) "" (car docstring))))
      (begin
           (xtc:cache:register-new-globalvar ,(symbol->string symname)
                                           type-list
                                           ds)
           (xtc:aot:insert-globalvar-binding-details ,(symbol->string library)
                                                      ,(symbol->string symname)
                                                      ,(symbol->string type)
                                                      ds)
           (xtc:diagnostics:print-binding-details-to-log "Lib Registered:"
                                                       ,(symbol->string symname)
                                                       ,(symbol->string type)))))

;; THIS IS A HELPER FUNCTION
;;
;; returns a (bind-lib-xtm) form for the named function
;; by using the xtm-closure-doc to get the type
;; function must already have been compiled into module
(define-macro (bind-lib-xtm-get-string name)
  (let ((res (eval `(xtm-closure-doc ,name))))
    (if (string? res)
        `(sexpr->string '(bind-lib-xtm mathlib ,name ,(string->symbol res)))
        `(sexpr->string '(bind-lib-xtm mathlib ,name ,(string->symbol (cdr res)))))))


;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(define xtc:bind:initialize-closure-with-new-zone
  (lambda (func-name zone-size)
    (if (not (xtc:aot:currently-compiling?))
        (let ((setter (llvm:get-function (string-append func-name "_setter"))))
          (if setter
              (begin
                (sys:push-memzone (sys:create-mzone zone-size))
                (llvm:run setter)
                ;; don't destroy - this happens in _setter func
                (sys:pop-memzone))
              (xtc:diagnostics:print-missing-identifier-error (string->symbol (string-append func-name "_setter")) 'closure-setter))))))

(define xtc:bind:create-scm-wrapper?
  (lambda (func-name)
    (cl:every
     (lambda (type)
       (or (xtc:codegen:void? type)
           (xtc:codegen:floating-point? type)
           (xtc:codegen:fixed-point? type)
           (xtc:codegen:pointer? type)))
     (map xtc:codegen:get-type-from-str
          (xtc:cache:get-closure-or-nativefunc-arg-types func-name)))))

(define xtc:bind:adhoc-scheme-wrapper
  (lambda (polyname funcname)
    `(define ,(string->symbol polyname)
       (lambda args
         (if (and (not (null? args))
                  (symbol? (car args)))
             (if (equal? (car args) 'xtlang)
                 ',(string->symbol funcname)
                 (if (null? (cdr args))
                     (eval (string->sexpr (string-append "(" ,funcname "." (symbol->string (car args)) ")")))
                     (eval (append (string->sexpr (string-append "(" ,funcname "." (symbol->string (car args)) ")"))
                                   (list (cadr args))))))
             (apply ,(string->symbol funcname) args))))))


(define xtc:bind:create-scheme-wrapper
  (lambda (func-name)
    (if (xtc:aot:currently-compiling?)
        (lambda ()
          (if (not (xtc:aot:currently-compiling?))
              (begin
                (print-with-colors 'yellow 'default #t (print "Compiler Warning:"))
                (print " the scheme wrapper for ")
                (print-with-colors *xtc:globals:pretty-print-name-color* 'default #t (print (string->symbol func-name)))
                (print " was called, but it doesn't exist (yet)\n"))))
        (let ((scheme-func (llvm:get-function-pointer (string-append func-name "_scheme")))
              (p (regex:split func-name "_adhoc_")))
          (if (and
               (or (not (defined? (string->symbol (car p))))
                   (defined? (string->symbol (string-append (car p) "_xtlang_name"))))
               (not (null? (cdr p)))) ;; if _adhoc_ is true
              (let ((polytypes (xtc:cache:get-polyfunc-candidate-list (car p))))
                (if (and (list? polytypes)
                         (= (length polytypes) 1))
                    (begin
                      (eval `(define
                               ,(string->symbol (string-append (car p) "_xtlang_name"))
                               ,(vector-ref (car polytypes) 0))
                            (interaction-environment))
                      (eval (xtc:bind:adhoc-scheme-wrapper
                             (car p)
                             (vector-ref (car polytypes) 0))
                            (interaction-environment)))
                    (begin
                      (eval `(define ,(string->symbol (string-append (car p) "_xtlang_name")) #f)
                            (interaction-environment))
                      (eval `(define ,(string->symbol (car p))
                               (lambda args
                                 (println 'Ambiguous 'or 'unavailable 'xtlang 'wrapper: ,(car p))))
                            (interaction-environment))))))
          (if scheme-func
              (begin
                (llvm:ffi-set-name scheme-func func-name)
                ;; (println 'mk-ff func-name)
                (mk-ff func-name scheme-func))
              (xtc:diagnostics:print-no-scheme-stub-notification (string->symbol func-name)))))))

;; a helper for returning a native closure (if one exists!)
(define llvm:get-native-closure
  (lambda (name)
    (if (xtc:aot:currently-compiling?)
        (xtc:diagnostics:print-not-during-aot-error)
        (let ((f (llvm:get-function (string-append name "_getter"))))
          (if f (llvm:run f)
              '())))))

(define llvm:get-closure-setter
  (lambda (name)
    (if (xtc:aot:currently-compiling?)
        (xtc:diagnostics:print-not-during-aot-error)
        (llvm:get-function-pointer (string-append name "_setter")))))

;; a helper for returning a scheme closure native closure (if one exists!)
(define llvm:get-native-function
  (lambda (name)
    (if (xtc:aot:currently-compiling?)
        (xtc:diagnostics:print-not-during-aot-error)
        (llvm:get-function-pointer (string-append name "_native")))))

;; Wrap a native, bound C function, allowing it to be called from scheme
(define-macro (bind-wrapper local-sym native-sym)
  (let* ((types (cdr (xtc:cache:get-closure-arg-types (symbol->string native-sym))))
         (args (map (lambda (t v) v)
                    types (make-list-with-proc
                           (length types)
                           (lambda (i)
                             (string->symbol (string-append "arg_" (atom->string i))))))))
    `(bind-func ,local-sym
       (lambda ,args
         ,(cons native-sym args)))))


;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;
;; very dodgy
;; generic constraints
;;
;; simply forces supplied specialisations
;; add to polys and remove gpoly
;;
;; for example
;;
;; (bind-func test:[!a,!a]*
;;   (lambda (x) (* x x)))
;;
;; (constrain-genericfunc test [i32,i32]* [float,float]*)
;;
(define xtc:bind:constrain-genericfunc
  (lambda (sym . types)
    ;; (println 'xtc:bind:constrain-genericfunc 'sym: sym types)
    (if (not (xtc:cache:genericfunc-exists? (string->symbol sym)))
        (xtc:diagnostics:print-missing-identifier-error sym "generic function")
        (let ((printspec *xtc:globals:print-code-specialization-compiles*))
          (set! *xtc:globals:print-code-specialization-compiles* #t)
          (for-each
           (lambda (t)
             (if (regex:match? t "_poly_")
                 (set! t (cname-decode (cadr (regex:type-split t "_poly_")))))
             (let ((etype (cname-encode t)))
               (if (not (xtc:cache:closure-exists? (string-append sym "_poly_" etype)))
                   (let* ((arity (xtc:codegen:get-arity-from-pretty-closure t))
                          (code (caddr (cadr (xtc:cache:genericfunc-types (string->symbol sym) arity t))))
                          (pfunc (string->symbol (string-append sym "_poly_" etype))))
                     ;; (println 'arity: arity 'code: code 'pfunc: pfunc)
                     ;; pre-populate the closure cache for the new specialised func
                     (if (not (xtc:cache:closure-exists? (symbol->string pfunc)))
                         (xtc:cache:register-new-closure (symbol->string pfunc)
                                                       '()
                                                       *xtc:globals:default-zone-size*
                                                       ""
                                                       code))
                     (set! code `(let ((,pfunc ,code)) ,pfunc))
                     (xtc:driver:run pfunc code *xtc:globals:default-zone-size* #f #f (cons pfunc (string->symbol t)))
                     (xtc:cache:register-new-polyfunc sym
                                                    (symbol->string pfunc)
                                                    (xtc:codegen:get-type-from-pretty-str t)
                                                    "")
                     (xtc:bind:initialize-closure-with-new-zone (symbol->string pfunc)
                                                               *xtc:globals:default-zone-size*)
                     pfunc))))
           types)
          (set! *xtc:globals:print-code-specialization-compiles* printspec)
          (hashtable-delete! *xtc:cache:genericfunc-cache* sym)
          #t))))

(define-macro (constrain-genericfunc sym . args)
  (apply xtc:bind:constrain-genericfunc
         (symbol->string sym)
         (map (lambda (x)
                (if (regex:match? (symbol->string x) "^\\$")
                    (set! x (string->symbol (string-append (symbol->string sym) ":" (symbol->string x)))))
                (symbol->string (xtc:desugar:expand-generic-type x))) args)))

;; old name (for compatibility)
(define constrain-generic constrain-genericfunc)

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;
;; specialize generic type!
;;
(define xtc:bind:specialize-generictype
  (lambda (sym . types)
    ;; (println 'xtc:bind:specialize-generictype 'sym: sym types)
    (if (not (xtc:cache:get-generictype-candidate-types (string->symbol sym)))
        (xtc:diagnostics:print-missing-generic-type-error sym)
        (let ((printspec *xtc:globals:print-code-specialization-compiles*))
          (set! *xtc:globals:print-code-specialization-compiles* #t)
          (for-each
           (lambda (t)
             (if (regex:match? t ":")
                 (set! t (cadr (regex:type-split t ":"))))
             (let ((newname (string-append sym "_poly_" (cname-encode t))))
               (if (llvm:compile-ir (string-append "%" newname " = type " (xtc:codegen:get-type-str (xtc:codegen:get-type-from-pretty-str t))))
                   (xtc:bind:compile-type-dataconstructors (string->symbol newname) t #f #t #t #t)
                   (xtc:diagnostics:print-compiler-error "failed to compile IR in xtc:bind:specialize-generictype" sym))))
           types)
          (set! *xtc:globals:print-code-specialization-compiles* printspec)
          #t))))

(define-macro (specialize-generictype sym . args)
  (apply xtc:bind:specialize-generictype
         (symbol->string sym)
         (map (lambda (x)
                (if (regex:match? (symbol->string x) "^\\$")
                    (set! x (string->symbol (string-append (symbol->string sym) ":" (symbol->string x)))))
                (symbol->string (xtc:desugar:expand-generic-type x))) args)))


;; force specializations on a generic funtion
(define xtc:bind:specialize-genericfunc
  (lambda (sym . types)
    ;; (println 'xtc:bind:specialize-genericfunc 'sym: sym types)
    (if (not (xtc:cache:genericfunc-exists? (string->symbol sym)))
        (xtc:diagnostics:print-missing-identifier-error sym "generic function")
        (let ((printspec *xtc:globals:print-code-specialization-compiles*))
          (set! *xtc:globals:print-code-specialization-compiles* #t)
          (for-each
           (lambda (t)
             (if (regex:match? t "_poly_")
                 (set! t (cname-decode (cadr (regex:type-split t "_poly_")))))
             (let ((etype (cname-encode t)))
               (if (not (xtc:cache:closure-exists? (string-append sym "_poly_" etype)))
                   (let* ((arity (xtc:codegen:get-arity-from-pretty-closure t))
                          (gftypes (xtc:cache:genericfunc-types (string->symbol sym) arity t))
                          (res (if (not gftypes)
                                   (xtc:diagnostics:print-compiler-error "Bad generic closure type:" (list sym t))))
                          (code (caddr (cadr gftypes)))
                          (pfunc (string->symbol (string-append sym "_poly_" etype))))
                     ;; (println 'makesym etype 't: t)
                     ;; (println 'arity: arity 'code: code 'pfunc: pfunc)
                     ;; pre-populate the closure cache for the new specialised func
                     (if (not (xtc:cache:closure-exists? (symbol->string pfunc)))
                         (xtc:cache:register-new-closure (symbol->string pfunc)
                                                       '()
                                                       *xtc:globals:default-zone-size*
                                                       ""
                                                       code))
                     (set! code `(let ((,pfunc ,code)) ,pfunc))
                     (xtc:driver:run pfunc code *xtc:globals:default-zone-size* #f #f (cons pfunc (string->symbol t)))
                     (xtc:cache:register-new-polyfunc sym
                                                    (symbol->string pfunc)
                                                    (xtc:codegen:get-type-from-pretty-str t)
                                                    "")
                     (xtc:bind:initialize-closure-with-new-zone (symbol->string pfunc)
                                                               *xtc:globals:default-zone-size*)
                     pfunc))))
           types)
          (set! *xtc:globals:print-code-specialization-compiles* printspec)
          #t))))

(define-macro (call-as-xtlang . expr)
  (if (not (xtc:aot:currently-compiling?))
      (sys:with-quiet-compiler
       (begin
         (set! *xtc:codegen:sym-name-stack* '())
         (set! *xtc:codegen:ls_var* '())
         (set! *xtc:globals:bound-lambdas* '())
         (set! *xtc:desugar:generic-type-mappings* '())
         (set! *xtc:typecheck:nativef-generics-recurse-test* 0)
         (let ((type (xtc:bind:get-expression-type (car (reverse expr)))))
           (eval `(bind-func xtlang_expression
                    (lambda ()
                      ,(if (equal? type -1)
                           `(let ((s:i8* (halloc 2)))
                              ,@expr
                              s)
                           `(letz ((res (begin ,@expr))
                                   (s:String* (toString res))
                                   (lgth (+ 1 (tref s 0)))
                                   (oldcs (tref s 1))
                                   (newcs:i8* (halloc lgth)))
                              (strcpy newcs oldcs)
                              newcs))))
                 (interaction-environment))
           (quote (string->atom (cptr->string (xtlang_expression)))))))))

(define xtmX call-as-xtlang)
(define $ call-as-xtlang)

;; this version uses a let instead of a letz
(define-macro (call-as-xtlang-leaky . expr)
  (if (not (xtc:aot:currently-compiling?))
      (sys:with-quiet-compiler
       (begin
         (set! *xtc:codegen:sym-name-stack* '())
         (set! *xtc:codegen:ls_var* '())
         (set! *xtc:globals:bound-lambdas* '())
         (set! *xtc:desugar:generic-type-mappings* '())
         (set! *xtc:typecheck:nativef-generics-recurse-test* 0)
         (let ((type (xtc:bind:get-expression-type (car (reverse expr)))))
           (eval `(bind-func xtlang_expression
                    (lambda ()
                      ,(if (not (xtc:codegen:pointer? type))
                           `(let ((s:i8* null))
                              ;; (println "returning null for non-pointer type")
                              ,@expr
                              s)
                           `(let ((res:i8* (cast (begin ,@expr) i8*)))
                              res))))
                 (interaction-environment))
           (quote (xtlang_expression)))))))

(define $$ call-as-xtlang-leaky)

;; helper macro for specializing generics
;;
;; i.e. (specialize-genericfunc blah [i32,i32]* [i64,i64]*)
(define-macro (specialize-genericfunc sym . args)
  (apply xtc:bind:specialize-genericfunc
         (symbol->string sym)
         (map (lambda (x)
                (if (regex:match? (symbol->string x) "^\\$")
                    (set! x (string->symbol (string-append (symbol->string sym) ":" (symbol->string x)))))
                (symbol->string (xtc:desugar:expand-generic-type x))) args)))

;;;;;;;;;;;;
;; xtmdoc ;;
;;;;;;;;;;;;

;; the documentation function should return an associative list with
;; the following keys:

;; ((name . awesome_closure)
;;  (category . "closure")
;;  (type . "[i64]")
;;  (args . (arg1 arg2))
;;  (docstring . "the docstring))

;; the keys must be present, but the cdr of each element may be
;; missing where appropriate (e.g. scheme functions have no type field)

(define xtmdoc-strip-arg-type-annotations
  (lambda (form)
    (if (or (symbol? form)
            (not (list? form)))
        form
        (map (lambda (arg)
               (string->symbol (car (regex:split (symbol->string arg) ":"))))
             form))))

(define xtmdoc-get-args-from-form
  (lambda (form)
    (if (null? form)
        #f
        (if (equal? (car form) 'lambda)
            (xtmdoc-strip-arg-type-annotations (cadr form))
            (if (and (list? (car form)) (equal? (caar form) 'lambda))
                (xtmdoc-strip-arg-type-annotations (cadar form))
                ;; recurse!
                (xtmdoc-get-args-from-form (if (member (car form) '(let let* letz))
                                               (cddr form)
                                               (cdr form))))))))

;; currently only returns the result for the first arity
(define xtmdoc-get-xtlang-genericfunc-args
  (lambda (fn-sym)
    (xtmdoc-get-args-from-form
     (caddar (cdddar (reverse (or (hashtable-ref *xtc:cache:genericfunc-cache* (symbol->string fn-sym)) '())))))))

(define xtmdoc-builtin-handler
  (lambda (name-sym)
    (list
     '(category . "builtin")
     (cons 'name (symbol->string name-sym))
     (cons 'args (xtc:cache:get-builtin-args (symbol->string name-sym)))
     (cons 'type
           (let ((type (xtc:cache:get-builtin-type-str (symbol->string name-sym))))
             (if (string=? type "") '() type)))
     (cons 'docstring
           (let ((docstring (xtc:cache:get-builtin-docstring (symbol->string name-sym))))
             (if (string=? docstring "") '() docstring))))))

(define xtmdoc-genericfunc-handler
  (lambda (name-sym)
    ;; once we have a way to handle multipe aritys, we should update
    ;; this function
    (list
     '(category . "generic closure")
     (cons 'name (symbol->string name-sym))
     (cons 'args (xtmdoc-get-xtlang-genericfunc-args name-sym))
     (cons 'type (xtc:desugar:simplify-genericfunc-pretty-type
                  (symbol->string (caddar (reverse (or (hashtable-ref *xtc:cache:genericfunc-cache* (symbol->string name-sym)) '()))))))
     (list 'docstring))))

(define xtmdoc-generictype-handler
  (lambda (name-sym)
    (list
     '(category . "generic type")
     (cons 'name (symbol->string name-sym))
     (list 'args)
     (cons 'type (xtc:desugar:simplify-generictype-pretty-type
                  (symbol->string (xtc:cache:get-generictype-candidate-types name-sym))))
     (list 'docstring))))

(define xtmdoc-polyfunc-handler
  (lambda (name-sym)
    (list
     '(category . "polymorphic closure")
     (cons 'name (symbol->string name-sym))
     (cons 'args "")
     (list 'type)
     (cons 'docstring
           (let ((docstring (xtc:cache:get-polyfunc-docstring (symbol->string name-sym)))
                 (poly-options-docstring
                  (string-join (map (lambda (pf)
                                      (let* ((option-name (vector-ref pf 0)))
                                        (string-append "@poly " option-name ":"
                                                       (xtc:codegen:pretty-print-type (vector-ref pf 1)))))
                                    (cl:remove-if
                                     (lambda (pf) (regex:match? (vector-ref pf 0) "_poly_"))
                                     (xtc:cache:get-polyfunc-candidate-list (symbol->string name-sym))))
                               "\n")))
             (string-append docstring "\n\n" poly-options-docstring))))))

(define xtmdoc-polytype-handler
  (lambda (name-sym)
    (list
     '(category . "polymorphic type")
     (cons 'name (symbol->string name-sym))
     (list 'args)
     (cons 'type (string-join (map (lambda (pf) (xtc:codegen:pretty-print-type pf))
                                   (xtc:cache:get-polytype-candidate-types (symbol->string name-sym)))
                              " "))
     (list 'docstring))))

(define xtmdoc-closure-handler
  (lambda (name-sym)
    (list
     '(category . "closure")
     (cons 'name (symbol->string name-sym))
     (cons 'args (xtmdoc-get-args-from-form (xtc:cache:get-closure-body (symbol->string name-sym))))
     (cons 'type (xtc:codegen:pretty-print-type (xtc:cache:get-closure-type (symbol->string name-sym))))
     (cons 'docstring
           (let ((docstring (xtc:cache:get-closure-docstring (symbol->string name-sym))))
             (if (string=? docstring "") '() docstring))))))

(define xtmdoc-nativefunc-handler
  (lambda (name-sym)
    (list
     '(category . "C function")
     (cons 'name (symbol->string name-sym))
     (cons 'args (xtc:cache:get-nativefunc-arg-names (symbol->string name-sym)))
     (cons 'type
           (let ((type (xtc:cache:get-nativefunc-type (symbol->string name-sym))))
             (if (equal? type 'varargs)
                 "varargs"
                 (xtc:codegen:pretty-print-type type))))
     (cons 'docstring
           (let ((docstring (xtc:cache:get-nativefunc-docstring (symbol->string name-sym))))
             (if (string=? docstring "") '() docstring))))))

(define xtmdoc-typealias-handler
  (lambda (name-sym)
    (list
     '(category . "type alias")
     (cons 'name (symbol->string name-sym))
     (list 'args)
     (cons 'type (xtc:codegen:pretty-print-type (xtc:cache:get-typealias-ground-type (symbol->string name-sym))))
     (cons 'docstring
           (let ((docstring (xtc:cache:get-typealias-docstring (symbol->string name-sym))))
             (if (string=? docstring "") '() docstring))))))

(define xtmdoc-namedtype-handler
  (lambda (name-sym)
    (list
     '(category . "named type")
     (cons 'name (symbol->string name-sym))
     (list 'args)
     (cons 'type (xtc:codegen:pretty-print-type (xtc:cache:get-namedtype-type (symbol->string name-sym))))
     (cons 'docstring
           (let ((docstring (xtc:cache:get-namedtype-docstring (symbol->string name-sym))))
             (if (string=? docstring "") '() docstring))))))

(define xtmdoc-globalvar-handler
  (lambda (name-sym)
    (list
     '(category . "global var")
     (cons 'name (symbol->string name-sym))
     (list 'args)
     ;; rememeber that global vars need to be "depointerised" by one level
     (cons 'type (xtc:codegen:pretty-print-type (xtc:codegen:pointer-- (xtc:cache:get-globalvar-type (symbol->string name-sym)))))
     (cons 'docstring
           (let ((docstring (xtc:cache:get-globalvar-docstring (symbol->string name-sym))))
             (if (string=? docstring "") '() docstring))))))

(define xtmdoc-scheme-function-handler
  (lambda (name-sym)
    (list
     '(category . "scheme closure")
     (cons 'name (symbol->string name-sym))
     (cons 'args (xtmdoc-get-args-from-form (get-closure-code (eval name-sym))))
     (list 'type)
     (list 'docstring))))

(define xtmdoc-scheme-macro-handler
  (lambda (name-sym)
    (list
     '(category . "scheme macro")
     (cons 'name (symbol->string name-sym))
     (cons 'args (cadadr (caddr (get-closure-code (eval name-sym)))))
     (list 'type)
     (list 'docstring))))

(define xtmdoc-documentation-function
  (lambda (name)
    (let ((sym (string->symbol name)))
      (cond ((xtc:cache:builtin-exists? name)
             (cons 'xtmdoc-docstring (xtmdoc-builtin-handler sym)))
            ((xtc:cache:typealias-exists? name)
             (cons 'xtmdoc-docstring (xtmdoc-typealias-handler sym)))
            ((xtc:cache:genericfunc-exists? name)
             (cons 'xtmdoc-docstring (xtmdoc-genericfunc-handler sym)))
            ((xtc:cache:polyfunc-exists? name)
             (cons 'xtmdoc-docstring (xtmdoc-polyfunc-handler sym)))
            ((xtc:cache:closure-exists? name)
             (cons 'xtmdoc-docstring (xtmdoc-closure-handler sym)))
            ((xtc:cache:nativefunc-exists? name)
             (cons 'xtmdoc-docstring (xtmdoc-nativefunc-handler sym)))
            ((xtc:cache:globalvar-exists? name)
             (cons 'xtmdoc-docstring (xtmdoc-globalvar-handler sym)))
            ((xtc:cache:generictype-exists? name)
             (cons 'xtmdoc-docstring (xtmdoc-generictype-handler sym)))
            ((xtc:cache:polytype-exists? name)
             (cons 'xtmdoc-docstring (xtmdoc-polytype-handler sym)))
            ((xtc:cache:namedtype-exists? name)
             (cons 'xtmdoc-docstring (xtmdoc-namedtype-handler sym)))
            ((and (defined? sym) (closure? (eval sym)))
             (cons 'xtmdoc-docstring (xtmdoc-scheme-function-handler sym)))
            ((and (defined? sym) (macro? (eval sym)))
             (cons 'xtmdoc-docstring (xtmdoc-scheme-macro-handler sym)))
            (else
             '(xtmdoc-docstring-nodocstring))))))

;; sort the alists (as returned by the various handler functions) into
;; a reasonably meaningful order (least to most important)
(define xtmdoc-alist-lessthan
  (lambda (left right)
    (let ((categories '("C function"
                        "global var"
                        "polymorphic closure"
                        "polymorphic type"
                        "closure"
                        "named type"
                        "generic closure"
                        "generic type"
                        "type alias"
                        "builtin")))
      (let ((lpos (cl:position (cdr (assoc-strcmp 'category left)) categories))
            (rpos (cl:position (cdr (assoc-strcmp 'category right)) categories)))
        (if (<> lpos rpos)
            (< lpos rpos)
            (string<? (cdr (assoc-strcmp 'name left))
                      (cdr (assoc-strcmp 'name right))))))))

(define xtmdoc-clean-nativefunc-alist
  (lambda (closure-alists nativefunc-alists)
    (cl:remove-if
     (lambda (nativefunc-data)
       (let ((nativefunc-name (cdr (assoc-strcmp 'name nativefunc-data))))
         (cl:find-if (lambda (closure-data)
                       ;; is it a closure?
                       (string=? (cdr (assoc-strcmp 'name closure-data)) nativefunc-name))
                     closure-alists)))
     nativefunc-alists)))

(define xtmdoc-all-doc-alists
  (lambda (include-nativefuncs?)
    (let* ((closure-alists
            (map (lambda (data) (xtmdoc-closure-handler (string->symbol (car data))))
                 (hashtable->alist *xtc:cache:closure-cache*)))
           (all-doc-alists
            (append
             (map (lambda (data) (xtmdoc-builtin-handler (string->symbol (car data)))) (hashtable->alist *xtc:cache:builtin-cache*))
             (map (lambda (data) (xtmdoc-typealias-handler (string->symbol (car data)))) (hashtable->alist *xtc:cache:typealias-cache*))
             (map (lambda (data) (xtmdoc-generictype-handler (string->symbol (car data)))) (hashtable->alist *xtc:cache:generictype-cache*))
             (map (lambda (data) (xtmdoc-genericfunc-handler (string->symbol (car data)))) (hashtable->alist *xtc:cache:genericfunc-cache*))

             (map (lambda (data) (xtmdoc-namedtype-handler (string->symbol (car data)))) (hashtable->alist *xtc:cache:namedtype-cache*))
             closure-alists
             (map (lambda (data) (xtmdoc-polytype-handler (string->symbol (car data)))) (hashtable->alist *xtc:cache:polytype-cache*))
             (map (lambda (data) (xtmdoc-polyfunc-handler (string->symbol (car data)))) (hashtable->alist *xtc:cache:polyfunc-cache*))
             (map (lambda (data) (xtmdoc-globalvar-handler (string->symbol (car data)))) (hashtable->alist *xtc:cache:globalvar-cache*))
             ;; make sure the "_native" versions of each closure don't get in
             ;; there (since the closure is already there)
             (if include-nativefuncs?
                 (xtmdoc-clean-nativefunc-alist
                  closure-alists
                  (map (lambda (x)
                         (xtmdoc-nativefunc-handler (string->symbol (car x))))
                       (hashtable->alist *xtc:cache:nativefunc-cache*)))
                 '()))))
      ;; filter out the things which shouldn't make it to the exported docs
      (cl:remove-if
       (lambda (doc-alist)
         (regex:match? (cdr (assoc-strcmp 'name doc-alist))
                       "(_setter$|_scheme$|_native$|_maker$|_getter$|_callback$|_poly_)"))
       all-doc-alists))))

;; we handle the args field separately, since there are a few special
;; cases to handle
(define xtmdoc-write-alist-args-as-json
  (lambda (xtmdoc-alist file-port)
    ;; (println (cdr (assoc-strcmp 'name xtmdoc-alist)))
    (display ",\n  \"args\": " file-port)
    (let ((category (cdr (assoc-strcmp 'category xtmdoc-alist)))
          (args (cdr (assoc-strcmp 'args xtmdoc-alist)))
          (type (cdr (assoc-strcmp 'type xtmdoc-alist))))
      ;; arg names and types
      (cond
       ((member category '("closure" "generic closure"))
        (display
         (string-append
          "["
          (string-join (map (lambda (name type)
                              (string-append "[\"" (symbol->string name) "\", \"" type "\"]"))
                            (cons 'RETURN args)
                            (xtc:codegen:get-pretty-closure-arg-strings type))
                       ", ")
          "]")
         file-port))
       ((string=? category "builtin")
        (if (or (not (string? type))
                (string=? type "")
                (<> (length (cdr (xtc:codegen:get-pretty-closure-arg-strings type)))
                    (length args)))
            ;; allow builtins have malformed arg/type relationships
            (display
             (string-append
              "["
              (string-join (map (lambda (name)
                                  (string-append "[\"" (symbol->string name) "\", null]"))
                                args)
                           ", ")
              "]")
             file-port)
            (display
             (string-append
              "["
              (string-join (map (lambda (name type)
                                  (string-append "[\"" (symbol->string name) "\", \"" type "\"]"))
                                (cons 'RETURN args)
                                (xtc:codegen:get-pretty-closure-arg-strings type))
                           ", ")
              "]")
             file-port)))
       ((string=? category "C function")
        (display
         (string-append
          "["
          ;; at the moment, there's no way of telling the xtlang
          ;; compiler about the names of the arguments to a C function
          (string-join (map (lambda (type)
                              (string-append "[null, \"" type "\"]"))
                            (xtc:codegen:get-pretty-closure-arg-strings type))
                       ", ")
          "]")
         file-port))
       ;; these are the ones for which "args" doesn't make sense
       ;; "named type"
       ;; "generic type"
       ;; "polymorphic closure"
       ;; "global var"
       ;; "polymorphic type"
       ;; "type alias"
       (else (write 'null file-port))))))

(define xtmdoc-write-alist-as-json
  (lambda (xtmdoc-alist file-port)
    (display "{\n  \"category\": " file-port)
    (write (cdr (assoc-strcmp 'category xtmdoc-alist)) file-port)
    (display ",\n  \"name\": " file-port)
    (write (cdr (assoc-strcmp 'name xtmdoc-alist)) file-port)
    (xtmdoc-write-alist-args-as-json xtmdoc-alist file-port)
    (display ",\n  \"type\": " file-port)
    (let ((type (cdr (assoc-strcmp 'type xtmdoc-alist))))
      (write (if (null? type) 'null type) file-port))
    (display ",\n  \"docstring\": " file-port)
    (let ((docstring (cdr (assoc-strcmp 'docstring xtmdoc-alist))))
      (write (if (null? docstring) 'null docstring) file-port))
    (display "\n}" file-port)))

(define xtmdoc-export-caches-to-json
  (lambda (file-path include-nativefuncs?)
    (let ((outfile-port (open-output-file file-path)))
      (display "[\n" outfile-port)
      (let loop ((doc-alists (cl:sort (xtmdoc-all-doc-alists include-nativefuncs?)
                                      (lambda (a b) (not (xtmdoc-alist-lessthan a b))))))
        (if (null? doc-alists)
            (begin
              (display "\n]" outfile-port)
              (close-port outfile-port)
              (print "Succesfully exported docs as json to " file-path "\n")
              #t)
            (begin
              (xtmdoc-write-alist-as-json (car doc-alists) outfile-port)
              (if (not (null? (cdr doc-alists)))
                  (display ",\n" outfile-port))
              (loop (cdr doc-alists))))))))

(define-macro (xtc:bind:get-native-name closure-name . type)
  (let* ((pair (regex:type-split (symbol->string closure-name) ":"))
         (base (if (null? (cdr pair)) "" (xtc:codegen:get-base-type (cadr pair)))))
    (set! closure-name (symbol->string closure-name))
    (if (not (null? (cdr pair)))
        (string-append (car pair) "_adhoc_" (cname-encode base) "_native")
        (if (null? type)
            (if (and (xtc:cache:polyfunc-exists? closure-name)
                     (= (length (xtc:cache:get-polyfunc-candidate-types closure-name)) 1))
                (let* ((t (xtc:codegen:pretty-print-type (car (xtc:cache:get-polyfunc-candidate-types closure-name))))
                       (bt (xtc:codegen:get-base-type t))
                       (fullname (string-append closure-name
                                                "_adhoc_"
                                                (cname-encode bt)
                                                "_native")))
                  fullname)
                (xtc:diagnostics:print-compiler-error "Try forcing a type? Ambiguous call to get_native_fptr" (string->symbol closure-name)))
            (let* ((bt (xtc:codegen:get-base-type (symbol->string (car type))))
                   (fullname (string-append closure-name
                                            "_adhoc_"
                                            (cname-encode bt)
                                            "_native")))
              fullname)))))

(define-macro (xtc:bind:get-mono-name closure-name . type)
  (let* ((pair (regex:type-split (symbol->string closure-name) ":"))
         (base (if (null? (cdr pair)) "" (xtc:codegen:get-base-type (cadr pair)))))
    (set! closure-name (symbol->string closure-name))
    (if (not (null? (cdr pair)))
        (string-append (car pair) "_adhoc_" (cname-encode base) "_native")
        (if (null? type)
            (if (and (xtc:cache:polyfunc-exists? closure-name)
                     (= (length (xtc:cache:get-polyfunc-candidate-types closure-name)) 1))
                (let* ((t (xtc:codegen:pretty-print-type (car (xtc:cache:get-polyfunc-candidate-types closure-name))))
                       (bt (xtc:codegen:get-base-type t))
                       (fullname (string-append closure-name
                                                "_adhoc_"
                                                (cname-encode bt)
                                                "")))
                  fullname)
                (xtc:diagnostics:print-compiler-error "Try forcing a type? Ambiguous call to get_native_fptr" (string->symbol closure-name)))
            (let* ((bt (xtc:codegen:get-base-type (symbol->string (car type))))
                   (fullname (string-append closure-name
                                            "_adhoc_"
                                            (cname-encode bt)
                                            "")))
              fullname)))))


;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;
;; print ir & x86 assm
;;

(define-macro (llvm:ir name . type)
  (let ((t (if (null? type) #f (car type))))
    `(let* ((n1 ,(if t
                     `(xtc:bind:get-mono-name ,name ,t)
                     `(xtc:bind:get-mono-name ,name)))
            (n2 (llvm:get-closure-work-name n1)))
       ;; (println 'n1 n1 'n2 n2)
       (llvm:print-closure n2))))

(define-macro (llvm:asm name . args)
  (let* ((a1 (if (null? args) #f (car args)))
         (a2 (if (null? args) #f (if (null? (cdr args)) #f (cadr args))))
         (type (if (symbol? a1) a1 (if (symbol? a2) a2 #f)))
         (assm_print_type (if (number? a1) a1 (if (number? a2) a2 #f))))
    `(let ((n1 ,(if type
                    `(xtc:bind:get-mono-name ,name ,type)
                    `(xtc:bind:get-mono-name ,name))))
       ,(if (not assm_print_type)
            `(print (llvm:disassemble n1 0) "\n")
            `(print (llvm:disassemble n1 ,assm_print_type) "\n")))))


;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;
;; helper functions for constraint checking
;;
;; note that these need to take *xtc:codegen:notype* into acct
;;
;; in other words they should only fail for actual types
;; they should succeed against *xtc:codegen:notype*
;;

;; (define t:integer? (lambda (x) (or (equal? x *xtc:codegen:notype*) (xtc:codegen:fixed-point? x))))
;; (define t:float? (lambda (x) (or (equal? x *xtc:codegen:notype*) (xtc:codegen:floating-point? x))))
;; (define t:number? (lambda (x) (or (equal? x *xtc:codegen:notype*) (xtc:codegen:number? x))))
;; (define t:void? (lambda (x) (or (equal? x *xtc:codegen:notype*) (xtc:codegen:void? x))))
;; (define t:signed? (lambda (x) (or (equal? x *xtc:codegen:notype*) (xtc:codegen:signed? x))))
;; (define t:closure? (lambda (x) (or (equal? x *xtc:codegen:notype*) (xtc:codegen:closure? x))))
;; (define t:vector? (lambda (x) (or (equal? x *xtc:codegen:notype*) (xtc:codegen:vector? x))))
;; (define t:array? (lambda (x) (or (equal? x *xtc:codegen:notype*) (xtc:codegen:array? x))))
;; (define t:tuple? (lambda (x) (or (equal? x *xtc:codegen:notype*) (xtc:codegen:tuple? x))))
;; (define t:scalar? (lambda (x) (or (equal? x *xtc:codegen:notype*) (xtc:codegen:scalar? x))))
;; (define t:pointer? (lambda (x) (or (equal? x *xtc:codegen:notype*) (xtc:codegen:pointer? x))))
;; (define t:notype? (lambda (x) (equal? x *xtc:codegen:notype*)))

(define t:integer? (lambda (x) (if (string? x) (set! x (xtc:codegen:get-type-from-pretty-str x))) (xtc:codegen:fixed-point? x)))
(define t:float? (lambda (x) (if (string? x) (set! x (xtc:codegen:get-type-from-pretty-str x))) (xtc:codegen:floating-point? x)))
(define t:number? (lambda (x) (if (string? x) (set! x (xtc:codegen:get-type-from-pretty-str x))) (xtc:codegen:number? x)))
(define t:void? (lambda (x) (if (string? x) (set! x (xtc:codegen:get-type-from-pretty-str x))) (xtc:codegen:void? x)))
(define t:signed? (lambda (x) (if (string? x) (set! x (xtc:codegen:get-type-from-pretty-str x))) (xtc:codegen:signed? x)))
(define t:closure? (lambda (x) (if (string? x) (set! x (xtc:codegen:get-type-from-pretty-str x))) (xtc:codegen:closure? x)))
(define t:vector? (lambda (x) (if (string? x) (set! x (xtc:codegen:get-type-from-pretty-str x))) (xtc:codegen:vector? x)))
(define t:array? (lambda (x) (if (string? x) (set! x (xtc:codegen:get-type-from-pretty-str x))) (xtc:codegen:array? x)))
(define t:tuple? (lambda (x) (if (string? x) (set! x (xtc:codegen:get-type-from-pretty-str x))) (xtc:codegen:tuple? x)))
(define t:scalar? (lambda (x) (if (string? x) (set! x (xtc:codegen:get-type-from-pretty-str x))) (xtc:codegen:scalar? x)))
(define t:pointer? (lambda (x) (if (string? x) (set! x (xtc:codegen:get-type-from-pretty-str x))) (xtc:codegen:pointer? x)))
(define t:notype? (lambda (x) (if (string? x) (set! x (xtc:codegen:get-type-from-pretty-str x))) (equal? x *xtc:codegen:notype*)))

;; how many elements (or args for closure) does type have
;;
(define t:elts? (lambda (x num)
                  (if (string? x) (set! x (xtc:codegen:get-type-from-pretty-str x)))
                  (cond ((string? x) (= num -1))
                        ((or (t:array? x) (t:vector? x))
                         (= (cadr x) num))
                        ((t:tuple? x)
                         (= (- (length x) 1) num))
                        ((t:closure? x)
                         (= (- (length x) 2) num))
                        (else (= num 1)))))

;; closure with number of args
(define t:closure-size? (lambda (f num)
                          (if (string? f) (set! f (xtc:codegen:get-type-from-pretty-str f)))
                          (and (xtc:codegen:closure? f)
                               (t:elts? f num))))


;; named type check strips pointers!
;; (you can use t:pointer? fo
;; (define t:cleanup-string-type
;;   (lambda (a)
;;     (let* ((nt (xtc:cache:get-named-type (xtc:codegen:get-base-type (xtc:codegen:clean-named-type a))))
;;            (bt (xtc:codegen:get-base-type (xtc:codegen:clean-named-type a)))
;;            (ptrdepth (xtc:codegen:get-ptr-depth a))
;;            (strtype (xtc:codegen:pointer++ nt ptrdepth)))
;;       ;; (println 'bt bt 'ptrdepth ptrdepth 'nt nt 'strtype strtype)
;;       (apply string-append bt (make-list ptrdepth "*")))))

(define t:cleanup-string-type
  (lambda (a)
    (let* ((nt (xtc:cache:get-named-type (xtc:codegen:get-base-type (xtc:codegen:clean-named-type a))))
           (bt (xtc:codegen:get-base-type (xtc:codegen:clean-named-type a))))
      bt)))

(define reduce-ptrdepth-to-zero
  (lambda (t)
    (if (> (xtc:codegen:get-ptr-depth t) 0)
        (reduce-ptrdepth-to-zero (xtc:codegen:pointer-- t))
        t)))

(define t:named? (lambda (x y)
                   (if (or (t:notype? x) (t:notype? y))
                       #t
                       (begin
                         (if (symbol? x) (set! x (symbol->string x)))
                         (if (symbol? y) (set! y (symbol->string y)))
                         (if (string? x) (set! x (xtc:codegen:get-type-from-pretty-str x)))
                         (if (string? y) (set! y (xtc:codegen:get-type-from-pretty-str y)))
                         (set! x (reduce-ptrdepth-to-zero x))
                         (set! y (reduce-ptrdepth-to-zero y))
                         ;; (println 'x x 'y y)
                         (if (and (string? x) (string? y))
                             (if (string=? (t:cleanup-string-type x) (t:cleanup-string-type y))
                                 #t
                                 #f)
                             (xtc:codegen:types-equal? x y))))))

