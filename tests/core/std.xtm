(bind-func test_String_cat_1
   (lambda ()
     (println (cat (String "string1 ")
                          (String "string2")))))
(xtmtest-runs (test_String_cat_1))

(bind-func test_cat2
   (lambda ()
     (println (cat (String "string1 ")
                          (String "string2 ")
                          (String "string3 ")
                          (String "string4 ")
                          (String "string5 ")
                          (String "string6 ")
                          (String "string7 ")
                          (String "string8")))))
(xtmtest-runs (test_cat2))
