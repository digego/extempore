;;; math.xtm:tests -- test for the math library

;; Author: Ben Swift
;; Keywords: extempore
;; Required dylibs:

;;; Commentary:

;; Tests for libs/core/math.xtm

;;; Code:

(sys:load "libs/core/math.xtm")
(sys:load "libs/core/rational.xtm")

(bind-func test_gcd
   (lambda ()
     (Rational_greatest_common_divisor 4 12)))
(xtmtest-result (test_gcd) 4)

(bind-func test_rat_reduce
   (lambda ()
     (println "3/6 =" (Rational_reduce 3/6))
     (println "-2/12 =" (Rational_reduce -2/12))))
(xtmtest-runs (test_rat_reduce))

(bind-func test_overload_rational_addition
   (lambda ()
     (println (+ 1/3 2/3))))
(xtmtest-runs (test_overload_rational_addition))

(bind-func test_overload_rational_subtraction
   (lambda ()
     (println (- 1/3 2/3))))
(xtmtest-runs (test_overload_rational_subtraction))

(bind-func test_overload_rational_multiplication
   (lambda ()
     (println (* 1/3 2/3))))
(xtmtest-runs (test_overload_rational_multiplication))

(bind-func test_overload_rational_division
   (lambda ()
     (println (/ 1/3 2/3))))
(xtmtest-runs (test_overload_rational_division))

(bind-func test_rational_equal
   (lambda ()
     (= 3/4 6/8)))
(xtmtest-result (test_rational_equal) 1)

(bind-func test_rational_notequal
   (lambda ()
     (<> 3/4 6/8)))
(xtmtest-result (test_rational_notequal) 0)

(bind-func test_rational_lessthan
   (lambda ()
     (< 1/2 3/4)))
(xtmtest-result (test_rational_lessthan) 1)

(bind-func test_rational_greaterthan
   (lambda ()
     (> 1/2 3/4)))
(xtmtest-result (test_rational_greaterthan) 0)

;; some more complicated tests

(bind-func test_operator_overloading_1
   (lambda ()
     (= (* (Rat 4 3) (Rat 1 2))
        (/ (Rat 12 3) (Rat 12 2)))))
(xtmtest-result (test_operator_overloading_1) 1)

;; Complexd number tests

(bind-func test_complex_addition
   (lambda ()
     (println (+ (Cpxd 2. 0.4)
                 (Cpxd 5.4 6.)))))
(xtmtest-runs (test_complex_addition))

(bind-func test_complex_multiplication_1
   (lambda ()
     (println (* 1+1i 0+1i))))
(xtmtest-runs (test_complex_multiplication_1))

(bind-func test_complex_multiplication_2
   (lambda ()
     (println (* 1+1i 1.0))))
(xtmtest-runs (test_complex_multiplication_2))

(bind-func test_clampi32
   (lambda ()
     (and (= (clamp 5:i32 0:i32 3:i32) 3)
          (= (clamp -4:i32 0:i32 3:i32) 0)
          (= (clamp 1:i32 0:i32 3:i32) 1))))
(xtmtest-result (test_clampi32) 1)

(bind-func test_clampi64
   (lambda ()
     (and (= (clamp 5 0 3) 3)
          (= (clamp -4 0 3) 0)
          (= (clamp 1 0 3) 1))))
(xtmtest-result (test_clampi64) 1)

(bind-func test_clampf
   (lambda ()
     (and (= (clamp 5. 0.4 3.3) 3.3)
          (= (clamp -4. 0.4 3.3) 0.4)
          (= (clamp 1. 0.4 3.3) 1.))))
(xtmtest-result (test_clampf) 1)

(bind-func test_clampd
   (lambda ()
     (and (= (clamp 5. 0.4 3.3) 3.3)
          (= (clamp -4. 0.4 3.3) 0.4)
          (= (clamp 1. 0.4 3.3) 1.))))
(xtmtest-result (test_clampd) 1)

(bind-func test_vcopy_unpack
   (lambda ()
     (let ((src:float* (salloc 4))
           (dest:float* (salloc 8)))
       (pfill! src 4. 5. 6. 7.)
       (vcopy_unpack src dest 4 2 2)
       (and (= (pref dest 0) 4.)
            (= (pref dest 1) 5.)
            (= (pref dest 4) 6.)
            (= (pref dest 5) 7.)))))
(xtmtest-result (test_vcopy_unpack) 1)

(bind-func test_vcopy_pack
   (lambda ()
     (let ((src:float* (salloc 8))
           (dest:float* (salloc 4)))
       (pfill! src 0. 1. 2. 3. 4. 5. 6. 7.)
       (vcopy_pack src dest 4 2 2)
       (vsum dest 4))))
(xtmtest-result (test_vcopy_pack) 10.)

(bind-func test_vcopy_pack1
   (lambda ()
     (let ((src:double* (salloc 8))
           (dest:double* (salloc 4)))
       (pfill! src 0. 1. 2. 3. 4. 5. 6. 7.)
       (vcopy_pack src dest 4 2 2)
       (vsum dest 4))))
(xtmtest-result (test_vcopy_pack1) 10.)

(bind-func test_histogram_float
   (lambda ()
     (let ((buf:float* (salloc 8))
           (hist:HistBin* (salloc 4)))
       (pfill! buf 0. 1. 2. 3. 4. 5. 6. 7.)
       (set! hist (histogram hist buf 8 4))
       (doloop (i 4)
         (println (pref-ptr hist i)))
       (and (= (tref (pref hist 1) 0) 1.75)
            (= (tref (pref hist 1) 1) 2.0)))))
(xtmtest-result (test_histogram_float) 1)

(bind-func test_rowmaj_idx_2D
   (lambda ()
     (letz ((m:i64* (zalloc 6)))
       (pfill! m 0 1 2 3 4 5)
       (and (= (pref m (rowmaj_idx_2D 0 0 3)) 0)
            (= (pref m (rowmaj_idx_2D 0 1 3)) 1)
            (= (pref m (rowmaj_idx_2D 0 2 3)) 2)
            (= (pref m (rowmaj_idx_2D 1 0 3)) 3)
            (= (pref m (rowmaj_idx_2D 1 1 3)) 4)
            (= (pref m (rowmaj_idx_2D 1 2 3)) 5)))))
(xtmtest-result (test_rowmaj_idx_2D) 1)

(bind-func test_colmaj_idx_2D
   (lambda ()
     (letz ((m:i64* (zalloc 6)))
       (pfill! m 0 3 1 4 2 5)
       (and (= (pref m (colmaj_idx_2D 0 0 2)) 0)
            (= (pref m (colmaj_idx_2D 0 1 2)) 1)
            (= (pref m (colmaj_idx_2D 0 2 2)) 2)
            (= (pref m (colmaj_idx_2D 1 0 2)) 3)
            (= (pref m (colmaj_idx_2D 1 1 2)) 4)
            (= (pref m (colmaj_idx_2D 1 2 2)) 5)))))
(xtmtest-result (test_colmaj_idx_2D) 1)

;; diff e^x
(bind-func test-diff1
  (lambda ()
    (let ((a (ndiff (lambda (x) (exp x)) 5.0))
          (b ((lambda (x:double) (exp x)) 5.0)))
      (println 'diff_a a 'diff_b b)
      (if (< (fabs (- a b)) .0001) 1 0))))
(xtmtest-result (test-diff1) 1)

;; diff sin x
(bind-func test-diff2
   (lambda ()
     (let ((a (ndiff (lambda (x) (sin x)) 5.0))
           (b ((lambda (x:double) (cos x)) 5.0)))
      (println 'diff_a a 'diff_b b)
       (if (< (fabs (- a b)) .0001) 1 0))))
(xtmtest-result (test-diff2) 1)

;; diff x^2
(bind-func test-diff3
   (lambda ()
     (let ((a (ndiff (lambda (x) (* x x)) 5.0))
           (b ((lambda (x:double) (* 2.0 x)) 5.0)))
       (println 'diff_a a 'diff_b b)
       (if (< (fabs (- a b)) .0001) 1 0))))
(xtmtest-result (test-diff3) 1)

;; diff ln x
(bind-func test-diff4
   (lambda ()
     (let ((a (ndiff (lambda (x) (log x)) 5.0))
           (b ((lambda (x:double) (/ 1.0 x)) 5.0)))
       (println 'diff_a a 'diff_b b)
       (if (< (fabs (- a b)) .0001) 1 0))))
(xtmtest-result (test-diff4) 1)


;; integrate x^2 [4,5]
(bind-func test-intgrate1
   (lambda ()
     (let ((a (nintegrate (lambda (x) (* x x)) 4.0 5.0))
           (b (- ((lambda (x:double) (* (/ 1.0 3.0) (* x x x))) 5.0)
                 ((lambda (x:double) (* (/ 1.0 3.0) (* x x x))) 4.0))))
       (println 'integrate_a a 'integrate_b b)
       (if (< (fabs (- a b)) .0001) 1 0))))
(xtmtest-result (test-intgrate1) 1)

;; integrate
(bind-func test-integrate2
   (lambda ()
     (let ((a (nintegrate (lambda (x) (sin x)) 0.0 2.0))
           (b (- ((lambda (x:double) (* -1.0 (cos x))) 2.0)
                 ((lambda (x:double) (* -1.0 (cos x))) 0.0))))
       (if (< (fabs (- a b)) .0001) 1 0))))
(xtmtest-result (test-integrate2) 1)


;; RNG builtins.  Salvaged here (the only place they now run in CI) when the
;; decade-orphaned tests/core/builtins.xtm was retired.  The xtc_rand* family
;; was renamed from imp_rand* in TASK-061.
(bind-func test-xtc-rand
   (lambda ()
     (if (and (< (xtc_rand2_f 0. 10.) 10.)
              (< (xtc_rand1_f 10.) 10.)
              (< (xtc_rand2_d 0. 10.) 10.)
              (< (xtc_rand1_d 10.) 10.)
              (< (xtc_rand2_i32 0 10) 10)
              (< (xtc_rand1_i32 10) 10)
              (< (xtc_rand2_i64 0 10) 10)
              (< (xtc_rand1_i64 10) 10)
              (< (xtc_randf) 1.0)
              (< (xtc_randd) 1.0))
         1 0)))
(xtmtest-result (test-xtc-rand) 1)

;; the deprecated imp_rand* spellings still resolve via the desugar aliases in
;; xtc:desugar:transform-atom (TASK-061; aliases removed in TASK-063)
(bind-func test-imp-rand-alias
   (lambda ()
     (if (and (< (imp_rand2_f 0. 10.) 10.)
              (< (imp_rand1_i64 10) 10)
              (< (imp_randd) 1.0))
         1 0)))
(xtmtest-result (test-imp-rand-alias) 1)
