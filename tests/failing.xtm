;;; failing.xtm -- a place for failing tests

;; Author: Ben Swift
;; Keywords: extempore
;; Required dylibs:

;;; Commentary:

;; failing tests go here first. once the bug is fixed, the test should
;; be moved into the appropriate test file.

;;; Code:

;; An untyped argument used only as a doloop bound is not pinned to an integer:
;; the constraint engine reports "couldn't resolve type" rather than inferring
;; nx:i64 from the loop count. (The typed-count sibling now compiles and lives
;; in tests/core/type-system.xtm.)
(bind-func dotimes_type_quirk_1
  (lambda (nx)
    (doloop (x nx)
      x)
    nx))
(xtmtest-result (integer? (dotimes_type_quirk_1 2)) #t)
