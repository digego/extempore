;;; tests/compiler/typeunify.xtm -- unit tests for type unification

(sys:load "libs/core/test.xtm")

(xtmtest-result (xtc:desugar:type-unify '(2) '())
                2
                "single-si64")

(xtmtest-result (xtc:desugar:type-unify '(2 2) '())
                2
                "identical-si64")

(xtmtest-result (xtc:desugar:type-unify '(2 4) '())
                '(2 4)
                "si64-and-si32")

(xtmtest-result (xtc:desugar:type-unify '(0) '())
                0
                "single-fp64")

(xtmtest-result (xtc:desugar:type-unify 2 '())
                2
                "atom-passthrough")

(xtmtest-result (xtc:desugar:type-unify '() '())
                '()
                "null-input")

(xtmtest-result (xtc:desugar:type-unify '(4) '())
                4
                "single-si32")

(xtmtest-result (xtc:desugar:type-unify '((213 2 4)) '())
                '(213 2 4)
                "closure-type")

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; characterisation: union simplification and pruning                      ;;
;;                                                                         ;;
;; The cases below pin the *current* behaviour of the old candidate-list   ;;
;; unifier, captured from the live function, ahead of routing inference    ;;
;; through the canonical Robinson core (xtc:type:unify, TASK-059).  Unlike ;;
;; Robinson unification of two terms, this function collapses a *set* of   ;;
;; candidate types for one expression: it dedups, keeps genuinely distinct ;;
;; bases as a union (the list-valued results below), flattens singleton    ;;
;; nesting, and applies the "number-crunch" heuristics that pick a common  ;;
;; member out of a choice of sets.  Whatever replaces it must reproduce    ;;
;; these outcomes, so they are frozen here as the behavioural spec.        ;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

;; duplicate base codes collapse; genuinely distinct ones survive as a union
(xtmtest-result (xtc:desugar:type-unify '(2 2 4) '())
                '(2 4)
                "dedup-then-union")

(xtmtest-result (xtc:desugar:type-unify '(4 2 2) '())
                '(4 2)
                "dedup-preserves-order")

;; pointer codes behave as ordinary distinct atoms: equal ones merge, a
;; pointer and its pointee do not
(xtmtest-result (xtc:desugar:type-unify '(102 102) '())
                102
                "same-pointer-dedup")

(xtmtest-result (xtc:desugar:type-unify '(102 2) '())
                '(102 2)
                "pointer-vs-base-union")

;; identical compound types collapse to the single type; a tuple and a
;; pointer-to-that-tuple are distinct and survive as a union
(xtmtest-result (xtc:desugar:type-unify '((14 2 0) (14 2 0)) '())
                '(14 2 0)
                "identical-tuples-collapse")

(xtmtest-result (xtc:desugar:type-unify '((14 2 0) (114 2 0)) '())
                '((14 2 0) (114 2 0))
                "tuple-vs-ptr-tuple-union")

(xtmtest-result (xtc:desugar:type-unify '((213 2 4) (213 2 4)) '())
                '(213 2 4)
                "identical-closures-collapse")

(xtmtest-result (xtc:desugar:type-unify '((213 2 4) (213 2 2)) '())
                '((213 2 4) (213 2 2))
                "distinct-closures-union")

;; singleton nesting is flattened away
(xtmtest-result (xtc:desugar:type-unify '(2 (2)) '())
                2
                "nested-singleton-flatten")

(xtmtest-result (xtc:desugar:type-unify '((2) (2)) '())
                2
                "list-of-singletons-collapse")

;; "number-crunch": when the candidates are a single base together with sets
;; that contain it, the base wins; given only sets, the wider set is kept
(xtmtest-result (xtc:desugar:type-unify '(0 (0 1)) '())
                0
                "crunch-member-collapses")

(xtmtest-result (xtc:desugar:type-unify '((0 1) 1) '())
                1
                "crunch-pick-member")

(xtmtest-result (xtc:desugar:type-unify '((0 1) (0 1 2)) '())
                '(0 1 2)
                "crunch-wider-set")

(xtmtest-result (xtc:desugar:type-unify '(0 (0 1) (0 1 2)) '())
                0
                "crunch-common-element")
