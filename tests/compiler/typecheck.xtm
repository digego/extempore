;;; tests/compiler/typecheck.xtm -- unit tests for type inference

(sys:load "libs/core/test.xtm")

;; literal types

(xtmtest-result (xtc:bind:get-expression-type 42)
                2
                "integer-literal")

(xtmtest-result (xtc:bind:get-expression-type 4.0)
                0
                "float-literal")

(xtmtest-result (xtc:bind:get-expression-type #t)
                10
                "boolean-literal")

;; arithmetic

(xtmtest-result (xtc:bind:get-expression-type '(+ 1 2))
                2
                "arithmetic")

(xtmtest-result (xtc:bind:get-expression-type '(* 3 4))
                2
                "multiply")

(xtmtest-result (xtc:bind:get-expression-type '(- 10 5))
                2
                "subtract")

;; if expression

(xtmtest-result (xtc:bind:get-expression-type '(if #t 1 2))
                2
                "if-expression")

;; let expression

(xtmtest-result (xtc:bind:get-expression-type '(let ((x:i64 1)) x))
                2
                "let-expression")

(xtmtest-result (xtc:bind:get-expression-type '(let ((x:i64 1) (y:i64 2)) (+ x y)))
                2
                "nested-let")

;; lambda

(xtmtest-result (xtc:bind:get-expression-type '(lambda (x:i64) (+ x 1)))
                '(213 2 2)
                "lambda")

(xtmtest-with-fixture lambda-two-args
                      (define typ (xtc:bind:get-expression-type '(lambda (x:i64 y:i64) (+ x y))))
                      (is? (car typ) 213 "closure-tag")
                      (is? (length typ) 4 "three-type-slots"))

;; nested let

(xtmtest-result (xtc:bind:get-expression-type '(let ((x:i64 1)) (let ((y:i64 2)) (+ x y))))
                2
                "nested-let-scopes")

;; boolean operations via if

(xtmtest-result (xtc:bind:get-expression-type '(if #t #t #f))
                10
                "if-boolean-result")

;; multi-arg arithmetic (binary arity normalisation)

(xtmtest-result (xtc:bind:get-expression-type '(+ 1 2 3))
                2
                "multi-arg-add")

(xtmtest-result (xtc:bind:get-expression-type '(* 1 2 3 4))
                2
                "multi-arg-mul")

;; float arithmetic

(xtmtest-result (xtc:bind:get-expression-type '(+ 1.0 2.0))
                0
                "float-add")

;; let with float

(xtmtest-result (xtc:bind:get-expression-type '(let ((x:double 1.0)) (+ x 2.0)))
                0
                "let-float")

;; begin expression (type of last expression)

(xtmtest-result (xtc:bind:get-expression-type '(let ((x:i64 1)) (begin x)))
                2
                "begin-expr")
