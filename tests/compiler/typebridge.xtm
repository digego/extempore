;;; tests/compiler/typebridge.xtm -- conversions between canonical terms and
;;; the live int-code representation (runtime/xtc-types-bridge.xtm)
;;;
;;; The corpus below is ground truth taken from the existing parser
;;; (impc:ir:get-type-from-pretty-str), so a passing round-trip certifies that
;;; the canonical representation is faithful to the encoding the rest of the
;;; compiler already uses.

(sys:load "libs/core/test.xtm")
(sys:load "runtime/xtc-types.xtm")
(sys:load "runtime/xtc-types-bridge.xtm")

;;;;;;;;;;;;;;;;;;;;;;;;;;
;; round-trip corpus   ;;
;;;;;;;;;;;;;;;;;;;;;;;;;;

;; For every int-code, decoding to a term then re-encoding must be the
;; identity.  The test returns the codes that fail to round-trip, so a failure
;; names exactly which encodings broke; an empty list means all passed.
(xtmtest-result
 (let ((corpus (list 2 102 202 0 1 4 108 10
                     '(14 2 0) '(114 2 0) '(214 2 0)
                     '(15 4 2) '(115 4 2) '(16 4 1)
                     '(113 2 2) '(213 2 2) '(313 2 2)
                     '(14 2 (14 0 1)) '(14 2 (114 0 1))
                     '(213 2 (114 0 1))
                     '(15 3 (14 2 0)))))
   (cl:remove-if
    (lambda (ic)
      (equal? ic (impc:type:to-intcode (impc:type:from-intcode ic (make-hashtable)))))
    corpus))
 '()
 "intcode-roundtrip")

;;;;;;;;;;;;;;;;;;;;;;;;;;
;; explicit decode     ;;
;;;;;;;;;;;;;;;;;;;;;;;;;;

(xtmtest-result (impc:type:from-intcode 102 (make-hashtable))
                (impc:type:ptr 'i64)
                "decode-pointer")

(xtmtest-result (impc:type:from-intcode '(114 2 0) (make-hashtable))
                (impc:type:ptr (impc:type:tuple 'i64 'f64))
                "decode-pointer-tuple")

;; the everyday boxed closure decodes to a pointer-to-closure
(xtmtest-result (impc:type:from-intcode '(213 2 2) (make-hashtable))
                (impc:type:ptr (impc:type:closure 'i64 'i64))
                "decode-boxed-closure")

;; the bare (unboxed) closure has no extra pointer
(xtmtest-result (impc:type:from-intcode '(113 2 2) (make-hashtable))
                (impc:type:closure 'i64 'i64)
                "decode-bare-closure")

(xtmtest-result (impc:type:from-intcode '(15 4 2) (make-hashtable))
                (impc:type:array 4 'i64)
                "decode-array")

;;;;;;;;;;;;;;;;;;;;;;;;;;
;; explicit encode     ;;
;;;;;;;;;;;;;;;;;;;;;;;;;;

(xtmtest-result (impc:type:to-intcode (impc:type:ptr (impc:type:tuple 'i64 'f64)))
                '(114 2 0)
                "encode-pointer-tuple")

(xtmtest-result (impc:type:to-intcode (impc:type:ptr (impc:type:closure 'i64 'i64)))
                '(213 2 2)
                "encode-boxed-closure")

;;;;;;;;;;;;;;;;;;;;;;;;;;
;; named types         ;;
;;;;;;;;;;;;;;;;;;;;;;;;;;

(xtmtest-result (impc:type:from-intcode "%string" (make-hashtable))
                (impc:type:named "string")
                "decode-named")

(xtmtest-result (impc:type:to-intcode (impc:type:ptr (impc:type:named "string")))
                "%string*"
                "encode-named-pointer")

(xtmtest-result (impc:type:to-intcode
                 (impc:type:from-intcode "%foo**" (make-hashtable)))
                "%foo**"
                "named-roundtrip")

;;;;;;;;;;;;;;;;;;;;;;;;;;
;; bang-variable intern ;;
;;;;;;;;;;;;;;;;;;;;;;;;;;

;; !a and !a* share one variable (the inner term of !a* is !a) --- this is the
;; pointer-depth-bearing variable whose absence causes #315.
(xtmtest-result (let ((tbl (make-hashtable)))
                  (let ((a  (impc:type:from-intcode '!a tbl))
                        (a* (impc:type:from-intcode '!a* tbl)))
                    (equal? a (impc:type:ptr-to a*))))
                #t
                "bang-shares-across-depth")

;; the same call-site suffix interns to the same variable ...
(xtmtest-result (let ((tbl (make-hashtable)))
                  (equal? (impc:type:from-intcode (string->symbol "!a##3") tbl)
                          (impc:type:from-intcode (string->symbol "!a##3") tbl)))
                #t
                "bang-same-callsite")

;; ... but distinct call sites do not.
(xtmtest-result (let ((tbl (make-hashtable)))
                  (equal? (impc:type:from-intcode (string->symbol "!a##3") tbl)
                          (impc:type:from-intcode (string->symbol "!a##7") tbl)))
                #f
                "bang-distinct-callsites")

;;;;;;;;;;;;;;;;;;;;;;;;;;
;; pretty <-> term     ;;
;;;;;;;;;;;;;;;;;;;;;;;;;;

;; Parsing a surface type string then rendering it back is the identity, for
;; concrete types and for types carrying bang variables alike --- the property
;; the canonical reification relies on.
(xtmtest-result
 (let ((corpus (list "i64" "i64*" "double" "<i64,double>" "<i64,double>*"
                     "[i64,i64]*" "|4,double|" "/4,float/"
                     "!a*" "<!a*,i64>" "<!a*,!b>" "<!a,<!b,i64>>")))
   (cl:remove-if
    (lambda (s)
      (let* ((tbl (make-hashtable)) (term (impc:type:from-pretty s tbl)))
        (string=? s (impc:type:to-pretty term tbl))))
    corpus))
 '()
 "pretty-roundtrip")

;; a tuple field !a* parses to a pointer-to-variable
(xtmtest-result (let ((tbl (make-hashtable)))
                  (impc:type:ptr? (cadr (impc:type:from-pretty "<!a*,i64>" tbl))))
                #t
                "pretty-field-is-pointer")

;; !a and !a* in one type share a single variable
(xtmtest-result (let* ((tbl (make-hashtable))
                       (term (impc:type:from-pretty "<!a,!a*>" tbl)))
                  (equal? (cadr term) (impc:type:ptr-to (caddr term))))
                #t
                "pretty-shares-variable")

;; substituting the variable's binding reifies the field with its depth intact
(xtmtest-result (let* ((tbl (make-hashtable))
                       (term (impc:type:from-pretty "<!a*,i64>" tbl))
                       (v (impc:type:from-pretty "!a" tbl))
                       (subst (impc:type:unify v 'i64 impc:type:empty-subst)))
                  (impc:type:to-pretty (impc:type:apply-subst term subst) tbl))
                "<i64*,i64>"
                "reify-keeps-depth")

;;;;;;;;;;;;;;;;;;;;;;;;;;
;; pointer-depth core  ;;
;;;;;;;;;;;;;;;;;;;;;;;;;;

;; reduce and deepen are structural inverses on concrete int-codes.  This is the
;; #315 parameter/field relationship made structural: a type variable's depth-0
;; binding (its base, !a = i64) re-deepens to the starred occurrence (!a* =
;; i64*), and a depth-1 value strips back to the base, both via the unifier
;; rather than star arithmetic.
(xtmtest-result (impc:type:deepen-ptr-depth 2 1) 102 "deepen-base")
(xtmtest-result (impc:type:deepen-ptr-depth 2 2) 202 "deepen-twice")
(xtmtest-result (impc:type:deepen-ptr-depth '(14 2 0) 1) '(114 2 0) "deepen-tuple")
(xtmtest-result (impc:type:deepen-ptr-depth "%Foo" 1) "%Foo*" "deepen-named")
(xtmtest-result (impc:type:reduce-ptr-depth (impc:type:deepen-ptr-depth 2 2) 2)
                2 "deepen-reduce-roundtrip")

;; a concrete value shallower than the requested reduction has no inverse: the
;; unifier reports 'fail rather than underflowing to a bogus code.  (update-var
;; reads this to drop the #315 conflation of !a* with a depth-0 value.)
(xtmtest-result (impc:type:reduce-ptr-depth 2 1) 'fail "reduce-underflow-fails")

;; the type parameters of a template are its free variables by identity ---
;; depth-independent, deduplicated, in first-seen order --- the bare !a, never
;; the field usage !a*.
(xtmtest-result (impc:type:pretty-type-params "<!a*,i64>")  '("!a")      "params-depth1")
(xtmtest-result (impc:type:pretty-type-params "<!a**,i64>") '("!a")      "params-depth2")
(xtmtest-result (impc:type:pretty-type-params "<!a*,!b>")   '("!a" "!b") "params-two")
(xtmtest-result (impc:type:pretty-type-params "<!a,!a*>")   '("!a")      "params-shared")
