# Ensure consistent line endings across platforms
* text=auto

# LLVM IR files must use LF line endings (the C++ regex parser expects this)
*.ll text eol=lf

# Other source files
*.cpp text
*.h text
*.hpp text
*.xtm text eol=lf
*.scm text eol=lf

# Binary files
*.png binary
*.jpg binary
*.wav binary
*.aif binary
*.aiff binary
*.bc binary
